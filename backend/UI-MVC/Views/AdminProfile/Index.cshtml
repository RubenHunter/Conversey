@using Conversey.BL.Domain.Administration
@using Conversey.UI_MVC.Models
@using Conversey.UI_MVC.Resources
@model Conversey.UI_MVC.Models.Admin.AdminProfileViewModel
@inject AdminContext AdminContext
@inject WorkspaceContext WorkspaceContext
@inject IAdminI18nService I18n
@{
    var isWorkspaceAdmin = AdminContext.CurrentAdmin is WorkspaceAdmin;
    var workspaceName = isWorkspaceAdmin
        ? WorkspaceContext.CurrentWorkspace?.Name ?? "Workspace"
        : "Conversey";

    ViewData["Title"] = I18n["Profile"];
    ViewData["WorkspaceName"] = workspaceName;
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        (I18n["Profile"], null, true)
    };
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto">
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-text tracking-tight">@I18n["Profile settings"]</h1>
            <p class="mt-2 text-sm text-text/60">@I18n["Update your account details and security settings."]</p>
        </div>

        @if (TempData["ProfileSaved"] is string savedMessage)
        {
            <div class="mb-6 rounded-xl border border-primary/20 bg-primary/5 px-4 py-3 text-sm font-medium text-primary">
                @savedMessage
            </div>
        }

        <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
            <section class="xl:col-span-2 rounded-2xl border border-secondary/10 bg-white p-6 shadow-sm">
                <div class="mb-6">
                    <h2 class="text-lg font-bold text-text">@I18n["Account information"]</h2>
                    <p class="mt-1 text-sm text-text/55">@I18n["Changes apply to this admin account login profile."]</p>
                </div>

                <form asp-controller="AdminProfile" asp-action="Index" method="post" class="space-y-5">
                    <div asp-validation-summary="ModelOnly" class="rounded-xl border border-accent/30 bg-accent/5 px-4 py-3 text-sm text-accent"></div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="md:col-span-2">
                            <label asp-for="Username" class="mb-2 block text-sm font-semibold text-text/80"></label>
                            <input asp-for="Username"
                                   class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text placeholder:text-text/35 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25" />
                            <span asp-validation-for="Username" class="mt-1 block text-sm text-accent"></span>
                        </div>

                        <div>
                            <label asp-for="Email" class="mb-2 block text-sm font-semibold text-text/80"></label>
                            <input asp-for="Email" type="email"
                                   class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text placeholder:text-text/35 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25" />
                            <span asp-validation-for="Email" class="mt-1 block text-sm text-accent"></span>
                        </div>

                        <div>
                            <label asp-for="PhoneNumber" class="mb-2 block text-sm font-semibold text-text/80"></label>
                            <input asp-for="PhoneNumber" type="tel"
                                   class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text placeholder:text-text/35 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25" />
                            <span asp-validation-for="PhoneNumber" class="mt-1 block text-sm text-accent"></span>
                        </div>
                    </div>

                    <div class="pt-2">
                        <button type="submit"
                                class="inline-flex items-center justify-center rounded-xl bg-primary px-5 py-2.5 text-sm font-bold text-white shadow-sm shadow-primary/20 transition hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-primary/30">
                            @I18n["Save changes"]
                        </button>
                    </div>
                </form>
            </section>

            <aside class="rounded-2xl border border-secondary/10 bg-white p-6 shadow-sm h-fit">
                <h2 class="text-lg font-bold text-text">@I18n["Security"]</h2>
                <p class="mt-2 text-sm text-text/55">
                    @I18n["Use a strong password with uppercase letters, numbers, and symbols."]
                </p>

                <button id="openChangePasswordModal"
                        type="button"
                        class="mt-6 w-full rounded-xl border border-accent/30 bg-accent/5 px-4 py-2.5 text-sm font-bold text-accent transition hover:bg-accent/10">
                    @I18n["Change password"]
                </button>

                <p id="passwordModalInfo"
                   class="mt-3 hidden rounded-lg border border-secondary/20 bg-background px-3 py-2 text-xs text-text/60"></p>
            </aside>
        </div>
    </main>
</div>

<div id="changePasswordModal" class="fixed inset-0 hidden items-center justify-center bg-text/45 p-4">
    <div class="w-full max-w-md rounded-2xl border border-secondary/10 bg-white p-6 shadow-xl">
        <div class="mb-4">
            <h3 class="text-xl font-bold text-text">@I18n["Change password"]</h3>
            <p class="mt-1 text-sm text-text/60">@I18n["Enter your current password and your new password."]</p>
        </div>

        <form id="changePasswordForm" class="space-y-4">
            <div>
                <label for="currentPassword" class="mb-1 block text-sm font-semibold text-text/80">@I18n["Current password"]</label>
                <input id="currentPassword" name="currentPassword" type="password" required
                       class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25" />
            </div>

            <div>
                <label for="newPassword" class="mb-1 block text-sm font-semibold text-text/80">@I18n["New password"]</label>
                <input id="newPassword" name="newPassword" type="password" required
                       class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25" />
            </div>

            <div>
                <label for="confirmPassword" class="mb-1 block text-sm font-semibold text-text/80">@I18n["Confirm new password"]</label>
                <input id="confirmPassword" name="confirmPassword" type="password" required
                       class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25" />
            </div>

            <p id="passwordModalError" class="hidden text-sm font-medium text-accent"></p>

            <div class="mt-6 flex justify-end gap-3">
                <button id="cancelChangePassword" type="button"
                        class="rounded-xl border border-secondary/20 px-4 py-2 text-sm font-semibold text-text/70 transition hover:bg-background">
                    @I18n["Cancel"]
                </button>
                <button type="submit"
                        class="rounded-xl bg-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary/90">
                    @I18n["Update password"]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script type="module" vite-src="~/components/shared/adminProfilePasswordModal.ts"></script>
}
