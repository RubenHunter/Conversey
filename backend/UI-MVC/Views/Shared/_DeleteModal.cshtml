<div id="deleteModal"
     class="fixed inset-0 hidden items-center justify-center bg-black/50">

    <div class="w-full max-w-md rounded-lg bg-white p-6 shadow-lg">

        <h2 class="text-lg font-semibold text-gray-900">
            Confirm deletion
        </h2>

        <p class="mt-2 text-sm text-gray-600">
            Are you sure you want to delete
            <span id="deleteItemName" class="font-medium text-gray-900"></span>?
        </p>

        <div class="mt-6 flex justify-end gap-3">

            <button id="cancelDelete"
                    type="button"
                    class="rounded-md border px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                Cancel
            </button>

            <button id="confirmDelete"
                    type="button"
                    class="rounded-md bg-red-600 px-4 py-2 text-sm text-white hover:bg-red-700">
                Delete
            </button>

        </div>
    </div>
</div>

<div id="toast"
     class="fixed bottom-5 right-5 hidden rounded-md bg-green-600 px-4 py-2 text-white shadow-lg">
</div>


