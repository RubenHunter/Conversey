<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="/Assets/Conversey_logo.png" />

    @inject Dictionary<string, string> Manifest
    @{
        var cssFile = Manifest.GetValueOrDefault("main.css", "main.css");
        var jsFile = Manifest.GetValueOrDefault("main.ts", "main.ts");
    }
    <link rel="stylesheet" href="/@cssFile" />
    <script type="module" src="/@jsFile"></script>
</head>
<body>
	<div id="app" class="min-h-screen flex flex-col items-center justify-center gap-8">
		@RenderBody()
	</div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
