<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="/images/Conversey_logo.png" asp-append-version="true" />

    <script type="module" vite-src="~/main.ts"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <link rel="stylesheet" vite-href="~/main.ts" asp-append-version="true" />
</head>
<body>
    <div class="bg-blue-500 text-white p-2 text-center">DEBUG: Layout is geladen</div>
	<div id="app" class="min-h-screen flex flex-col items-center justify-center gap-8">
		@RenderBody()
	</div>
</body>
</html>
