@model Conversey.UI_MVC.Models.Admin.ComparisonWidgetViewModel
@{
    bool hasToggle = Model.AllItems.Any();
    string DotClass(string c) => c switch { "secondary" => "bg-secondary", "accent" => "bg-accent", _ => "bg-primary" };
    string CircleClass(string c) => c switch { "secondary" => "bg-secondary/20 border-secondary", "accent" => "bg-accent/20 border-accent", _ => "bg-primary/20 border-primary" };
}

<div class="bg-white rounded-xl border border-secondary/10 shadow-sm h-full p-5 comparison-widget"
     data-comparison-widget="@Model.Id"
     data-items="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items.Select(i => new { label = i.Label, value = i.Value, color = i.Color })))"
     data-all-items="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllItems.Select(i => new { label = i.Label, value = i.Value, color = i.Color })))">
    <div class="flex h-full gap-4">
        <!-- Left: titles + legend -->
        <div class="flex flex-col justify-between min-w-[130px] shrink-0">
            <div>
                @if (hasToggle)
                {
                    <div class="comparison-toggle-group mb-1" role="group">
                        <button type="button" class="comparison-toggle active" data-mode="primary">@Model.Title</button>
                        <button type="button" class="comparison-toggle" data-mode="all">@Model.SubTitle</button>
                    </div>
                }
                else
                {
                    <div>
                        <span class="font-semibold text-sm text-text block">@Model.Title</span>
                        <span class="text-xs text-text/40 block mt-0.5">@Model.SubTitle</span>
                    </div>
                }
            </div>

            <div class="space-y-2 legend-container">
                @foreach (var item in Model.Items)
                {
                    <div class="flex items-center gap-2 legend-item cursor-pointer" data-item-id="@item.Label">
                        <div class="w-2.5 h-2.5 rounded-full shrink-0 @DotClass(item.Color) legend-dot"></div>
                        <span class="text-xs text-text/70 truncate">@item.Label</span>
                    </div>
                }
            </div>
        </div>

        <!-- Right: radial circles (sized and positioned by TS) -->
        <div class="flex-1 relative circle-container overflow-hidden" id="circles-@Model.Id">
            @{
                double maxValue = Model.Items.Any() ? Model.Items.Max(i => (double)i.Value) : 1;
                if (maxValue == 0) maxValue = 1;
                int count = Model.Items.Count;
                double angleStep = count > 0 ? 360.0 / count : 0;
            }
            @foreach (var item in Model.Items)
            {
                int index = Model.Items.IndexOf(item);
                double angle = angleStep * index - 90;
                double valueRatio = item.Value / maxValue;

                <div class="absolute circle-item"
                     data-item-id="@item.Label"
                     data-angle="@angle.ToString("F1")"
                     data-value="@item.Value"
                     data-value-ratio="@valueRatio.ToString("F4")"
                     data-color="@item.Color">
                    <div class="rounded-full flex items-center justify-center shadow-sm border-2 transition-all duration-300 @CircleClass(item.Color)">
                        <span class="font-semibold text-text text-xs circle-value">@item.Value</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
