@model Conversey.UI_MVC.Models.Admin.ComparisonWidgetViewModel
@{
    bool hasToggle = Model.AllItems.Any();

    string LegendColor(string c) => c switch
    {
        "secondary" => "#db99c8",
        "accent"    => "#cd6f88",
        _           => "#6c5ce7"
    };
}

<div class="bg-white rounded-xl border border-secondary/10 shadow-sm h-full p-5 comparison-widget"
     data-comparison-widget="@Model.Id"
     data-items='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items.Select(i => new { label = i.Label, value = i.Value, color = i.Color })))'
     data-all-items='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllItems.Select(i => new { label = i.Label, value = i.Value, color = i.Color })))'>

    <div class="flex flex-col h-full gap-3">

        @* Toggle pill at top *@
        @if (hasToggle)
        {
            <div class="comparison-toggle-group self-start" role="group">
                <button type="button" class="comparison-toggle active" data-mode="primary">@Model.Title</button>
                <button type="button" class="comparison-toggle" data-mode="all">@Model.SubTitle</button>
            </div>
        }
        else
        {
            <div>
                <span class="font-semibold text-sm text-text">@Model.Title</span>
                <span class="text-xs text-text/40 block mt-0.5">@Model.SubTitle</span>
            </div>
        }

        @* Circles area — fills remaining space *@
        <div class="flex-1 relative circle-container overflow-hidden min-h-[120px]" id="circles-@Model.Id">
            @foreach (var item in Model.Items)
            {
                <div class="absolute circle-item"
                     data-item-id="@item.Label"
                     data-value="@item.Value"
                     data-color="@item.Color">
                    <div class="rounded-full flex items-center justify-center shadow-sm transition-all duration-300">
                        <span class="font-semibold text-white circle-value text-xs">@item.Value</span>
                    </div>
                </div>
            }
        </div>

        @* Legend at bottom *@
        <div class="space-y-1.5 legend-container shrink-0">
            @foreach (var item in Model.Items)
            {
                <div class="flex items-center gap-2 legend-item cursor-pointer" data-item-id="@item.Label">
                    <div class="w-3.5 h-2 rounded shrink-0 legend-dot" style="background-color: @LegendColor(item.Color)"></div>
                    <span class="text-xs text-text/70 truncate">@item.Label</span>
                </div>
            }
        </div>

    </div>
</div>
