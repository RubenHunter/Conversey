@model Conversey.UI_MVC.Models.Admin.StatWidgetViewModel

<div class="bg-gradient-to-br from-white to-primary/[0.03] rounded-xl border border-secondary/10 p-5 relative overflow-hidden stat-widget">
    <span class="text-[10px] text-secondary uppercase font-bold tracking-wider block" data-i18n="@Model.Label">
        @Model.Label
    </span>
    <div class="text-2xl font-bold text-text mt-1 tabular-nums">@Model.Value</div>
    @if (!string.IsNullOrEmpty(Model.SubLabel))
    {
        <p class="text-xs text-text/60 mt-1" data-i18n="@Model.SubLabel">@Model.SubLabel</p>
    }
</div>
