@model Conversey.UI_MVC.Models.Admin.EngagementWidgetViewModel
@{
    double radius = 40;
    double circumference = (270.0 / 360.0) * 2 * Math.PI * radius;
    double gaugePct = Math.Min(Model.GaugePercentage, 100);
    double strokeOffset = circumference * (1 - gaugePct / 100.0);
}

<div class="bg-white rounded-xl border border-secondary/10 shadow-sm h-full p-5">
    <h2 class="text-sm font-semibold text-text" data-i18n="@Model.Title">@Model.Title</h2>

    @* 270° circular gauge *@
    <div class="flex flex-col items-center mb-5">
        <div class="relative w-32 h-32">
            <svg viewBox="0 0 100 100" class="w-full h-full" aria-hidden="true">
                @* Track arc — from bottom-left to bottom-right, 270° clockwise *@
                <path d="M 21.72 78.28 A 40 40 0 1 1 78.28 78.28"
                      fill="none" stroke="currentColor"
                      class="text-secondary/20" stroke-width="8" stroke-linecap="round"/>
                @* Filled arc *@
                <path d="M 21.72 78.28 A 40 40 0 1 1 78.28 78.28"
                      fill="none" stroke="currentColor"
                      class="@Model.GaugeColor gauge-arc-fill" stroke-width="8" stroke-linecap="round"
                      stroke-dasharray="@circumference.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                      stroke-dashoffset="@strokeOffset.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                      style="--gauge-circumference:@circumference.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);--gauge-offset:@strokeOffset.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"/>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-2xl font-bold text-text leading-none tabular-nums">@Model.GaugePercentage%</span>
            </div>
        </div>
        <span class="text-xs text-text/50 mt-1" data-i18n="@Model.GaugeLabel">@Model.GaugeLabel</span>
    </div>

    @* Progress Bars *@
    <div class="space-y-4">
        @{ int barIndex = 0; }
        @foreach (var bar in Model.Bars)
        {
            <div>
                <div class="flex justify-between text-xs mb-1">
                    <span class="font-semibold text-text/70 truncate max-w-[60%]" data-i18n="@bar.Label">@bar.Label</span>
                    <span class="text-text/40 flex-shrink-0 text-right ml-2" data-i18n="@bar.SubLabel">@bar.SubLabel</span>
                </div>
                <div class="relative w-full h-5 bg-secondary/10 rounded-full overflow-hidden">
                    <div class="h-full rounded-full @bar.ColorClass engagement-bar"
                         style="width: @bar.Percentage%; --bar-delay: @((0.5 + barIndex * 0.12).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))s"></div>
                    <span class="absolute inset-0 flex items-center justify-center text-[10px] font-semibold text-white mix-blend-difference">
                        @bar.DisplayValue
                    </span>
                </div>
            </div>
            barIndex++;
        }
    </div>
</div>
