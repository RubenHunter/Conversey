@model Conversey.UI_MVC.Models.Admin.QuickLinkItemViewModel
@{
    string iconStyle = !string.IsNullOrEmpty(Model.IconBgHex) && !string.IsNullOrEmpty(Model.IconFgHex)
        ? $"background-color:{Model.IconBgHex}; color:{Model.IconFgHex}"
        : string.Empty;
}

<a href="@Model.NavigateUrl"
   class="w-full bg-white rounded-xl border border-secondary/10 shadow-sm p-5
          flex items-center gap-4 hover:shadow-md hover:border-primary/20
          transition-all group quick-link-card"
   data-quick-link="true"
   data-title="@Model.Title"
   data-description="@Model.Description"
   data-navigate-url="@Model.NavigateUrl"
   @(Model.IsModal ? $"data-modal-target=\"{Model.ModalTarget}\"" : "")>
    <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="@iconStyle">
        @Html.Raw(Model.Icon)
    </div>
    <div>
        <span class="font-semibold text-text group-hover:text-primary transition-colors block" data-i18n="@Model.Title">
            @Model.Title
        </span>
        <span class="text-xs text-text/50 mt-0.5 block" data-i18n="@Model.Description">@Model.Description</span>
    </div>
</a>
