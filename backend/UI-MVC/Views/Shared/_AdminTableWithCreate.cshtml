@using Microsoft.AspNetCore.Html
@using Conversey.UI_MVC.Resources
@model dynamic

@inject IAdminI18nService I18n

@{
    var columns = Model.Columns as IEnumerable<dynamic> ?? [];
    var items = Model.Items as IEnumerable<dynamic> ?? [];
    var enumerable = items.ToList();
    var hasItems = enumerable.Any();
    var objects = columns.ToList();
    var columnCount = objects.Count();
}

<div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <div class="overflow-hidden rounded-md border border-gray-200">
        <!-- Header -->
        <div class="flex items-center justify-between gap-4 border-b border-gray-200 bg-gray-50 px-4 py-3">
            <div>
                <h2 class="text-xl font-semibold text-gray-900">@Model.SectionTitle</h2>
                <p class="mt-1 text-sm text-gray-600">@Model.TableDescription</p>
            </div>
            <a
                href="@Model.CreateUrl"
                class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-indigo-600 text-white shadow-sm transition hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
                aria-label="@Model.CreateButtonLabel"
                title="@Model.CreateButtonLabel">
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path d="M10 4.25a.75.75 0 0 1 .75.75v4.25H15a.75.75 0 0 1 0 1.5h-4.25V15a.75.75 0 0 1-1.5 0v-4.25H5a.75.75 0 0 1 0-1.5h4.25V5a.75.75 0 0 1 .75-.75Z"/>
                </svg>
            </a>
        </div>

        <!-- Table -->
        <table class="min-w-full divide-y divide-gray-200">
            <!-- Head -->
            <thead class="bg-gray-50">
                <tr>
                    @foreach (var col in objects)
                    {
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-700">
                            @col.Header
                        </th>
                    }
                </tr>
            </thead>
            
            <!-- Body -->
            <tbody class="divide-y divide-gray-100 bg-white">
            @if (!hasItems)
            {
                <tr>
                    <td colspan="@columnCount" class="px-4 py-10 text-center text-sm text-gray-500">
                        @Model.EmptyState
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in enumerable)
                {
                    <tr data-row-id="@Model.RowId(item)" class="hover:bg-gray-50">
                        @foreach (var col in objects)
                        {
                            <td class="px-4 py-3 text-sm text-gray-700">
                                @col.Template(item)
                            </td>
                        }
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
