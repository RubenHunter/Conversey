@{
    var sectionTitle = ViewData["SectionTitle"] as string ?? "Items";
    var tableDescription = ViewData["TableDescription"] as string ?? "Overview";
    var createUrl = ViewData["CreateUrl"] as string ?? "#";
    var createButtonLabel = ViewData["CreateButtonLabel"] as string ?? "Add item";
    var emptyState = ViewData["EmptyState"] as string ?? "No items yet.";
    var columnHeaders = ViewData["ColumnHeaders"] as IEnumerable<string> ?? Array.Empty<string>();
    var headerCount = 0;
    foreach (var _ in columnHeaders)
    {
        headerCount++;
    }
    if (headerCount == 0)
    {
        headerCount = 1;
    }
}

<div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <div class="overflow-hidden rounded-md border border-gray-200">
        <div class="flex items-center justify-between gap-4 border-b border-gray-200 bg-gray-50 px-4 py-3">
            <div>
                <h2 class="text-xl font-semibold text-gray-900">@sectionTitle</h2>
                <p class="mt-1 text-sm text-gray-600">@tableDescription</p>
            </div>
            <a
                href="@createUrl"
                class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-indigo-600 text-white shadow-sm transition hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
                aria-label="@createButtonLabel"
                title="@createButtonLabel">
                <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path d="M10 4.25a.75.75 0 0 1 .75.75v4.25H15a.75.75 0 0 1 0 1.5h-4.25V15a.75.75 0 0 1-1.5 0v-4.25H5a.75.75 0 0 1 0-1.5h4.25V5a.75.75 0 0 1 .75-.75Z" />
                </svg>
            </a>
        </div>

        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    @foreach (var header in columnHeaders)
                    {
                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-700">@header</th>
                    }
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
                <tr>
                    <td colspan="@headerCount" class="px-4 py-10 text-center text-sm text-gray-500">
                        @emptyState
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
