<div id="contactModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-text/45 p-4">
    <div class="w-full max-w-2xl rounded-2xl border border-secondary/10 bg-white shadow-xl max-h-[90vh] flex flex-col">
        <div class="px-6 py-4 border-b border-secondary/10 flex items-center justify-between shrink-0">
            <h3 class="text-lg font-bold text-text" data-i18n="Send Email">Send Email</h3>
            <button id="closeContactModal" class="p-1 text-text/40 hover:text-text rounded-lg hover:bg-background transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <div class="p-6 space-y-4 overflow-y-auto">
            <div>
                <label class="block text-sm font-semibold text-text/80 mb-1" data-i18n="To">To</label>
                <input id="contactToEmail" type="email" readonly class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text/60 cursor-not-allowed" />
            </div>

            <div id="contactIdeaSelectWrapper">
                <label class="block text-sm font-semibold text-text/80 mb-1" data-i18n="Select idea to reference">Select idea to reference</label>
                <select id="contactIdeaSelect" class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25">
                    <option value="" data-i18n="(no idea reference)">(no idea reference)</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold text-text/80 mb-1" data-i18n="Template">Template</label>
                <select id="contactTemplateSelect" class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25">
                    <option value="" data-i18n="Custom message">Custom message</option>
                    <option value="liked" data-i18n="We liked your idea">We liked your idea</option>
                    <option value="thanks" data-i18n="Thank you for your idea">Thank you for your idea</option>
                    <option value="followup" data-i18n="Follow-up question about your idea">Follow-up question about your idea</option>
                    <option value="selected" data-i18n="Your idea has been selected">Your idea has been selected</option>
                    <option value="update" data-i18n="Update on your submitted idea">Update on your submitted idea</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold text-text/80 mb-1" data-i18n="Subject">Subject</label>
                <input id="contactSubject" type="text" class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-text/80 mb-1" data-i18n="Message">Message</label>
                <textarea id="contactBody" rows="8" class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-3 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25 resize-y"></textarea>
            </div>

            <div id="contactError" class="hidden text-sm font-medium text-accent bg-accent/5 rounded-xl px-4 py-2"></div>
            <div id="contactSuccess" class="hidden text-sm font-medium text-emerald-600 bg-emerald-50 rounded-xl px-4 py-2" data-i18n="Email sent successfully!">Email sent successfully!</div>
        </div>

        <div class="px-6 py-4 border-t border-secondary/10 flex justify-end gap-3 shrink-0">
            <button id="cancelContactBtn" class="rounded-xl border border-secondary/20 px-4 py-2 text-sm font-semibold text-text/70 hover:bg-background transition-colors" data-i18n="Cancel">Cancel</button>
            <button id="sendContactBtn" class="rounded-xl bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                <span id="sendContactBtnText" data-i18n="Send Email">Send Email</span>
                <span id="sendContactBtnSpinner" style="display:none" data-i18n="Sending...">Sending...</span>
            </button>
        </div>
    </div>
</div>

<script>
(function() {
    var t = function(key, fallback) {
        var dict = window.__AdminI18n?.strings;
        if (dict && dict[key] !== undefined) return dict[key];
        return fallback ?? key;
    };

    var workspaceName = document.querySelector('[data-workspace-name]')?.dataset.workspaceName || 'Conversey Team';

    var modal = document.getElementById('contactModal');
    var closeBtn = document.getElementById('closeContactModal');
    var cancelBtn = document.getElementById('cancelContactBtn');
    var sendBtn = document.getElementById('sendContactBtn');
    var sendBtnText = document.getElementById('sendContactBtnText');
    var sendBtnSpinner = document.getElementById('sendContactBtnSpinner');
    var toEmail = document.getElementById('contactToEmail');
    var ideaSelect = document.getElementById('contactIdeaSelect');
    var ideaSelectWrapper = document.getElementById('contactIdeaSelectWrapper');
    var templateSelect = document.getElementById('contactTemplateSelect');
    var subject = document.getElementById('contactSubject');
    var body = document.getElementById('contactBody');
    var error = document.getElementById('contactError');
    var success = document.getElementById('contactSuccess');

    var currentYouthId = null;
    var currentEmail = null;
    var currentIdeas = [];
    var selectedIdeaIdx = null;

    var templatePatterns = {
        liked: {
            subject: t('We liked your idea'),
            body: function(idea, ws) { return t('Hello,') + '\n\n' + t('We really liked your idea about:') + '\n"' + idea + '"\n\n' + t('We would like to discuss it further with you.') + '\n\n' + t('Best regards,') + '\n' + ws; }
        },
        thanks: {
            subject: t('Thank you for your idea'),
            body: function(idea, ws) { return t('Hello,') + '\n\n' + t('Thank you for sharing your idea about:') + '\n"' + idea + '"\n\n' + t('We appreciate your contribution and will review it carefully.') + '\n\n' + t('Best regards,') + '\n' + ws; }
        },
        followup: {
            subject: t('Follow-up question about your idea'),
            body: function(idea, ws) { return t('Hello,') + '\n\n' + t('We have a question regarding your idea:') + '\n"' + idea + '"\n\n' + t('Could you tell us more about it?') + '\n\n' + t('Best regards,') + '\n' + ws; }
        },
        selected: {
            subject: t('Your idea has been selected'),
            body: function(idea, ws) { return t('Hello,') + '\n\n' + t('Great news! Your idea about:') + '\n"' + idea + '"\n\n' + t('has been selected for further discussion. We will be in touch with next steps.') + '\n\n' + t('Best regards,') + '\n' + ws; }
        },
        update: {
            subject: t('Update on your submitted idea'),
            body: function(idea, ws) { return t('Hello,') + '\n\n' + t('We wanted to give you an update on your idea:') + '\n"' + idea + '"\n\n' + t('It is currently under review by our team.') + '\n\n' + t('Best regards,') + '\n' + ws; }
        }
    };

    window.openContactModal = function(youthId, email, ideas, preselectedIdeaIdx) {
        currentYouthId = youthId;
        currentEmail = email;
        currentIdeas = ideas || [];
        selectedIdeaIdx = preselectedIdeaIdx !== undefined ? preselectedIdeaIdx : null;
        toEmail.value = email;

        if (currentIdeas.length > 0) {
            ideaSelectWrapper.style.display = '';
            ideaSelect.innerHTML = '<option value="">' + t('(no idea reference)') + '</option>';
            currentIdeas.forEach(function(idea, i) {
                var text = idea.Content || '';
                var truncated = text.length > 80 ? text.substring(0, 80) + '...' : text;
                var sel = i === selectedIdeaIdx ? ' selected' : '';
                ideaSelect.innerHTML += '<option value="' + i + '"' + sel + '>' + truncated + '</option>';
            });
        } else {
            ideaSelectWrapper.style.display = 'none';
        }

        templateSelect.value = '';
        subject.value = '';
        body.value = '';
        error.classList.add('hidden');
        success.classList.add('hidden');

        if (selectedIdeaIdx !== null && selectedIdeaIdx !== undefined && currentIdeas[selectedIdeaIdx]) {
            templateSelect.value = 'thanks';
            templateSelect.dispatchEvent(new Event('change'));
        }

        modal.classList.remove('hidden');
        modal.classList.add('flex');
    };

    window.closeContactModal = function() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    };

    closeBtn.addEventListener('click', window.closeContactModal);
    cancelBtn.addEventListener('click', window.closeContactModal);
    modal.addEventListener('click', function(e) {
        if (e.target === modal) window.closeContactModal();
    });

    templateSelect.addEventListener('change', function() {
        var ideaIdx = ideaSelect.value;
        var ideaText = '';
        if (ideaIdx !== '' && currentIdeas[ideaIdx]) {
            ideaText = currentIdeas[ideaIdx].Content || '';
        }

        var pattern = templatePatterns[templateSelect.value];
        if (pattern) {
            subject.value = pattern.subject;
            body.value = pattern.body(ideaText, workspaceName);
        }
    });

    ideaSelect.addEventListener('change', function() {
        if (templateSelect.value) {
            templateSelect.dispatchEvent(new Event('change'));
        }
    });

    sendBtn.addEventListener('click', async function() {
        if (!subject.value.trim() || !body.value.trim()) {
            error.textContent = t('Subject and message are required.', 'Subject and message are required.');
            error.classList.remove('hidden');
            return;
        }

        error.classList.add('hidden');
        success.classList.add('hidden');
        sendBtn.disabled = true;
        sendBtnText.style.display = 'none';
        sendBtnSpinner.style.display = 'inline';

        try {
            var resp = await fetch('/admin/contacts/send', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify({
                    youthId: currentYouthId || null,
                    toEmail: currentEmail,
                    subject: subject.value.trim(),
                    body: body.value.trim()
                })
            });

            if (resp.ok) {
                success.classList.remove('hidden');
                setTimeout(window.closeContactModal, 2000);
            } else {
                var data = await resp.json();
                error.textContent = data.error || t('Failed to send email.', 'Failed to send email.');
                error.classList.remove('hidden');
            }
        } catch (e) {
            error.textContent = t('Network error. Please try again.', 'Network error. Please try again.');
            error.classList.remove('hidden');
        } finally {
            sendBtn.disabled = false;
            sendBtnText.style.display = '';
            sendBtnSpinner.style.display = 'none';
        }
    });

    document.querySelectorAll('.contact-admin-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var email = btn.getAttribute('data-contact-email');
            if (email) {
                window.openContactModal(null, email, [], null);
            }
        });
    });
})();
</script>
