@using Conversey.BL.Domain.Administration
@using Conversey.UI_MVC.Models
@using Conversey.UI_MVC.Resources
@inject AdminContext AdminContext
@inject IAdminI18nService AdminI18n



<header id="admin-header" class="w-full flex items-center justify-between px-8 py-3 border-b border-secondary/10 bg-white sticky top-0 z-50 shadow-sm">
    <!-- Left Section -->
    <div class="flex items-center space-x-4">
        <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white shadow-sm shadow-primary/20">
            <span class="font-bold text-xs">C</span>
        </div>

        <div class="h-6 w-px bg-secondary/20"></div>

        <div class="flex flex-col">
            <span class="text-[10px] uppercase tracking-widest font-bold text-secondary">
                @(ViewData["WorkspaceName"] ?? "Workspace")
            </span>
            <nav class="flex items-center space-x-2 text-sm">
                @{
                    var breadcrumbList = ViewData["Breadcrumbs"] as (string Label, string? Url, bool IsCurrent)[];
                }
                @if (breadcrumbList != null && breadcrumbList.Length > 0)
                {
                    for (var i = 0; i < breadcrumbList.Length; i++)
                    {
                        var crumb = breadcrumbList[i];
                        if (!string.IsNullOrWhiteSpace(crumb.Url) && !crumb.IsCurrent)
                        {
                            <a href="@crumb.Url" class="font-semibold text-text hover:text-primary transition-colors">
                                @crumb.Label
                            </a>
                        }
                        else
                        {
                            <span class="font-semibold text-text/70">@crumb.Label</span>
                        }

                        if (i < breadcrumbList.Length - 1)
                        {
                            <svg class="w-4 h-4 text-secondary/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        }
                    }
                }
                else
                {
                    <a href="@AdminContext.GetDashboardUrl()" class="font-semibold text-text hover:text-primary transition-colors" data-i18n="Dashboard">
                        @(ViewData["Breadcrumb"] ?? "Dashboard")
                    </a>
                    <svg class="w-4 h-4 text-secondary/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                }
            </nav>
        </div>
    </div>

    <div class="flex items-center gap-3">
        <span class="hidden lg:flex text-xs font-medium bg-background px-3 py-1 rounded-full border border-secondary/10 text-text/60" data-i18n="Admin Portal">
            Admin Portal
        </span>
    </div>

    <div class="flex items-center gap-3">
        <div class="relative lang-dropdown">
            <button type="button" class="lang-toggle flex items-center gap-1 px-2 py-1 text-xs font-semibold rounded-md border border-secondary/30 bg-white text-text/60 hover:text-primary hover:border-primary/30 transition-colors" aria-label="Change language" aria-haspopup="true" aria-expanded="false">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10A15.3 15.3 0 0112 2z"/>
                </svg>
                <span>@AdminI18n.CurrentLanguage.ToUpperInvariant()</span>
                <span class="text-[0.65rem] leading-none opacity-70" aria-hidden="true">&#x25BE;</span>
            </button>
            <div class="lang-menu hidden absolute right-0 mt-1.5 bg-white rounded-lg border border-secondary/10 shadow-lg py-1 z-50 min-w-[100px]">
                @foreach (var lang in AdminI18n.SupportedLanguages)
                {
                    var isCurrent = lang == AdminI18n.CurrentLanguage;
                    <a href="@Url.Action("SetLanguage", "AiAdmin", new { lang = lang, returnUrl = Context.Request.Path + Context.Request.QueryString })"
                       class="block w-full text-left px-3 py-1.5 text-xs font-semibold rounded transition-colors@(isCurrent ? " bg-primary/5 text-primary" : " text-text/70 hover:bg-background/50")">
                        @lang.ToUpperInvariant()
                    </a>
                }
            </div>
        </div>

        <button class="relative text-secondary hover:text-primary transition-colors">
            <div class="absolute top-0 right-0 w-2 h-2 bg-accent rounded-full border-2 border-white"></div>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
            </svg>
        </button>
    </div>
</header>

@if (AdminContext.CurrentAdmin is ConverseyAdmin)
{
    @await Html.PartialAsync("_AdminSidebarConversey")
}
else if (AdminContext.CurrentAdmin is WorkspaceAdmin)
{
    @await Html.PartialAsync("_AdminSidebarWorkspace")
}
