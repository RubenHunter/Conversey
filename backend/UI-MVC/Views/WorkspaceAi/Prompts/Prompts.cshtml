@using Conversey.UI_MVC.Models
@using Conversey.BL.Domain.Administration
@model Conversey.UI_MVC.Models.WorkspaceAi.WorkspaceAiPromptsViewModel
@inject AdminContext AdminContext
@{
    ViewData["Title"] = "AI Prompts";
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-text tracking-tight" data-i18n="Prompts">Prompts</h1>
                <p class="mt-1 text-sm text-text/60" data-i18n="Customize the AI's user-facing instructions per project context. These prompts shape how the AI interacts with participants.">Customize the AI's user-facing instructions per project context. These prompts shape how the AI interacts with participants.</p>
            </div>
            <a href="@Url.Action("Dashboard", new { workspaceSlug = Model.WorkspaceId })" class="text-sm text-primary hover:text-primary/80 transition-colors flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                <span data-i18n="Back to AI Settings">Back to AI Settings</span>
            </a>
        </div>

        <div class="flex flex-col md:flex-row gap-4 mb-6">
            <div class="relative flex-1">
                <input type="text" id="promptSearch" placeholder="Search prompts..." value="@Model.SearchQuery"
                       class="w-full pl-10 pr-4 py-2 bg-white border border-secondary/20 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all shadow-sm text-sm" data-i18n-placeholder="Search prompts..." />
                <span class="absolute left-3 top-2.5 text-secondary">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </span>
            </div>
            <div class="w-full md:w-64">
                <select id="projectFilter" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                    <option value="" data-i18n="Global (all projects)">Global (all projects)</option>
                    @foreach (var p in Model.Projects)
                    {
                        <option value="@p.Id.ToString()" selected="@(Model.SelectedProjectId == p.Id.ToString())">@p.Name</option>
                    }
                </select>
            </div>
        </div>

        <div class="mb-4 px-1">
            <span class="text-xs font-medium text-text/50">
                @if (string.IsNullOrEmpty(Model.SelectedProjectId))
                {
                    <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-primary"></span> <span data-i18n="Showing global prompts">Showing global prompts</span> — <span data-i18n="used as defaults for all projects">used as defaults for all projects</span></span>
                }
                else
                {
                    var proj = Model.Projects.FirstOrDefault(p => p.Id.ToString() == Model.SelectedProjectId);
                    <span class="inline-flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-secondary"></span> <span data-i18n="Showing project-specific prompts for">Showing project-specific prompts for</span> <strong class="text-text">@proj?.Name</strong></span>
                }
            </span>
        </div>

        <div class="space-y-4" id="promptsList">
            @foreach (var prompt in Model.Prompts)
            {
                @await Html.PartialAsync("_PromptCard", (
                    Prompt: prompt,
                    EditUrl: Url.Action("EditPrompt", new { workspaceSlug = Model.WorkspaceId, id = prompt.Id, projectId = Model.SelectedProjectId }),
                    HasOverride: false
                ))
            }
        </div>
    </main>
</div>

<script>window.__PromptsBaseUrl = '@Url.Action("Prompts", new { workspaceSlug = Model.WorkspaceId })';</script>
<script type="module" vite-src="~/components/aiAdmin/promptsPage.ts"></script>
