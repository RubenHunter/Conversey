@using Conversey.BL.Domain.Administration
@using Conversey.UI_MVC.Models
@using Conversey.UI_MVC.Models.Admin
@model IEnumerable<Conversey.BL.Domain.Administration.Workspace>
@inject AdminContext AdminContext
@Html.AntiForgeryToken()

@{
    ViewData["Title"] = "Workspaces";
    ViewData["WorkspaceName"] = "Conversey Platform";
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        ("Dashboard", AdminContext.GetDashboardUrl(), false),
        ("Workspaces", null, true)
    };
    var workspaces = Model ?? [];

    var tableModel = new AdminTableViewModel<Workspace>
    {
        SectionTitle = "All Workspaces",
        TableDescription = "Manage all workspaces for Conversey",
        CreateUrl = Url.Action("CreateWorkspace", "ConverseyAdmin"),
        CreateButtonLabel = "Create new Workspace",
        EmptyState = "Workspaces will show up here once they are created.",
        RowId = w => w.Id.Text,

        Items = workspaces.ToList(),

        Columns =
        [
            new()
            {
                Header = "ID",
                Template = w =>
                {
                    var span = new TagBuilder("span");
                    span.InnerHtml.Append(w.Id.Text);
                    return span;
                }
            },
            new()
            {
                Header = "Name",
                Template = w =>
                {
                    var link = new TagBuilder("a")
                    {
                        Attributes =
                        {
                            ["href"] = Url.Action("WorkspaceDetails", "ConverseyAdmin", new { id = w.Id.Text })!
                        }
                    };
                    link.AddCssClass("text-indigo-600 hover:underline");
                    link.InnerHtml.Append(w.Name ?? "-");
                    return link;
                }
            },

            new()
            {
                Header = "Actions",
                Template = w =>
                {
                    var container = new TagBuilder("div");
                    container.AddCssClass("flex gap-3");

                    // EDIT BUTTON
                    var edit = new TagBuilder("a")
                    {
                        Attributes =
                        {
                            ["href"] = Url.Action("EditWorkspace", "ConverseyAdmin", new { id = w.Id.Text })!,
                            ["data-i18n"] = "Edit"
                        }
                    };
                    edit.AddCssClass("text-blue-600 hover:underline");
                    edit.InnerHtml.Append("Edit");

                    var divider = new TagBuilder("p");
                    divider.InnerHtml.Append("|");

                    // DELETE BUTTON
                    var delete = new TagBuilder("button")
                    {
                        Attributes =
                        {
                            ["type"] = "button",
                            ["data-delete-id"] = w.Id.Text,
                            ["data-delete-name"] = w.Name ?? "-",
                            ["data-delete-endpoint"] = $"/admin/workspace/delete/{w.Id.Text}",
                            ["data-i18n"] = "Delete"
                        }
                    };

                    delete.AddCssClass("text-red-600 hover:underline");
                    delete.InnerHtml.Append("Delete");

                    container.InnerHtml.AppendHtml(edit);
                    container.InnerHtml.AppendHtml(divider);
                    container.InnerHtml.AppendHtml(delete);

                    return container;
                }
            }
        ]
    };
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-5xl mx-auto">
        @await Html.PartialAsync("_AdminTableWithCreate", tableModel)
    </main>
</div>

@await Html.PartialAsync("_DeleteModal")
