@using Conversey.BL.Domain.Administration
@using Conversey.UI_MVC.Models
@using Conversey.UI_MVC.Models.Admin
@using Conversey.UI_MVC.Resources
@model IEnumerable<Conversey.BL.Domain.Administration.Workspace>
@inject AdminContext AdminContext
@Html.AntiForgeryToken()
@inject IAdminI18nService I18n

@{
    ViewData["Title"] = "Workspaces";
    ViewData["WorkspaceName"] = "Conversey Platform";
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        ("Dashboard", AdminContext.GetDashboardUrl(), false),
        ("Workspaces", null, true)
    };
    var workspaces = Model ?? [];
    var createWorkspaceForm = new AdminFormViewModel<Workspace>
    {
        FormItem = new Workspace(),
        FormAction = "CreateWorkspace",
        SubmitLabel = "Create workspace"
    };
    var editWorkspaceForm = new AdminFormViewModel<Workspace>
    {
        FormItem = new Workspace(),
        FormAction = "EditWorkspace",
        SubmitLabel = "Save changes"
    };
    var editWorkspaceActionTemplate = Url.Action("EditWorkspace", "ConverseyAdmin", new { id = "__workspaceId__" }) ?? "/admin/workspace/__workspaceId__";
    var createWorkspaceViewData = new ViewDataDictionary(ViewData)
    {
        ["ModalTitle"] = "Create workspace",
        ["FormId"] = "workspaceCreateForm",
        ["CloseButtonId"] = "closeWorkspaceCreateModal",
        ["FormPostUrl"] = Url.Action("CreateWorkspace", "ConverseyAdmin") ?? "/admin/workspaces/new",
        ["WorkspaceNameInputId"] = "workspaceCreateNameInput",
        ["WorkspaceIdInputId"] = "workspaceCreateIdInput",
        ["SubmitLabel"] = "Create workspace",
        ["ImageUploadUrl"] = Url.Action("UploadCreateWorkspaceImage", "ConverseyAdmin") ?? "/admin/workspaces/new/upload-image"
    };
    var editWorkspaceViewData = new ViewDataDictionary(ViewData)
    {
        ["ModalTitle"] = "Edit workspace",
        ["FormId"] = "workspaceEditForm",
        ["CloseButtonId"] = "closeWorkspaceEditModal",
        ["FormActionTemplate"] = editWorkspaceActionTemplate,
        ["WorkspaceNameInputId"] = "workspaceEditNameInput",
        ["WorkspaceIdInputId"] = "workspaceEditIdInput",
        ["SubmitLabel"] = "Save changes",
        ["ImageUploadUrl"] = Url.Action("UploadCreateWorkspaceImage", "ConverseyAdmin") ?? "/admin/workspaces/new/upload-image"
    };
}
<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto" data-search-root data-search-input="#workspaceSearchInput" data-search-count="#workspaceSearchCount">

        <!-- Top Stats Row -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
            <div class="bg-white p-5 rounded-xl border border-secondary/10 shadow-sm flex items-center justify-between">
                <div>
                    <span class="text-[10px] text-secondary uppercase font-bold tracking-wider block">Total Workspaces</span>
                    <div class="text-2xl font-bold text-text">@workspaces.Count()</div>
                </div>
                <div class="p-2 bg-primary/5 rounded-lg text-primary">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7h18M3 12h18M3 17h18"></path></svg>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div class="flex items-center space-x-4">
                <div class="relative w-80">
                    <input id="workspaceSearchInput" type="text" placeholder="Search workspaces..."
                           class="w-full pl-10 pr-4 py-2 bg-white border border-secondary/20 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all shadow-sm" />
                    <span class="absolute left-3 top-2.5 text-secondary">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </span>
                </div>
                <div class="flex items-center gap-2">
                    <button class="px-3 py-2 text-sm font-medium text-text/60 hover:text-accent transition-colors">Delete</button>
                    <button class="px-3 py-2 text-sm font-medium text-text/60 hover:text-primary transition-colors">Select all</button>
                </div>
            </div>

            <div class="text-sm text-text/50">
                Showing <strong id="workspaceSearchCount">@workspaces.Count()</strong> workspaces
            </div>
        </div>

        <!-- Workspace Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8" data-search-items>
            @foreach (var workspace in workspaces)
            {
                <div class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-secondary/10 relative" data-search-item data-search-text="@workspace.Name @workspace.Id.Text">
                    <a class="absolute inset-0 z-10" href="@Url.Action("WorkspaceDetails", "ConverseyAdmin", new { id = workspace.Id.Text })" aria-label="View workspace @workspace.Name"></a>

                    <div class="project-card-header workspace-card-header h-44 relative flex items-center justify-center bg-linear-to-br from-primary/5 to-secondary/5 overflow-hidden" style="--card-image: url('@workspace.ImageUrl');">
                        <div class="text-center px-4 relative z-0">
                            <span class="block font-bold text-xl text-primary tracking-tight">@workspace.Name</span>
                            <span class="text-xs uppercase tracking-widest text-secondary font-semibold mt-1 block">Workspace</span>
                        </div>

                        <div class="absolute top-3 right-3 flex gap-2 z-20">
                            <span class="text-[10px] uppercase tracking-widest font-bold px-2 py-1 rounded-full border border-secondary/20 bg-white/90 text-secondary">
                                @workspace.Id.Text
                            </span>
                        </div>

                        <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/5 transition-colors duration-300"></div>
                    </div>

                    <div class="p-4 flex items-center justify-between border-t border-secondary/10 relative z-20">
                        <div class="flex -space-x-2">
                            <div class="w-8 h-8 rounded-full bg-secondary/20 border-2 border-white flex items-center justify-center text-[10px] font-bold">
                                @(string.IsNullOrWhiteSpace(workspace.Name) ? "W" : workspace.Name.Trim().Substring(0, 1).ToUpperInvariant())
                            </div>
                        </div>

                        <div class="flex items-center space-x-1">
                            <button type="button" title="Edit" class="p-2 text-text/40 hover:text-primary hover:bg-primary/5 rounded-lg transition-all relative z-20"
                                    data-open-workspace-edit-modal="true"
                                    data-workspace-id="@workspace.Id.Text"
                                    data-workspace-name="@workspace.Name"
                                    data-workspace-image-url="@workspace.ImageUrl"
                                    aria-label="Edit workspace @workspace.Name">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                            </button>
                            <button title="Copy" class="p-2 text-text/40 hover:text-primary hover:bg-primary/5 rounded-lg transition-all relative z-20" data-copy-id="@workspace.Id.Text" data-copy-name="@workspace.Name" aria-label="Copy workspace @workspace.Name">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 8h8a2 2 0 002-2V8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                            </button>
                        </div>
                    </div>
                </div>
            }

            <button type="button" class="group border-2 border-dashed border-secondary/20 rounded-xl h-60.25 flex flex-col items-center justify-center hover:border-primary/50 hover:bg-primary/5 transition-all" data-open-workspace-create-modal="true" aria-label="Create workspace" data-search-item data-search-ignore>
                <div class="w-12 h-12 rounded-full bg-white shadow-sm border border-secondary/10 flex items-center justify-center text-secondary group-hover:text-primary group-hover:scale-110 transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                </div>
                <span class="mt-4 font-bold text-sm text-secondary group-hover:text-primary">Create New Workspace</span>
            </button>
        </div>
    </main>

    <button type="button" class="fixed bottom-8 right-8 bg-primary text-white flex items-center space-x-2 px-6 py-4 rounded-2xl font-bold shadow-lg shadow-primary/30 hover:bg-primary/90 hover:scale-105 active:scale-95 transition-all group" data-open-workspace-create-modal="true" aria-label="New Workspace">
        <svg class="w-6 h-6 transition-transform group-hover:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        <span>New Workspace</span>
    </button>
</div>

<div id="workspaceCreateModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-text/45 p-4">
    <div class="w-full max-w-lg">
        @await Html.PartialAsync("~/Views/ConverseyAdmin/_WorkspaceForm.cshtml", createWorkspaceForm, createWorkspaceViewData)
    </div>
</div>

<div id="workspaceEditModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-text/45 p-4">
    <div class="w-full max-w-lg">
        @await Html.PartialAsync("~/Views/ConverseyAdmin/_WorkspaceForm.cshtml", editWorkspaceForm, editWorkspaceViewData)
    </div>
</div>

@await Html.PartialAsync("_DeleteModal")

@section Scripts {
    <script type="module" vite-src="~/components/shared/workspaceModalForms.ts"></script>
}
