@using System.Text.Json
@using Conversey.UI_MVC.Resources
@model Conversey.UI_MVC.Models.Analytics.ConverseyAnalyticsViewModel
@inject IAdminI18nService I18n

@{
    ViewData["Title"] = I18n["Platform Analytics"];
    ViewData["Breadcrumbs"] = new (string Label, string Url, bool IsCurrent)[]
    {
        (I18n["Platform Analytics"], null, true)
    };
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto">
        <div class="mb-8">
            <h1 class="text-2xl font-bold" data-i18n="Platform Analytics">Platform Analytics</h1>
            <p class="text-secondary text-sm mt-1" data-i18n="Overview of all workspaces">Overview of all workspaces</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            @{
                var totalYouth = Model.PlatformStats.Sum(s => s.YouthCount);
                var totalIdeas = Model.PlatformStats.Sum(s => s.IdeaCount);
                var totalAnswers = Model.PlatformStats.Sum(s => s.AnswerCount);
                var totalProjects = Model.PlatformStats.Sum(s => s.ProjectCount);
            }
            <div class="bg-card rounded-xl border border-secondary/10 p-5">
                <p class="text-xs font-semibold text-secondary uppercase tracking-wider" data-i18n="Workspaces">Workspaces</p>
                <p class="text-3xl font-bold text-primary mt-1">@Model.PlatformStats.Count</p>
            </div>
            <div class="bg-card rounded-xl border border-secondary/10 p-5">
                <p class="text-xs font-semibold text-secondary uppercase tracking-wider" data-i18n="Total Participants">Total Participants</p>
                <p class="text-3xl font-bold text-primary mt-1">@totalYouth</p>
            </div>
            <div class="bg-card rounded-xl border border-secondary/10 p-5">
                <p class="text-xs font-semibold text-secondary uppercase tracking-wider" data-i18n="Total Ideas">Total Ideas</p>
                <p class="text-3xl font-bold text-primary mt-1">@totalIdeas</p>
            </div>
            <div class="bg-card rounded-xl border border-secondary/10 p-5">
                <p class="text-xs font-semibold text-secondary uppercase tracking-wider" data-i18n="Total Answers">Total Answers</p>
                <p class="text-3xl font-bold text-primary mt-1">@totalAnswers</p>
            </div>
        </div>

        <div class="bg-card rounded-xl border border-secondary/10 p-6 mb-8">
            <h2 class="text-lg font-bold mb-4" data-i18n="Workspace Comparison">Workspace Comparison</h2>
            <canvas id="platform-comparison-chart" height="200"></canvas>
        </div>

        <div class="bg-card rounded-xl border border-secondary/10 p-6 mb-8">
            <h2 class="text-lg font-bold mb-4" data-i18n="Per Workspace Details">Per Workspace Details</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-secondary/10 text-left">
                            <th class="py-3 px-4 font-semibold" data-i18n="Workspace">Workspace</th>
                            <th class="py-3 px-4 font-semibold" data-i18n="Projects">Projects</th>
                            <th class="py-3 px-4 font-semibold" data-i18n="Participants">Participants</th>
                            <th class="py-3 px-4 font-semibold" data-i18n="Ideas">Ideas</th>
                            <th class="py-3 px-4 font-semibold" data-i18n="Answers">Answers</th>
                            <th class="py-3 px-4 font-semibold" data-i18n="Conversion Rate">Conversion Rate</th>
                            <th class="py-3 px-4 font-semibold"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ws in Model.PlatformStats)
                        {
                            <tr class="border-b border-secondary/5 hover:bg-secondary/5 transition-colors">
                                <td class="py-3 px-4 font-medium">@ws.WorkspaceName</td>
                                <td class="py-3 px-4">@ws.ProjectCount</td>
                                <td class="py-3 px-4">@ws.YouthCount</td>
                                <td class="py-3 px-4">@ws.IdeaCount</td>
                                <td class="py-3 px-4">@ws.AnswerCount</td>
                                <td class="py-3 px-4">@ws.ConversionRate%</td>
                                <td class="py-3 px-4">
                                    <a href="/admin/conversey/analytics/workspace/@ws.WorkspaceSlug"
                                       class="text-primary hover:underline text-xs font-semibold" data-i18n="View Details">View Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.SelectedWorkspaceDashboard != null)
        {
            <div class="mt-8">
                <h2 class="text-xl font-bold mb-4" data-i18n="Workspace Details Dashboard">Workspace Details Dashboard</h2>
                @* Reuse the same stats cards pattern *@
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                    <div class="bg-card rounded-xl border border-secondary/10 p-4">
                        <p class="text-xs text-secondary" data-i18n="Participants">Participants</p>
                        <p class="text-2xl font-bold">@Model.SelectedWorkspaceDashboard.Participation.TotalYouth</p>
                    </div>
                    <div class="bg-card rounded-xl border border-secondary/10 p-4">
                        <p class="text-xs text-secondary" data-i18n="Ideas">Ideas</p>
                        <p class="text-2xl font-bold">@Model.SelectedWorkspaceDashboard.Ideas.Count</p>
                    </div>
                    <div class="bg-card rounded-xl border border-secondary/10 p-4">
                        <p class="text-xs text-secondary" data-i18n="Avg Scale Score">Avg Scale Score</p>
                        <p class="text-2xl font-bold">
                            @(Model.SelectedWorkspaceDashboard.ScaleQuestionStats.FirstOrDefault()?.Average.ToString("F1") ?? "-")
                        </p>
                    </div>
                    <div class="bg-card rounded-xl border border-secondary/10 p-4">
                        <p class="text-xs text-secondary" data-i18n="Conversion Rate">Conversion Rate</p>
                        <p class="text-2xl font-bold">@Model.SelectedWorkspaceDashboard.Participation.ConversionRate%</p>
                    </div>
                </div>
            </div>
        }
    </main>
</div>

<script type="application/json" id="platform-stats-data">@Model.PlatformStatsJson</script>
<script type="application/json" id="analytics-dashboard-data">@Model.DashboardJson</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script type="module" vite-src="~/components/analytics/converseyAnalyticsPage.ts"></script>
