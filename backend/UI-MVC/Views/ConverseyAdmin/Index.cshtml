@using Conversey.UI_MVC.Models
@using Conversey.UI_MVC.Resources
@inject AdminContext AdminContext
@inject IAdminI18nService AdminI18n
@{
    ViewData["Title"] = "Admin Panel";
    ViewData["WorkspaceName"] = "Conversey Platform";
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        ("Dashboard", null, true)
    };
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto">
        <div class="mb-10">
            <h1 class="text-3xl font-bold text-text tracking-tight" data-i18n="Conversey Admin">Conversey Admin</h1>
            <p class="mt-2 text-sm text-text/60" data-i18n="Platform-wide management and configuration.">Platform-wide management and configuration.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <a href="@Url.Action("Index", "AiAdmin")" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary/20 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="AI Settings">AI Settings</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="Configure providers, models, prompts, and monitor costs">Configure providers, models, prompts, and monitor costs</p>
                    </div>
                </div>
            </a>

            <a href="@Url.Action("Workspaces", "ConverseyAdmin")" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary group-hover:bg-secondary/20 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="Workspaces">Workspaces</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="Manage all workspaces and their settings">Manage all workspaces and their settings</p>
                    </div>
                </div>
            </a>

            <a href="@Url.Action("Index", "ConverseyAnalytics")" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center text-accent group-hover:bg-accent/20 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text">Analytics</h3>
                        <p class="text-xs text-text/50 mt-1">View platform-wide statistics and workspace comparisons</p>
                    </div>
                </div>
            </a>
        </div>
    </main>
</div>
