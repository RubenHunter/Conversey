@model Conversey.UI_MVC.Models.AiAdmin.AiModelsViewModel
@{
    ViewData["Title"] = "Configure Models: " + Model.Provider.ProviderName;
    var availableModels = Model.AvailableModels;
    var fetchError = Model.FetchError;
    var hasModels = availableModels.Count > 0;
}

<div class="min-h-screen bg-gray-50 px-4 py-10">
    <div class="mx-auto max-w-5xl">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900"><span data-i18n="Configure Models">Configure Models</span>: @Model.Provider.ProviderName</h1>
                <p class="mt-1 text-sm text-gray-500" data-i18n="Select which models to use for AI operations.">Select which models to use for AI operations.</p>
            </div>
            <a href="@Url.Action("Providers")" class="text-sm text-indigo-600 hover:text-indigo-700">&larr; <span data-i18n="Back to Providers">Back to Providers</span></a>
        </div>

        <div class="mt-6 space-y-6">
            <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                <div class="border-b border-gray-200 px-6 py-4">
                    <h2 class="text-sm font-semibold text-gray-900" data-i18n="Provider Connection">Provider Connection</h2>
                </div>
                <div class="px-6 py-4">
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            <h3 class="text-xs font-semibold uppercase text-gray-500" data-i18n="Base URL">Base URL</h3>
                            <p class="mt-1 text-sm font-mono text-gray-700">@(string.IsNullOrWhiteSpace(Model.Provider.BaseUrl) ? "—" : Model.Provider.BaseUrl)</p>
                        </div>
                        <div>
                            <h3 class="text-xs font-semibold uppercase text-gray-500" data-i18n="API Key">API Key</h3>
                            <p class="mt-1 text-sm font-mono text-gray-700">@(string.IsNullOrWhiteSpace(Model.Provider.ApiKey) ? "—" : new string('*', Math.Min(Model.Provider.ApiKey.Length, 20)))</p>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("EditProvider", new { id = Model.Provider.Id })" class="text-sm text-indigo-600 hover:text-indigo-700" data-i18n="Edit connection settings">Edit connection settings</a>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(fetchError))
            {
                <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 shadow-sm">
                    <p class="text-sm font-medium text-amber-800" data-i18n="Could not fetch models from provider API.">Could not fetch models from provider API.</p>
                    <p class="mt-1 text-xs text-amber-600">@fetchError</p>
                    <p class="mt-1 text-xs text-amber-600" data-i18n="You can still enter model names manually below.">You can still enter model names manually below.</p>
                </div>
            }

            @if (hasModels)
            {
                <div class="rounded-lg border border-green-200 bg-green-50 p-4 shadow-sm">
                    <p class="text-sm font-medium text-green-800">@availableModels.Count <span data-i18n="model(s) found.">model(s) found.</span></p>
                    <p class="mt-1 text-xs text-green-600" data-i18n="Select from the dropdowns below, or type a model name manually.">Select from the dropdowns below, or type a model name manually.</p>
                </div>
            }

            <form asp-action="SaveModels" asp-route-id="@Model.Provider.Id" method="post" class="space-y-6">
                @Html.AntiForgeryToken()

                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    <div class="border-b border-gray-200 px-6 py-4">
                        <h2 class="text-sm font-semibold text-gray-900" data-i18n="Model Selection">Model Selection</h2>
                    </div>
                    <div class="px-6 py-4 space-y-4">
                        <div>
                            <label class="block text-xs font-semibold uppercase text-gray-500" data-i18n="Completions Model">Completions Model</label>
                            <div class="mt-1 flex gap-2">
                                @if (hasModels)
                                {
                                    <select name="CompletionsModel" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                                        <option value="" data-i18n="select or type manually">select or type manually</option>
                                        @foreach (var m in availableModels)
                                        {
                                            var selected = string.Equals(m, Model.Provider.CompletionsModel, StringComparison.OrdinalIgnoreCase);
                                            <option value="@m" selected="@selected">@m</option>
                                        }
                                    </select>
                                }
                                <input name="CompletionsModel" type="text" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 @(hasModels ? "hidden" : "")" placeholder="e.g. mistral-large-latest" data-i18n-placeholder="e.g. mistral-large-latest" list="completions-datalist" />
                                @if (hasModels)
                                {
                                    <datalist id="completions-datalist">
                                        @foreach (var m in availableModels)
                                        {
                                            <option value="@m" />
                                        }
                                    </datalist>
                                }
                            </div>
                            <p class="mt-1 text-xs text-gray-400" data-i18n="Used for: idea nudging, ranking, categorization, alternative generation.">Used for: idea nudging, ranking, categorization, alternative generation.</p>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold uppercase text-gray-500" data-i18n="Moderation Model">Moderation Model</label>
                            <div class="mt-1 flex gap-2">
                                @if (hasModels)
                                {
                                    <select name="ModerationModel" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                                        <option value="" data-i18n="none (skip moderation)">none (skip moderation)</option>
                                        @foreach (var m in availableModels)
                                        {
                                            var selected = string.Equals(m, Model.Provider.ModerationModel, StringComparison.OrdinalIgnoreCase);
                                            <option value="@m" selected="@selected">@m</option>
                                        }
                                    </select>
                                }
                                <input name="ModerationModel" type="text" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 @(hasModels ? "hidden" : "")" placeholder="e.g. mistral-moderation-latest" data-i18n-placeholder="e.g. mistral-moderation-latest" list="moderation-datalist" />
                                @if (hasModels)
                                {
                                    <datalist id="moderation-datalist">
                                        @foreach (var m in availableModels)
                                        {
                                            <option value="@m" />
                                        }
                                    </datalist>
                                }
                            </div>
                            <p class="mt-1 text-xs text-gray-400" data-i18n="Used for content moderation. Leave empty for prompt-based fallback.">Used for content moderation. Leave empty for prompt-based fallback.</p>
                        </div>

                        <div>
                            <label class="block text-xs font-semibold uppercase text-gray-500" data-i18n="Temperature">Temperature</label>
                            <input name="Temperature" type="number" min="0" max="2" step="0.1" value="@Model.Provider.Temperature" class="mt-1 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="1.0" />
                            <p class="mt-1 text-xs text-gray-400" data-i18n="Controls randomness: 0 = deterministic, 2 = creative.">Controls randomness: 0 = deterministic, 2 = creative.</p>
                        </div>

                        @{
                            var cfgProviderName = Model.Provider.ProviderName?.Trim();
                            var cfgSupportsSpeech = string.Equals(cfgProviderName, "Mistral", StringComparison.OrdinalIgnoreCase) ||
                                                   string.Equals(cfgProviderName, "OpenAI", StringComparison.OrdinalIgnoreCase);
                        }
                        @if (cfgSupportsSpeech)
                        {
                            <div class="border-t border-gray-200 pt-4 mt-4">
                                <p class="text-xs font-semibold uppercase text-gray-500 mb-3" data-i18n="Speech Models (optional)">Speech Models (optional)</p>
                                <div>
                                    <label class="block text-xs font-semibold uppercase text-gray-500" data-i18n="STT Model (speech-to-text)">STT Model (speech-to-text)</label>
                                    <input name="SttModel" type="text" class="mt-1 w-full rounded-md border border-gray-300 bg-white px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="whisper-1" value="@Model.Provider.SttModel" />
                                    <p class="mt-1 text-xs text-gray-400" data-i18n="Model for transcribing speech to text. Leave empty for default.">Model for transcribing speech to text. Leave empty for default.</p>
                                </div>
                                <div class="mt-4">
                                    <label class="block text-xs font-semibold uppercase text-gray-500" data-i18n="TTS Model (text-to-speech)">TTS Model (text-to-speech)</label>
                                    <input name="TtsModel" type="text" class="mt-1 w-full rounded-md border border-gray-300 bg-white px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="tts-1" value="@Model.Provider.TtsModel" />
                                    <p class="mt-1 text-xs text-gray-400" data-i18n="Model for synthesizing text into speech audio. Leave empty for default.">Model for synthesizing text into speech audio. Leave empty for default.</p>
                                </div>
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(Model.Provider.SttModel) || !string.IsNullOrEmpty(Model.Provider.TtsModel))
                        {
                            <div class="border-t border-amber-200 pt-4 mt-4">
                                <p class="text-xs text-amber-600"><strong data-i18n="Note:">Note:</strong> <span>This provider (@cfgProviderName) does not support speech via the built-in providers. STT/TTS model values will be ignored.</span></p>
                            </div>
                        }
                    </div>
                </div>

                <div class="flex items-center justify-end gap-3">
                    <a href="@Url.Action("Providers")" class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                        <span data-i18n="Skip (save later)">Skip (save later)</span>
                    </a>
                    <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700">
                        <span data-i18n="Save Models">Save Models</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
