@using Conversey.BL.Domain.Administration
@model Conversey.UI_MVC.Models.Admin.AdminFormViewModel<Workspace>

<div class="mx-auto max-w-3xl rounded-lg border border-secondary/10 bg-white p-6 shadow-sm mt-8">
    <div class="flex items-center justify-between gap-4">
        <h1 class="text-2xl font-bold text-gray-900">Create Workspace</h1>
        <a
            href="@Url.Action("Workspaces", "ConverseyAdmin")"
            class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-700">
            Back to workspaces
        </a>
    </div>

    <form method="post" asp-action="@Model.FormAction" class="mt-6 space-y-6">

        <input type="hidden" asp-for="FormItem.Id" />


        <div>
            <label asp-for="FormItem.Name" class="block text-sm font-medium text-gray-700">Workspace Name</label>
            <input asp-for="FormItem.Name" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" />
            <span asp-validation-for="FormItem.Name" class="text-sm text-red-600"></span>
        </div>


        <div class="flex justify-end pt-4">
            <button type="submit"
                    class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">
                @Model.SubmitLabel
            </button>
        </div>
    </form>
</div>

