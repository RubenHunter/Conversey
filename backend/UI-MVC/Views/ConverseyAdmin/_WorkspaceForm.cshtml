@using Conversey.BL.Domain.Administration
@model Conversey.UI_MVC.Models.Admin.AdminFormViewModel<Workspace>

@{
    var modalTitle = ViewData["ModalTitle"] as string ?? "Workspace";
    var formId = ViewData["FormId"] as string ?? string.Empty;
    var closeButtonId = ViewData["CloseButtonId"] as string ?? string.Empty;
    var formPostUrl = ViewData["FormPostUrl"] as string ?? string.Empty;
    var formActionTemplate = ViewData["FormActionTemplate"] as string ?? string.Empty;
    var workspaceNameInputId = ViewData["WorkspaceNameInputId"] as string ?? string.Empty;
    var workspaceIdInputId = ViewData["WorkspaceIdInputId"] as string ?? string.Empty;
    var submitLabel = ViewData["SubmitLabel"] as string ?? Model.SubmitLabel;
    var workspaceIdText = Model.FormItem?.Id.Text ?? string.Empty;
    var fallbackAction = Model.FormAction == "EditWorkspace"
        ? Url.Action(Model.FormAction, "ConverseyAdmin", new { id = workspaceIdText }) ?? string.Empty
        : Url.Action(Model.FormAction, "ConverseyAdmin") ?? string.Empty;
    var resolvedAction = string.IsNullOrWhiteSpace(formPostUrl) ? fallbackAction : formPostUrl;
}

<div class="rounded-2xl border border-secondary/10 bg-white p-6 shadow-sm">
    <div class="mb-5 flex items-start justify-between gap-4">
        <h2 class="text-xl font-bold text-text tracking-tight">@modalTitle</h2>
        @if (!string.IsNullOrWhiteSpace(closeButtonId))
        {
            <button id="@closeButtonId" type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-secondary/20 text-secondary transition hover:bg-background hover:text-text" aria-label="Close">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        }
    </div>

    <form id="@formId" method="post" action="@resolvedAction" data-action-template="@formActionTemplate" class="space-y-5">
        <input type="hidden" asp-for="FormItem.Id" id="@workspaceIdInputId" />

        <div>
            <label asp-for="FormItem.Name" class="mb-2 block text-sm font-semibold text-text/80">Workspace name</label>
            <input asp-for="FormItem.Name" id="@workspaceNameInputId" class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25" />
            <span asp-validation-for="FormItem.Name" class="mt-1 block text-sm text-accent"></span>
        </div>

        <div class="flex justify-end gap-3 pt-3">
            @if (!string.IsNullOrWhiteSpace(closeButtonId))
            {
                <button id="@($"{closeButtonId}Secondary")" type="button" class="rounded-xl border border-secondary/20 px-4 py-2 text-sm font-semibold text-text/70 transition hover:bg-background">
                    Cancel
                </button>
            }
            else
            {
                <a href="@Url.Action("Workspaces", "ConverseyAdmin")" class="rounded-xl border border-secondary/20 px-4 py-2 text-sm font-semibold text-text/70 transition hover:bg-background">
                    Cancel
                </a>
            }
            <button type="submit" class="rounded-xl bg-primary px-4 py-2 text-sm font-bold text-white shadow-sm shadow-primary/20 transition hover:bg-primary/90">
                @submitLabel
            </button>
        </div>
    </form>
</div>

