<div id="addTopicModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-text/45 p-4">
    <div class="w-full max-w-lg rounded-2xl border border-secondary/10 bg-white p-6 shadow-lg">
        <h2 id="addTopicModalTitle" class="text-lg font-semibold text-text mb-4">Add Topic</h2>

        <form id="addTopicForm" class="space-y-4">
            <div>
                <label for="modalTopicName" class="block text-sm font-medium text-text">Topic Name</label>
                <input id="modalTopicName" type="text" required maxlength="200"
                       class="mt-1 block w-full rounded-md border border-text/20 bg-background px-3 py-2 text-text" />
            </div>

            <div>
                <label for="modalTopicContext" class="block text-sm font-medium text-text">Context</label>
                <textarea id="modalTopicContext" rows="3" maxlength="4000"
                          class="mt-1 block w-full rounded-md border border-text/20 bg-background px-3 py-2 text-text"></textarea>
            </div>

            <div>
                <label for="modalTopicMaxLoads" class="block text-sm font-medium text-text mb-2">Max Broad Selection Loads</label>
                <div class="range-slider">
                    <input id="modalTopicMaxLoads" type="range" min="0" max="20" step="1" value="3" />
                    <span id="modalTopicMaxLoadsBadge" class="range-slider-badge">3</span>
                </div>
            </div>

            <div class="flex justify-end gap-3 pt-4">
                <button id="cancelAddTopicBtn" type="button"
                        class="rounded-md border border-text/20 px-4 py-2 text-sm text-text/70 hover:bg-text/5">
                    Cancel
                </button>
                <button id="saveAddTopicBtn" type="button"
                        class="rounded-md bg-primary px-4 py-2 text-sm text-white hover:bg-primary/90 shadow-sm shadow-primary/25">
                    Add Topic
                </button>
            </div>
        </form>
    </div>
</div>
