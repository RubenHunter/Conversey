<section class="flex flex-wrap">
    <h2 class="grow">Questions</h2>
    <section class="flex gap-2 items-center">
        <button class="add-icon icon-button" id="add-question-button">Add question</button>
        <button class="add-directory-icon icon-button" id="add-section-button">Add sections</button>
        <button class="trash-icon icon-button" id="delete-button">Delete</button>
        <button class="select-icon icon-button" id="select-button">Select</button>
    </section>

    <ol id="question-list" class="w-full grid gap-2">
        <li draggable="true">
            <details>
                <summary class="flex items-center draggable-question gap-2 cursor-grab">
                    <h3 class="leading-none grow">Bussen</h3>
                    <span class="icon-button"></span>
                    <button class="icon-button select-icon">Select</button>
                </summary>
                <ol class="w-full grid gap-2 mt-2">
                    <li draggable="true">
                        <section class="flex items-center draggable-question gap-2 cursor-grab">
                            <h3 class="leading-none grow">Wat vind je van het aantal bushaltes?</h3>
                            <button class="icon-button trash-icon">Delete</button>
                            <button class="icon-button pencil-icon">Edit</button>
                            <button class="icon-button select-icon">Select</button>
                        </section>
                    </li>
                    <li draggable="true">
                        <section class="flex items-center draggable-question gap-2 cursor-grab">
                            <h3 class="leading-none grow">Wat vind je van het aantal bushaltes?</h3>
                            <button class="icon-button trash-icon">Delete</button>
                            <button class="icon-button pencil-icon">Edit</button>
                            <button class="icon-button select-icon">Select</button>
                        </section>
                    </li>
                </ol>
            </details>
        </li>
        <li draggable="true">
            <section class="flex items-center draggable-question gap-2 cursor-grab">
                <h3 class="leading-none grow">Welke treinen gebruik je het meest?</h3>
                <button class="icon-button trash-icon">Delete</button>
                <button class="icon-button pencil-icon">Edit</button>
                <button class="icon-button select-icon">Select</button>
            </section>
        </li>
    </ol>
</section>

<dialog id="add-question-dialog">
    <form>
        <label>
            Question
            <input type="text" name="question-text"/>
        </label>
        <label>
            Type
            <select>
                <option>multiple choice</option>
                <option>single choice</option>
                <option>open</option>
                <option>range</option>
            </select>
        </label>
        <label>
            Answers
        </label>
        <input type="submit" value="Add question"/>
        <button commandfor="add-question-dialog" command="close">Cancel</button>
    </form>
</dialog>

<dialog id="edit-question-dialog">
    <form>
        <label>
            Question
            <input type="text" name="question-text" id="edit-question-text"/>
        </label>
        <label>
            Type
            <select name="question-type" id="edit-question-type">
                <option>multiple choice</option>
                <option>single choice</option>
                <option>open</option>
                <option>range</option>
            </select>
        </label>
        <label>
            Answers
        </label>
        <input type="submit" value="Save question"/>
        <button commandfor="edit-question-dialog" command="close">Cancel</button>
    </form>
</dialog>

<dialog id="add-section-dialog">
    <form>
        <label>
            Question
            <input type="text" name="question-text" id="add-section-text"/>
        </label>
        <input type="submit" value="Add section"/>
        <button commandfor="add-section-dialog" command="close">Cancel</button>
    </form>
</dialog>

@section Scripts
{
    <script type="module" vite-src="~/AddQuestionsViewModel.ts"></script>
}