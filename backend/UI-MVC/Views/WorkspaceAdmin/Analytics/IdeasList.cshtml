@using Conversey.UI_MVC.Resources
@using Conversey.UI_MVC.Models
@model Conversey.UI_MVC.Models.Analytics.IdeasListViewModel
@inject IAdminI18nService I18n
@inject WorkspaceContext WorkspaceContext
@inject AdminContext AdminContext

@{
    ViewData["Title"] = "Ideas List";
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[] {
        (I18n["Dashboard"], AdminContext.GetDashboardUrl(), false),
        (I18n["Analytics"], "/admin/workspace/analytics", false),
        ("Ideas", null, true)
    };
}

<div class="min-h-screen bg-background font-sans text-text" data-workspace-slug="@WorkspaceContext.CurrentWorkspace.Id.Text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold" data-i18n="Ideas">Ideas</h1>
                <div class="flex items-center gap-3 mt-1">
                    <span class="text-secondary text-sm" id="ideas-pagination-info">@Model.Ideas.Count ideas</span>
                    <label class="flex items-center gap-1.5 text-sm text-secondary">
                        <span class="text-xs">Show:</span>
                        <select id="ideas-page-size" class="rounded border border-secondary/20 px-2 py-1 text-xs bg-background">
                            <option value="25">25</option>
                            <option value="100">100</option>
                            <option value="500">500</option>
                            <option value="-1">All</option>
                        </select>
                    </label>
                </div>
            </div>
            <a href="/admin/workspace/analytics" class="text-sm text-primary hover:underline" data-i18n="← Back to Analytics">&larr; Back to Analytics</a>
        </div>

        <form method="get" class="mb-6" id="ideas-filter-form">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 p-4 bg-card rounded-xl border border-secondary/10">
                <div>
                    <label class="block text-xs font-semibold text-secondary mb-1" data-i18n="Project">Project</label>
                    <select name="projectId" class="w-full rounded-lg border border-secondary/20 px-3 py-2 text-sm bg-background" onchange="this.form.submit()">
                        <option value="" data-i18n="All Projects">All Projects</option>
                        @foreach (var p in Model.AvailableProjects)
                        {
                            <option value="@p.Id.Text" selected="@(Model.SelectedProjectId == p.Id.Text)">@p.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-secondary mb-1" data-i18n="Topic">Topic</label>
                    <select name="topicId" class="w-full rounded-lg border border-secondary/20 px-3 py-2 text-sm bg-background">
                        <option value="" data-i18n="All Topics">All Topics</option>
                        @foreach (var t in Model.AvailableTopics)
                        {
                            <option value="@t.Id" selected="@(Model.TopicId == t.Id.ToString())">@t.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-secondary mb-1" data-i18n="Status">Status</label>
                    <select name="status" class="w-full rounded-lg border border-secondary/20 px-3 py-2 text-sm bg-background">
                        <option value="" data-i18n="All">All</option>
                        <option value="Approved" selected="@(Model.Status == "Approved")" data-i18n="Approved">Approved</option>
                        <option value="Pending" selected="@(Model.Status == "Pending")" data-i18n="Pending">Pending</option>
                        <option value="Rejected" selected="@(Model.Status == "Rejected")" data-i18n="Rejected">Rejected</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-secondary mb-1" data-i18n="Category">Category</label>
                    <select name="category" class="w-full rounded-lg border border-secondary/20 px-3 py-2 text-sm bg-background">
                        <option value="" data-i18n="All Categories">All Categories</option>
                        @foreach (var cat in Model.AvailableCategories)
                        {
                            <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-secondary mb-1" data-i18n="Youth">Youth</label>
                    <select name="youthId" class="w-full rounded-lg border border-secondary/20 px-3 py-2 text-sm bg-background">
                        <option value="" data-i18n="All Youth">All Youth</option>
                        @foreach (var y in Model.AvailableYouth)
                        {
                            <option value="@y.Id" selected="@(Model.YouthId == y.Id.ToString())">@y.Display</option>
                        }
                    </select>
                    <p class="text-[10px] text-secondary/50 mt-0.5" data-i18n="Type to search by name or email">Type to search by name or email</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-secondary mb-1" data-i18n="Date From">Date From</label>
                    <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="w-full rounded-lg border border-secondary/20 px-3 py-2 text-sm bg-background"/>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-secondary mb-1" data-i18n="Date To">Date To</label>
                    <input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="w-full rounded-lg border border-secondary/20 px-3 py-2 text-sm bg-background"/>
                </div>
                <div class="flex items-center justify-center gap-2">
                    <button type="submit" class="rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary/90" data-i18n="Apply">Apply</button>
                    <div class="relative inline-block" id="export-dropdown-container-ideas">
                        <button type="button" id="export-dropdown-btn-ideas"
                                class="rounded-lg border border-secondary/20 px-4 py-2 text-sm font-semibold hover:bg-secondary/5 transition-colors flex items-center gap-2 bg-background" data-i18n="Export CSV">
                            Export CSV
                        </button>
                        <div id="export-dropdown-menu-ideas" class="hidden absolute right-0 mt-1 w-64 bg-white rounded-lg border border-secondary/10 shadow-lg z-50 py-1">
                            <a href="#" data-export-filtered="false"
                               class="export-ideas-link block px-4 py-2 text-sm hover:bg-secondary/5 transition-colors text-text" data-i18n="Download all ideas">Download all ideas</a>
                            <a href="#" data-export-filtered="true"
                               class="export-ideas-link block px-4 py-2 text-sm hover:bg-secondary/5 transition-colors text-text" data-i18n="Download with active filters">Download with active filters</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        <div class="bg-card rounded-xl border border-secondary/10 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm" id="ideas-table">
                    <thead>
                        <tr class="border-b border-secondary/10 text-left bg-secondary/5">
                            <th class="py-3 px-4 font-semibold w-8"></th>
                            <th class="py-3 px-4 font-semibold w-12 cursor-pointer hover:bg-secondary/10 select-none" data-sort="id" data-i18n="ID"> ID</th>
                            <th class="py-3 px-4 font-semibold cursor-pointer hover:bg-secondary/10 select-none" data-sort="content" data-i18n="Content">Content </th>
                            <th class="py-3 px-4 font-semibold cursor-pointer hover:bg-secondary/10 select-none max-w-[120px]" data-sort="summary" data-i18n="AI Summary">AI Summary </th>
                            <th class="py-3 px-4 font-semibold cursor-pointer hover:bg-secondary/10 select-none w-16 text-center" data-sort="comments" data-i18n="Comments">Comments </th>
                            <th class="py-3 px-4 font-semibold cursor-pointer hover:bg-secondary/10 select-none" data-sort="topic" data-i18n="Topic">Topic </th>
                            <th class="py-3 px-4 font-semibold cursor-pointer hover:bg-secondary/10 select-none" data-sort="status" data-i18n="Status">Status </th>
                            <th class="py-3 px-4 font-semibold cursor-pointer hover:bg-secondary/10 select-none" data-sort="categories" data-i18n="Categories">Categories </th>
                            <th class="py-3 px-4 font-semibold cursor-pointer hover:bg-secondary/10 select-none" data-sort="date" data-i18n="Date">Date </th>
                            <th class="py-3 px-4 font-semibold cursor-pointer hover:bg-secondary/10 select-none" data-sort="youth" data-i18n="Youth">Youth</th>
                            <th class="py-3 px-4 font-semibold w-10" data-i18n="MFR">MFR</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var idea in Model.Ideas)
                        {
                            <tr class="border-b border-secondary/5 hover:bg-secondary/5 transition-colors cursor-pointer idea-row @(idea.MarkedForReview ? "bg-amber-50" : "")" data-idea-id="@idea.Id">
                                <td class="py-3 px-4 text-secondary w-8">
                                    <svg class="w-4 h-4 chevron transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </td>
                                <td class="py-3 px-4 text-secondary" data-col="id">#@idea.Id</td>
                                <td class="py-3 px-4 max-w-xs" data-col="content">
                                    <div class="idea-preview">@(idea.Content.Length > 80 ? idea.Content[..80] + "..." : idea.Content)</div>
                                </td>
                                <td class="py-3 px-4 max-w-[140px]" data-col="summary">
                                    <div class="text-xs text-secondary truncate" title="@idea.Summary">@(string.IsNullOrWhiteSpace(idea.Summary) ? "-" : (idea.Summary.Length > 80 ? idea.Summary[..80] + "..." : idea.Summary))</div>
                                </td>
                                <td class="py-3 px-4 text-center" data-col="comments">
                                    @{
                                        var commentCount = Model.Comments.ContainsKey(idea.Id) ? Model.Comments[idea.Id].Count : 0;
                                    }
                                    <span class="inline-flex items-center gap-1 text-xs font-semibold @(commentCount > 0 ? "text-primary" : "text-secondary")">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                                        @commentCount
                                    </span>
                                </td>
                                <td class="py-3 px-4" data-col="topic">@idea.TopicName</td>
                                <td class="py-3 px-4" data-col="status">
                                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold @(idea.Status switch { "Approved" => "bg-green-100 text-green-700", "Rejected" => "bg-red-100 text-red-700", _ => "bg-yellow-100 text-yellow-700" })">@idea.Status</span>
                                </td>
                                <td class="py-3 px-4" data-col="categories">
                                    <div class="flex flex-wrap gap-1">
                                        @foreach (var cat in idea.SemanticCategories)
                                        {
                                            <span class="text-[10px] bg-secondary/10 rounded px-1.5 py-0.5">@cat</span>
                                        }
                                    </div>
                                </td>
                                <td class="py-3 px-4 text-secondary whitespace-nowrap" data-col="date">@idea.SubmissionDate.ToString("yyyy-MM-dd")</td>
                                <td class="py-3 px-4 text-secondary text-xs" data-col="youth">@(idea.YouthEmail ?? (idea.YouthId.HasValue ? idea.YouthId.Value.ToString()[..8] : "-"))</td>
                                <td class="py-3 px-4 text-center" onclick="event.stopPropagation()">
                                    <button type="button" class="mark-review-btn w-6 h-6 rounded flex items-center justify-center transition-colors @(idea.MarkedForReview ? "bg-amber-200 text-amber-700 hover:bg-amber-300" : "text-secondary/30 hover:text-amber-600 hover:bg-amber-50")" data-type="idea" data-id="@idea.Id" title="@(idea.MarkedForReview ? "Unmark for review" : "Mark for review")">
                                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd"/></svg>
                                    </button>
                                </td>
                            </tr>
                            <tr class="border-b border-secondary/5 hidden idea-expand-row" data-idea-id="@idea.Id">
                                <td></td>
                                <td colspan="10" class="py-4 px-6">
                                    <div class="bg-background rounded-lg border border-primary/20 p-5 max-w-full">
                                        <div class="flex items-center gap-2 mb-3">
                                            <span class="text-xs font-semibold text-primary uppercase tracking-wider" data-i18n="Full Idea Content">Full Idea Content</span>
                                            <span class="text-[10px] text-secondary">#@idea.Id &mdash; @idea.TopicName &mdash; @idea.Status</span>
                                            @if (idea.YouthId.HasValue && !string.IsNullOrWhiteSpace(idea.YouthEmail))
                                            {
                                                <button type="button" class="ml-auto rounded-xl bg-primary/10 text-primary px-3 py-1.5 text-xs font-semibold hover:bg-primary hover:text-white transition-all contact-youth-btn" data-youth-id="@idea.YouthId.Value" data-youth-email="@idea.YouthEmail" data-idea-id="@idea.Id" data-idea-content="@System.Net.WebUtility.HtmlEncode(idea.Content)" onclick="event.stopPropagation()">
                                                    <svg class="w-3.5 h-3.5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                                    Contact
                                                </button>
                                            }
                                        </div>
                                        <p class="text-sm leading-relaxed whitespace-pre-wrap break-words">@idea.Content</p>
                                        @if (idea.Status == "Rejected" && !string.IsNullOrWhiteSpace(idea.RejectionReason))
                                        {
                                            <div class="mt-3 p-3 rounded-lg bg-red-50 border border-red-100">
                                                <span class="text-[10px] font-semibold text-red-600 uppercase block mb-1" data-i18n="Rejection reason">Rejection reason</span>
                                                <p class="text-xs text-red-700 leading-relaxed">@idea.RejectionReason</p>
                                            </div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(idea.Summary))
                                        {
                                            <div class="mt-3 pt-3 border-t border-secondary/10">
                                                <span class="text-[10px] font-semibold text-secondary uppercase" data-i18n="AI Summary">AI Summary</span>
                                                <p class="text-xs text-secondary mt-1">@idea.Summary</p>
                                            </div>
                                        }
                                        @{
                                            var ideaComments = new List<Conversey.UI_MVC.Models.Analytics.CommentItemViewModel>();
                                            if (Model.Comments.TryGetValue(idea.Id, out var found))
                                                ideaComments = found;
                                        }
                                        @if (ideaComments.Count > 0)
                                        {
                                            <div class="mt-3 pt-3 border-t border-secondary/10">
                                                <span class="text-[10px] font-semibold text-secondary uppercase">@ideaComments.Count Comment@(ideaComments.Count != 1 ? "s" : "")</span>
                                                <div class="mt-3 space-y-2">
                                                    @foreach (var comment in ideaComments)
                                                    {
                                                        <div class="p-3 rounded-lg border @(comment.MarkedForReview ? "border-amber-300 bg-amber-50" : (comment.IsAuthor ? "border-primary/30 bg-primary/5" : "border-secondary/10 bg-white/50"))">
                                                            <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                                                                @if (comment.IsAuthor)
                                                                {
                                                                     <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold bg-primary/15 text-primary uppercase" data-i18n="Author">Author</span>
                                                                }
                                                                <span class="text-[10px] text-secondary">@(comment.YouthEmail ?? (comment.YouthId.HasValue ? comment.YouthId.Value.ToString()[..8] : "-"))</span>
                                                                <span class="text-[10px] text-secondary/50">&middot;</span>
                                                                <span class="text-[10px] text-secondary/50">@comment.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                                                                <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-semibold @(comment.Status switch { "Approved" => "bg-green-100 text-green-700", "Rejected" => "bg-red-100 text-red-700", _ => "bg-yellow-100 text-yellow-700" })">@comment.Status</span>
                                                                <div class="ml-auto">
                                                                    <button type="button" class="mark-review-btn w-5 h-5 rounded flex items-center justify-center transition-colors @(comment.MarkedForReview ? "bg-amber-200 text-amber-700 hover:bg-amber-300" : "text-secondary/30 hover:text-amber-600 hover:bg-amber-50")" data-type="response" data-id="@comment.Id" title="@(comment.MarkedForReview ? "Unmark for review" : "Mark for review")">
                                                                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd"/></svg>
                                                                    </button>
                                                                </div>
                                                            </div>
                                                            <p class="text-xs leading-relaxed">@comment.Text</p>
                                                            @if (comment.Status == "Rejected" && !string.IsNullOrWhiteSpace(comment.RejectionReason))
                                                            {
                                                                <div class="mt-2 pt-2 border-t border-red-100">
                                                                     <span class="text-[10px] font-semibold text-red-500 uppercase" data-i18n="Rejection reason">Rejection reason</span>
                                                                    <p class="text-[10px] text-red-600 leading-relaxed mt-0.5">@comment.RejectionReason</p>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="mt-3 pt-3 border-t border-secondary/10">
                                                <p class="text-xs text-secondary" data-i18n="No comments yet.">No comments yet.</p>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div id="ideas-pagination" class="flex items-center justify-between mt-4" style="display:none">
            <button id="ideas-prev" class="px-3 py-1.5 rounded border border-secondary/20 text-sm hover:bg-secondary/5 disabled:opacity-30" disabled>Prev</button>
            <span id="ideas-page-nums" class="flex items-center gap-1 text-sm"></span>
            <button id="ideas-next" class="px-3 py-1.5 rounded border border-secondary/20 text-sm hover:bg-secondary/5 disabled:opacity-30">Next</button>
        </div>
    </main>
</div>

@await Html.PartialAsync("~/Views/Shared/_ContactEmailModal.cshtml")

<script type="module" vite-src="~/components/analytics/listPage.ts"></script>
<style>
th[data-sort-dir="asc"]::after,
th[data-sort-dir="desc"]::after {
    display: inline-block;
    width: 0.75rem;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 700;
}
th[data-sort-dir="asc"]::after  { content: '\2191'; }
th[data-sort-dir="desc"]::after { content: '\2193'; }
</style>
<script>
(function() {
    document.querySelectorAll('.mark-review-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var type = btn.getAttribute('data-type');
            var id = parseInt(btn.getAttribute('data-id'));
            btn.disabled = true;

            fetch('/api/admin/analytics/mark-for-review', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ type: type, id: id })
            }).then(function(resp) {
                if (resp.ok) {
                    var isMarked = btn.classList.contains('bg-amber-200');
                    if (isMarked) {
                        btn.classList.remove('bg-amber-200', 'text-amber-700', 'hover:bg-amber-300');
                        btn.classList.add('text-secondary/30', 'hover:text-amber-600', 'hover:bg-amber-50');
                        btn.title = 'Mark for review';
                    } else {
                        btn.classList.add('bg-amber-200', 'text-amber-700', 'hover:bg-amber-300');
                        btn.classList.remove('text-secondary/30', 'hover:text-amber-600', 'hover:bg-amber-50');
                        btn.title = 'Unmark for review';
                    }
                    var card = btn.closest('.rounded-lg');
                    var row = btn.closest('tr.idea-row');
                    if (type === 'response' && card) {
                        if (isMarked) { card.classList.remove('border-amber-300', 'bg-amber-50'); }
                        else { card.classList.add('border-amber-300', 'bg-amber-50'); }
                    }
                    if (type === 'idea' && row) {
                        if (isMarked) row.classList.remove('bg-amber-50');
                        else row.classList.add('bg-amber-50');
                    }
                }
            }).finally(function() { btn.disabled = false; });
        });
    });

    document.querySelectorAll('.contact-youth-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var youthId = btn.getAttribute('data-youth-id');
            var youthEmail = btn.getAttribute('data-youth-email');
            var ideaContent = btn.getAttribute('data-idea-content');
            var ideas = ideaContent ? [{ Content: ideaContent }] : [];
            openContactModal(youthId, youthEmail, ideas, 0);
        });
    });
})();
</script>
