@using Conversey.UI_MVC.Resources
@inject IAdminI18nService I18n
@model Conversey.UI_MVC.Models.WorkspaceAdmin.ProjectViewModel

<div id="dynamic-stepper" class="w-full max-w-5xl mx-auto p-6 bg-background text-text" 
     data-total-steps="@Model.StepperViewModel.Steps.Count" 
     data-entity="@Model.StepperViewModel.EntityName">
    
    @* Header Section *@
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-12 gap-4">
        <h1 class="text-4xl font-bold tracking-tight">@Model.StepperViewModel.Title</h1>
        
        <div class="flex items-center gap-3">
            <button type="button" class="px-6 py-2 border border-text/20 rounded-lg hover:bg-text/5 transition-colors">
                @I18n["Save as draft"]
            </button>
            <div class="flex gap-2">
                <button id="prevBtn" type="button" class="hidden px-8 py-2 border border-text rounded-lg hover:bg-text/5 transition-all">
                    @I18n["< Back"]
                </button>
                <button id="nextBtn" type="button" class="px-8 py-2 bg-text text-background rounded-lg hover:opacity-90 transition-all">
                    @I18n["Next >"]
                </button>
            </div>
        </div>
    </div>

    @* Visual Stepper Line *@
     <div class="relative flex justify-between items-start mb-16 px-8">
     
         @* 1. The Track (Lower Layer) - JS positions this between first and last circle *@
         <div class="absolute top-3.5 h-0.5 z-0">
             @* Background Dotted Line *@
             <div class="absolute inset-0 border-t-2 border-dotted border-text/20"></div>
         
             @* Progress Fill Line *@
             <div id="progress-line" 
                  class="absolute inset-y-0 left-0 bg-primary transition-all duration-500 ease-in-out" 
                  style="width: 0%; height: 2px;"></div>
         </div>

         @for (int i = 0; i < Model.StepperViewModel.Steps.Count; i++)
         {
             var stepNum = i + 1;
             <div class="step-indicator flex flex-col items-center flex-1" data-step="@stepNum">
                 @* Circle stays the same, but ensure bg-background is opaque to hide the line behind it *@
                 <div class="step-circle z-10 w-7 h-7 rounded-full border-2 border-text bg-background flex items-center justify-center transition-all duration-300">
                     <div class="step-dot w-2 h-2 rounded-full bg-text scale-0 transition-transform duration-300"></div>
                 </div>
             
                 <span class="mt-4 text-xs uppercase text-text/50 font-medium">@I18n["step"] @stepNum</span>
                 <span class="text-sm font-bold text-center">@Model.StepperViewModel.Steps[i].Label</span>
             </div>
         }
     </div>

    @* Content Area *@
    <div class="step-content-container relative overflow-hidden min-h-75">
        @for (int i = 0; i < Model.StepperViewModel.Steps.Count; i++)
        {
            <div id="step-content-@(i+1)" class="step-pane hidden animate-in fade-in slide-in-from-right-4 duration-500">
                @await Html.PartialAsync(Model.StepperViewModel.Steps[i].PartialViewName, Model.AdminFormViewModel)
            </div>
        }
    </div>
</div>
