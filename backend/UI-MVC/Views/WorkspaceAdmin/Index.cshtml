@using Conversey.UI_MVC.Models
@using Conversey.BL.Domain.Administration
@inject AdminContext AdminContext
@inject WorkspaceContext WorkspaceContext
@{
    ViewData["Title"] = "Admin Panel";
    ViewData["WorkspaceName"] = WorkspaceContext.CurrentWorkspace?.Name ?? "Workspace";
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        ("Dashboard", null, true)
    };
    var workspaceSlug = WorkspaceContext.CurrentWorkspace?.Id.ToString() ?? string.Empty;
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto">
        <div class="mb-10">
            <h1 class="text-3xl font-bold text-text tracking-tight">@WorkspaceContext.CurrentWorkspace?.Name</h1>
            <p class="mt-2 text-sm text-text/60" data-i18n="Manage your workspace projects and settings.">Manage your workspace projects and settings.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <a href="@Url.Action("Projects", "WorkspaceAdmin")" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary/20 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="Projects">Projects</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="Manage projects, topics, and participants">Manage projects, topics, and participants</p>
                    </div>
                </div>
            </a>

            <a href="@Url.Action("Dashboard", "WorkspaceAi", new { workspaceSlug = workspaceSlug })" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary group-hover:bg-secondary/20 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="AI Settings">AI Settings</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="Monitor costs, manage prompts, and set cost limits">Monitor costs, manage prompts, and set cost limits</p>
                    </div>
                </div>
            </a>
        </div>
    </main>
</div>
