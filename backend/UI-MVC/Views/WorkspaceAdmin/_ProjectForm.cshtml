@using Conversey.BL.Domain.Administration
@using Conversey.UI_MVC.Models
@model Conversey.UI_MVC.Models.Admin.AdminFormViewModel<Project>
@inject WorkspaceContext WorkspaceContext

<div class="bg-background font-sans text-text p-5">
    <div class="mx-auto max-w-3xl rounded-lg border border-secondary/10 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between gap-4">
            <h1 class="text-2xl font-bold text-text" data-i18n="Create Project">Create Project</h1>
            <a
                href="@Url.Action("Projects", "WorkspaceAdmin")"
                class="inline-flex items-center text-sm font-medium text-primary hover:text-primary/80" data-i18n="Back to projects">
                Back to projects
            </a>
        </div>

        <form method="post" asp-action="@Model.FormAction" class="mt-6 space-y-6">
    
            <input type="hidden" asp-for="FormItem.Id" />


            <div>
                <label asp-for="FormItem.Name" class="block text-sm font-medium text-text/70" data-i18n="Project Name">Project Name</label>
                <input asp-for="FormItem.Name" class="mt-1 block w-full rounded-md border border-secondary/20 px-3 py-2" />
                <span asp-validation-for="FormItem.Name" class="text-sm text-red-600"></span>
            </div>

            <div>
                <label class="block text-sm font-medium text-text/70" data-i18n="Workspace">Workspace</label>
                <input type="text" value="@WorkspaceContext.CurrentWorkspace.Name" disabled
                       class="mt-1 block w-full rounded-md border border-secondary/20 bg-secondary/5 px-3 py-2 text-text/50" />
            </div>

            <div>
                <label asp-for="FormItem.Description" class="block text-sm font-medium text-text/70" data-i18n="Description">Description</label>
                <textarea asp-for="FormItem.Description" rows="4"
                          class="mt-1 block w-full rounded-md border border-secondary/20 px-3 py-2"></textarea>
                <span asp-validation-for="FormItem.Description" class="text-sm text-red-600"></span>
            </div>

            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                <div>
                    <label asp-for="FormItem.Status" class="block text-sm font-medium text-text/70" data-i18n="Status">Status</label>
                    <select asp-for="FormItem.Status" asp-items="Html.GetEnumSelectList<Status>()"
                            class="mt-1 block w-full rounded-md border border-secondary/20 px-3 py-2">
                    </select>
                </div>

                <div>
                    <label asp-for="FormItem.InteractionForm" class="block text-sm font-medium text-text/70" data-i18n="Interaction Form">Interaction Form</label>
                    <select asp-for="FormItem.InteractionForm" asp-items="Html.GetEnumSelectList<InteractionType>()"
                            class="mt-1 block w-full rounded-md border border-secondary/20 px-3 py-2">
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
                <div>
                    <label asp-for="FormItem.StartDate" class="block text-sm font-medium text-text/70" data-i18n="Start Date">Start Date</label>
                    <input asp-for="FormItem.StartDate" type="date"
                           class="mt-1 block w-full rounded-md border border-secondary/20 px-3 py-2" />
                </div>

                <div>
                    <label asp-for="FormItem.EndDate" class="block text-sm font-medium text-text/70" data-i18n="End Date">End Date</label>
                    <input asp-for="FormItem.EndDate" type="date"
                           class="mt-1 block w-full rounded-md border border-secondary/20 px-3 py-2" />
                </div>
            </div>

            <div class="flex justify-end pt-4">
                <button type="submit"
                        class="rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary/90"
                        data-i18n="@Model.SubmitLabel">
                    @Model.SubmitLabel
                </button>
            </div>
        </form>
    </div>
</div>
