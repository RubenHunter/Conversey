@using Conversey.BL.Domain.Administration
@model Conversey.BL.Domain.Administration.Project
@Html.AntiForgeryToken()

@{
    ViewData["Title"] = "Project Details";
}

<div class="min-h-screen bg-gray-50 px-4 py-10">
    <div class="mx-auto max-w-4xl">

        <div class="mb-6">
            <a href="@Url.Action("Projects", "WorkspaceAdmin")"
               class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-700">
                ← <span data-i18n="Back to projects">Back to projects</span>
            </a>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white shadow-sm">

            <div class="flex items-start justify-between border-b border-gray-200 px-6 py-5">
                <div>
                    <h1 class="text-2xl font-semibold text-gray-900">
                        @Model.Name
                    </h1>

                    <p class="mt-1 text-sm text-gray-500">
                        <span data-i18n="Project ID">Project ID</span>: @Model.Id.Text
                    </p>
                </div>

                @{
                    var statusColor = Model.Status switch
                    {
                        Status.Active => "bg-green-100 text-green-700",
                        Status.Draft => "bg-yellow-100 text-yellow-700",
                        Status.Archived => "bg-gray-100 text-gray-600",
                        _ => "bg-gray-100 text-gray-600"
                    };
                }

                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium @statusColor">
                    @Model.Status
                </span>
            </div>

            <div class="px-6 py-6 space-y-6">

                <div>
                    <h2 class="text-sm font-semibold text-gray-700" data-i18n="Description">Description</h2>
                    <p class="mt-2 whitespace-normal text-sm text-gray-600">
                        @(string.IsNullOrWhiteSpace(Model.Description) ? "No description provided." : Model.Description)
                    </p>
                </div>
                
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">

                    <div>
                        <h3 class="text-xs font-semibold uppercase text-gray-500" data-i18n="Status">Status</h3>
                        <p class="mt-1 text-sm text-gray-800">@Model.Status</p>
                    </div>

                    <div>
                        <h3 class="text-xs font-semibold uppercase text-gray-500" data-i18n="Interaction Type">Interaction Type</h3>
                        <p class="mt-1 text-sm text-gray-800">@Model.InteractionForm</p>
                    </div>

                    <div>
                        <h3 class="text-xs font-semibold uppercase text-gray-500" data-i18n="AI Nudging Strength">AI Nudging Strength</h3>
                        <p class="mt-1 text-sm text-gray-800">@Model.NudgingStrength</p>
                    </div>

                    <div>
                        <h3 class="text-xs font-semibold uppercase text-gray-500" data-i18n="Start Date">Start Date</h3>
                        <p class="mt-1 text-sm text-gray-800">
                            @(Model.StartDate == default ? "-" : Model.StartDate.ToString("yyyy-MM-dd"))
                        </p>
                    </div>

                    <div>
                        <h3 class="text-xs font-semibold uppercase text-gray-500" data-i18n="End Date">End Date</h3>
                        <p class="mt-1 text-sm text-gray-800">
                            @(Model.EndDate == default ? "-" : Model.EndDate.ToString("yyyy-MM-dd"))
                        </p>
                    </div>

                    <div class="sm:col-span-2">
                        <h3 class="text-xs font-semibold uppercase text-gray-500" data-i18n="Workspace">Workspace</h3>
                        <p class="mt-1 text-sm text-gray-800">
                            @Model.Workspace?.Name
                        </p>
                    </div>

                </div>
            </div>

            <div class="flex items-center justify-end gap-3 border-t border-gray-200 px-6 py-4">

                <a href="@Url.Action("EditProject", "WorkspaceAdmin", new { id = Model.Id.Text })"
                   class="inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700" data-i18n="Edit">
                    Edit
                </a>

                <button type="button"
                        data-delete-id="@Model.Id.Text"
                        data-delete-name="@Model.Name"
                        data-delete-endpoint="/admin/project/delete/@Model.Id.Text"
                        class="inline-flex items-center rounded-md border border-red-200 px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50" data-i18n="Delete">
                    Delete
                </button>
            </div>

        </div>
    </div>
</div>

@await Html.PartialAsync("_DeleteModal")
