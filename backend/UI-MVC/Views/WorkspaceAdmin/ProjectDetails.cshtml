@using Conversey.BL.Domain.Administration
@using Conversey.UI_MVC.Resources
@inject IAdminI18nService I18n
@model Conversey.BL.Domain.Administration.Project
@Html.AntiForgeryToken()

@{
    ViewData["Title"] = I18n["Project Details"];
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto">

        <!-- Back -->
        <div class="mb-6">
            <a href="@Url.Action("Projects", "WorkspaceAdmin")"
               class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-700">
                ← @I18n["Back to projects"]
            </a>
        </div>

        <!-- Card -->
        <div class="rounded-lg border border-gray-200 bg-white shadow-sm">

            <!-- Header -->
            <div class="flex items-start justify-between border-b border-gray-200 px-6 py-5">
                <div>
                    <div class="text-xs uppercase tracking-widest text-secondary font-semibold">
                        @I18n["Project Details"]
                    </div>
                    <h1 class="mt-1 text-3xl font-bold text-text tracking-tight">
                        @Model.Name
                    </h1>

                    <p class="mt-1 text-sm text-gray-500">
                        @I18n["Project ID"]: @Model.Id.Text
                    </p>
                </div>

                <!-- Status badge -->
                @{
                    var statusColor = Model.Status switch
                    {
                        Status.Active => "bg-primary/10 text-primary",
                        Status.Draft => "bg-secondary/20 text-secondary",
                        Status.Archived => "bg-text/5 text-text/60",
                        _ => "bg-text/5 text-text/60"
                    };
                }

                <span class="inline-flex items-center rounded-full px-3 py-1 text-[11px] uppercase tracking-widest font-bold @statusColor">
                    @Model.Status
                </span>
            </div>

            <!-- Body -->
            <div class="px-6 py-6 space-y-6">

                <!-- Description -->
                <div>
                    <h2 class="text-sm font-semibold text-gray-700">@I18n["Description"]</h2>
                    <p class="mt-2 whitespace-normal text-sm text-gray-600">
                        @(string.IsNullOrWhiteSpace(Model.Description) ? I18n["No description provided."] : Model.Description)
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">

                    <div>
                        <h3 class="text-xs font-semibold uppercase text-gray-500">@I18n["Status"]</h3>
                        <p class="mt-1 text-sm text-gray-800">@Model.Status</p>
                    </div>

                    <div>
                        <h3 class="text-xs font-semibold uppercase text-gray-500">@I18n["Interaction Type"]</h3>
                        <p class="mt-1 text-sm text-gray-800">@Model.InteractionForm</p>
                    </div>

                    <div>
                        <h3 class="text-xs font-semibold uppercase text-gray-500">@I18n["AI Nudging Strength"]</h3>
                        <p class="mt-1 text-sm text-gray-800">@Model.NudgingStrength</p>
                    </div>

                    <div>
                        <h3 class="text-xs font-semibold uppercase text-gray-500">@I18n["Start Date"]</h3>
                        <p class="mt-1 text-sm text-gray-800">
                            @(Model.StartDate == default ? "-" : Model.StartDate.ToString("yyyy-MM-dd"))
                        </p>
                    </div>

                    <div>
                        <h3 class="text-xs font-semibold uppercase text-gray-500">@I18n["End Date"]</h3>
                        <p class="mt-1 text-sm text-gray-800">
                            @(Model.EndDate == default ? "-" : Model.EndDate.ToString("yyyy-MM-dd"))
                        </p>
                    </div>

                    <div class="sm:col-span-2">
                        <h3 class="text-xs font-semibold uppercase text-gray-500">@I18n["Workspace"]</h3>
                        <p class="mt-1 text-sm text-gray-800">
                            @Model.Workspace?.Name
                        </p>
                    </div>

                </div>
            </div>

            <!-- Footer actions -->
            <div class="flex items-center justify-end gap-3 border-t border-gray-200 px-6 py-4">

                <a href="@Url.Action("EditProject", "WorkspaceAdmin", new { id = Model.Id.Text })"
                   class="inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700">
                    @I18n["Edit"]
                </a>

                <button type="button"
                        data-delete-id="@Model.Id.Text"
                        data-delete-name="@Model.Name"
                        data-delete-endpoint="/admin/project/delete/@Model.Id.Text"
                        class="inline-flex items-center rounded-md border border-red-200 px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50">
                    @I18n["Delete"]
                </button>
            </div>

        </div>
    </main>
</div>

@await Html.PartialAsync("_DeleteModal")
