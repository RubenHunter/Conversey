@using Conversey.BL.Domain.Administration
@using Conversey.UI_MVC.Models
@model Conversey.UI_MVC.Models.WorkspaceAdmin.ProjectViewModel
@inject WorkspaceContext WorkspaceContext

<form id="create-project-step1-form" method="post" asp-action="CreateProject" enctype="multipart/form-data" class="space-y-6">
    <div>
        <h2 class="text-2xl font-bold text-text">Step 1: Intro &amp; Presentation</h2>
        <p class="mt-1 text-sm text-text/60">Basic project details and cover image.</p>
    </div>

    <div>
        <label asp-for="CreateStep1ViewModel.Name" class="block text-sm font-medium text-text">Project Name</label>
        <input asp-for="CreateStep1ViewModel.Name" class="mt-1 block w-full rounded-md border border-text/20 bg-background px-3 py-2" required />
        <span asp-validation-for="CreateStep1ViewModel.Name" class="text-sm text-red-600"></span>
    </div>

    <div>
        <label class="block text-sm font-medium text-text">Workspace</label>
        <input type="text" value="@WorkspaceContext.CurrentWorkspace.Name" disabled
               class="mt-1 block w-full rounded-md border border-text/20 bg-text/5 px-3 py-2 text-text/70 sm:text-sm" />
    </div>

    <div>
        <label asp-for="CreateStep1ViewModel.Description" class="block text-sm font-medium text-text">Description</label>
        <textarea asp-for="CreateStep1ViewModel.Description" rows="4"
                  class="mt-1 block w-full rounded-md border border-text/20 bg-background px-3 py-2"></textarea>
        <span asp-validation-for="CreateStep1ViewModel.Description" class="text-sm text-red-600"></span>
    </div>

    <div>
        <label asp-for="CreateStep1ViewModel.ImageFile" class="block text-sm font-medium text-text">Cover Image</label>
        <input asp-for="CreateStep1ViewModel.ImageFile" id="step1ImageFile" type="file" accept="image/*"
               class="mt-1 block w-full rounded-md border border-text/20 bg-background px-3 py-2 text-sm" />
        <input asp-for="CreateStep1ViewModel.ImageUrl" id="step1ImageUrl" type="hidden" />
        <input id="step1ImageUploadSignature" type="hidden" />
        <p id="step1ImageUploadStatus" class="mt-1 text-xs text-text/60"></p>
        <p id="step1ImageUploadError" class="mt-1 text-xs text-red-600"></p>
        <span asp-validation-for="CreateStep1ViewModel.ImageFile" class="text-sm text-red-600"></span>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
            <label asp-for="CreateStep1ViewModel.InteractionForm" class="block text-sm font-medium text-text">Interaction Form</label>
            <select asp-for="CreateStep1ViewModel.InteractionForm" asp-items="Html.GetEnumSelectList<InteractionType>()"
                    class="mt-1 block w-full rounded-md border border-text/20 bg-background px-3 py-2">
            </select>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
            <label asp-for="CreateStep1ViewModel.StartDate" class="block text-sm font-medium text-text">Start Date</label>
            <input asp-for="CreateStep1ViewModel.StartDate" type="date"
                   class="mt-1 block w-full rounded-md border border-text/20 bg-background px-3 py-2" />
        </div>

        <div>
            <label asp-for="CreateStep1ViewModel.EndDate" class="block text-sm font-medium text-text">End Date</label>
            <input asp-for="CreateStep1ViewModel.EndDate" type="date"
                   class="mt-1 block w-full rounded-md border border-text/20 bg-background px-3 py-2" />
        </div>
    </div>
</form>
