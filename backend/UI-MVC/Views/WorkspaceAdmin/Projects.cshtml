@using Conversey.BL.Domain.Administration
@using Conversey.UI_MVC.Models
@using Conversey.UI_MVC.Models.Admin
@using Conversey.UI_MVC.Resources
@using Microsoft.AspNetCore.Html
@using Microsoft.AspNetCore.Mvc.Rendering
@model Conversey.UI_MVC.Models.WorkspaceAdmin.ProjectsPageViewModel
@Html.AntiForgeryToken()
@inject WorkspaceContext WorkspaceContext
@inject IAdminI18nService I18n
@{
    ViewData["WorkspaceName"] = WorkspaceContext.CurrentWorkspace.Name;
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        ("Dashboard", "/admin", false),
        (I18n["Projects"], null, true)
    };
}

<div id="projectsPage"
     class="min-h-screen bg-background font-sans text-text"
     data-draft-prefix="workspace:@WorkspaceContext.CurrentWorkspace.Id:project-create">
    
    @await Html.PartialAsync("_AdminHeader")

    <!-- Container widened to w-full with a max-width of 1600px for ultra-wide screens -->
    <main class="p-8 w-full max-w-400 mx-auto" data-search-root data-search-input="#projectSearchInput" data-search-count="#projectSearchCount">
        
        @* ── STATS ROW ── *@
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
            <div class="bg-white rounded-xl border border-text/10 p-4 flex items-center gap-3 shadow-sm">
                <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                </div>
                <div>
                    <div class="text-2xl font-bold text-text">@Model.TotalProjects</div>
                    <div class="text-[10px] font-semibold text-text/45 uppercase tracking-wide">@I18n["Projects"]</div>
                </div>
            </div>
            <div class="bg-white rounded-xl border border-text/10 p-4 flex items-center gap-3 shadow-sm">
                <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <div>
                    <div class="text-2xl font-bold text-text">@Model.ParticipantCount</div>
                    <div class="text-[10px] font-semibold text-text/45 uppercase tracking-wide">Participants</div>
                </div>
            </div>
            <div class="bg-white rounded-xl border border-text/10 p-4 flex items-center gap-3 shadow-sm">
                <div class="w-10 h-10 rounded-lg bg-accent/10 text-accent flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                    </svg>
                </div>
                <div>
                    <div class="text-2xl font-bold text-text">@Model.IdeaCount</div>
                    <div class="text-[10px] font-semibold text-text/45 uppercase tracking-wide">Ideas</div>
                </div>
            </div>
            <div class="bg-white rounded-xl border border-text/10 p-4 flex items-center gap-3 shadow-sm">
                <div class="w-10 h-10 rounded-lg bg-secondary/20 text-secondary flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div>
                    <div class="text-2xl font-bold text-text">@Model.AnswerCount</div>
                    <div class="text-[10px] font-semibold text-text/45 uppercase tracking-wide">Answers</div>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div class="flex items-center space-x-4">
                <div class="relative w-80">
                    <input id="projectSearchInput" type="text" placeholder="@I18n["Search projects..."]" 
                           class="w-full pl-10 pr-4 py-2 bg-white border border-secondary/20 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all shadow-sm" />
                    <span class="absolute left-3 top-2.5 text-secondary">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </span>
                </div>
                <div class="flex items-center gap-2">
                    <button class="px-3 py-2 text-sm font-medium text-text/60 hover:text-accent transition-colors">@I18n["Delete"]</button>
                    <button class="px-3 py-2 text-sm font-medium text-text/60 hover:text-primary transition-colors">@I18n["Select all"]</button>
                </div>
            </div>
            
            <div class="text-sm text-text/50">
                @I18n["Showing"] <strong id="projectSearchCount">@Model.TotalProjects</strong> @I18n["projects"]
            </div>
        </div>

        <!-- Project Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8" data-search-items>
            @foreach (var project in Model.Projects)
            {
                <div class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-secondary/10 relative" data-search-item data-search-text="@project.Title @project.Status">
                @* The main link covers the whole card *@
                <a class="absolute inset-0 z-10" href="/admin/projects/@project.Id" aria-label="@(string.Format(I18n["View project {0}"], project.Title))"></a>
                
                @* TOP SECTION: Now includes the image variable and the custom class *@
                <div class="project-card-header h-44 relative flex items-center justify-center bg-linear-to-br from-primary/5 to-secondary/5 overflow-hidden"
                     style="--card-image: url('@project.ImageUrl');">
                    
                    <div class="text-center px-4 relative z-0">
                        <span class="block font-bold text-xl text-primary tracking-tight">@project.Title</span>
                        <span class="text-xs uppercase tracking-widest text-secondary font-semibold mt-1 block">@I18n["Project Workspace"]</span>
                    </div>

                    <div class="absolute top-3 right-3 flex gap-2 z-20">
                        <span class="text-[10px] uppercase tracking-widest font-bold px-2 py-1 rounded-full border border-secondary/20 bg-white/90 text-secondary">
                            @project.Status
                        </span>
                    </div>
                    
                    @* Hover tint overlay *@
                    <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/5 transition-colors duration-300"></div>
                </div>

                @* FOOTER SECTION: Restored to original layout *@
                <div class="p-4 flex items-center justify-between border-t border-secondary/10 relative z-20">
                    @* Avatars *@
                    <div class="flex -space-x-2">
                        <div class="w-8 h-8 rounded-full bg-secondary/20 border-2 border-white flex items-center justify-center text-[10px] font-bold">JD</div>
                        <div class="w-8 h-8 rounded-full bg-primary/20 border-2 border-white flex items-center justify-center text-[10px] font-bold text-primary">+3</div>
                    </div>

                    @* Action Buttons *@
                    <div class="flex items-center space-x-1">
                        <a title="@I18n["Edit"]" class="p-2 text-text/40 hover:text-primary hover:bg-primary/5 rounded-lg transition-all relative z-20" href="/admin/project/@project.Id" aria-label="@(string.Format(I18n["Edit project {0}"], project.Title))">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                        </a>
                        <button title="Archive" class="p-2 text-text/40 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-all" data-archive-id="@project.Id" data-archive-name="@project.Title">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-2 12a2 2 0 01-2 2H8a2 2 0 01-2-2L4 7m16 0H4m16 0-1-3H5L4 7"></path></svg>
                        </button>
                        <button title="Copy" class="p-2 text-text/40 hover:text-primary hover:bg-primary/5 rounded-lg transition-all relative z-20" data-copy-id="@project.Id" data-copy-name="@project.Title" aria-label="Copy project @project.Title">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 8h8a2 2 0 002-2V8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                        </button>
                        <button title="Notifications" class="p-2 text-text/40 hover:text-accent hover:bg-accent/5 rounded-lg transition-all">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                        </button>
                        <button title="Share" class="p-2 text-text/40 hover:text-primary hover:bg-primary/5 rounded-lg transition-all relative z-20" data-share-id="@project.Id" data-share-name="@project.Title" data-share-status="@project.Status">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
                        </button>
                    </div>
                </div>
            </div>
            }

            <!-- Persistent "Add New" Card: Ensures the layout never looks empty -->
            <a class="group border-2 border-dashed border-secondary/20 rounded-xl h-60.25 flex flex-col items-center justify-center hover:border-primary/50 hover:bg-primary/5 transition-all" href="/admin/projects/new" aria-label="@I18n["Create project"]">
                <div class="w-12 h-12 rounded-full bg-white shadow-sm border border-secondary/10 flex items-center justify-center text-secondary group-hover:text-primary group-hover:scale-110 transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                </div>
                <span class="mt-4 font-bold text-sm text-secondary group-hover:text-primary">@I18n["Create New Project"]</span>
            </a>
        </div>
    </main>

    <!-- Floating Action Button remains for quick access -->
    <a class="fixed bottom-8 right-8 bg-primary text-white flex items-center space-x-2 px-6 py-4 rounded-2xl font-bold shadow-lg shadow-primary/30 hover:bg-primary/90 hover:scale-105 active:scale-95 transition-all group" href="/admin/projects/new" aria-label="@I18n["New Project"]">
        <svg class="w-6 h-6 transition-transform group-hover:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        <span>@I18n["New Project"]</span>
    </a>
</div>


@await Html.PartialAsync("_DeleteModal")

<div id="archiveModal"
     class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/50">

    <div class="w-full max-w-md rounded-lg bg-white p-6 shadow-lg">

        <h2 class="text-lg font-semibold text-gray-900">
            Archive project
        </h2>

        <p class="mt-2 text-sm text-gray-600">
            <span id="archiveItemName" class="font-medium text-gray-900"></span>
            project not publicly accessible anymore, only visible to admins.
        </p>

        <div class="mt-6 flex justify-end gap-3">
            <button id="cancelArchive"
                    type="button"
                    class="rounded-md border px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                Cancel
            </button>

            <button id="confirmArchive"
                    type="button"
                    class="rounded-md bg-amber-600 px-4 py-2 text-sm text-white hover:bg-amber-700">
                Archive
            </button>
        </div>
    </div>
</div>

<div id="copyModal"
     class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/50">

    <div class="w-full max-w-md rounded-lg bg-white p-6 shadow-lg">

        <h2 class="text-lg font-semibold text-gray-900">
            Copy project
        </h2>

        <p class="mt-2 text-sm text-gray-600">
            Copy <span id="copyItemName" class="font-medium text-gray-900"></span> into a new draft?
        </p>

        <div class="mt-6 flex justify-end gap-3">
            <button id="cancelCopy"
                    type="button"
                    class="rounded-md border px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                Cancel
            </button>

            <button id="confirmCopy"
                    type="button"
                    class="rounded-md bg-primary px-4 py-2 text-sm text-white hover:bg-primary/90">
                Copy
            </button>
        </div>
    </div>
</div>

<div id="recoverDraftModal"
     class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/50">

    <div class="w-full max-w-md rounded-lg bg-white p-6 shadow-lg">

        <h2 class="text-lg font-semibold text-gray-900">
            Unsaved draft found
        </h2>

        <p class="mt-2 text-sm text-gray-600">
            You have an unsaved project draft from a previous session. Would you like to recover it or discard it?
        </p>

        <div class="mt-6 flex justify-end gap-3">
            <button id="recoverDraftDiscard"
                    type="button"
                    class="rounded-md border border-red-200 px-4 py-2 text-sm text-red-700 hover:bg-red-50">
                Discard
            </button>

            <button id="recoverDraftRecover"
                    type="button"
                    class="rounded-md bg-primary px-4 py-2 text-sm text-white hover:bg-primary/90">
                Recover
            </button>
        </div>
    </div>
</div>

<div id="shareModal"
     class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/50">

    <div class="w-full max-w-md rounded-lg bg-white p-6 shadow-lg">

        <h2 class="text-lg font-semibold text-gray-900">
            Share project
        </h2>

        <h3 id="shareItemName" class="mt-1 text-base font-medium text-text"></h3>

        <div class="mt-3 flex items-center gap-2">
            <span class="text-xs font-semibold uppercase tracking-wider text-text/50">Status</span>
            <span id="shareStatusBadge" class="text-[10px] uppercase tracking-widest font-bold px-2 py-1 rounded-full border"></span>
        </div>

        <div id="shareAccessInfo" class="mt-3 p-3 rounded-lg bg-gray-50 text-sm text-gray-700">
        </div>

        <div class="mt-4 flex items-center gap-2">
            <input id="shareUrlInput" type="text" readonly
                   class="flex-1 rounded-md border border-gray-300 bg-gray-50 px-3 py-2 text-sm text-gray-700 font-mono" />
            <button id="copyShareUrl"
                    type="button"
                    class="rounded-md bg-primary px-4 py-2 text-sm text-white hover:bg-primary/90 shrink-0">
                Copy
            </button>
        </div>

        <div id="shareQrSection" class="mt-3 hidden">
            <button id="toggleQrBtn" type="button" class="flex items-center gap-2 text-sm text-text/60 hover:text-primary transition-colors w-full">
                <svg id="qrArrow" class="w-4 h-4 transition-transform duration-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
                <span>QR Code</span>
            </button>
            <div id="shareQrContainer" class="grid transition-[grid-template-rows] duration-300 ease-in-out grid-rows-[0fr] mt-3">
                <div class="overflow-hidden">
                    <div class="flex flex-col items-center gap-3">
                        <canvas id="shareQrCanvas" class="rounded-lg border border-gray-200"></canvas>
                        <button id="downloadQrBtn" type="button" class="flex items-center gap-2 rounded-md border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                            Download
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 flex justify-end">
            <button id="cancelShare"
                    type="button"
                    class="rounded-md border px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                Close
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" vite-src="~/components/shared/projectsPage.ts"></script>
}
