@using Conversey.UI_MVC.Resources
@inject IAdminI18nService I18n
@model Conversey.UI_MVC.Models.WorkspaceAdmin.ProjectViewModel

<form id="create-project-step4-form">
    <input type="hidden" id="step4PromptsJson" name="CreateStep4ViewModel.PromptsJson" value="@Model.CreateStep4ViewModel.PromptsJson" />

    <section class="step-panel">
        <div class="step-panel-bg"></div>
        <div class="step-panel-content">
            <div class="step-panel-header">
                <div class="space-y-3">
                    <p class="step-panel-kicker">AI configuration</p>
                    <h2 class="step-panel-title">Step 4: Tune the AI</h2>
                    <p class="step-panel-subtitle">@I18n["Configure how AI assists participants during this project."]</p>
                </div>
                <div class="hidden sm:flex flex-col items-end gap-2">
                    <div class="step-panel-badge">Step 4</div>
                    <div class="step-panel-badge-subtitle">Behavior & prompts</div>
                </div>
            </div>

            <div class="max-w-2xl space-y-4">

                <div class="rounded-xl border border-text/15 bg-background p-4 space-y-3">
            <div>
                <label for="step4NudgingStrength" class="block text-sm font-semibold text-text mb-0.5">@I18n["AI Nudging Strength"]</label>
                <p class="text-xs text-text/55 mb-4">@I18n["Controls how often AI prompts participants to expand or refine their ideas."]</p>
                <div class="range-slider">
                    <input type="range" id="step4NudgingStrength" name="CreateStep1ViewModel.NudgingStrength"
                           min="1" max="5" step="1"
                           value="@Model.CreateStep1ViewModel.NudgingStrength" />
                    <span id="step4NudgingDisplay" class="range-slider-badge">@Model.CreateStep1ViewModel.NudgingStrength</span>
                </div>
                <div class="flex justify-between mt-2 px-0.5">
                    <span class="text-xs text-text/40">@I18n["Minimal"]</span>
                    <span class="text-xs text-text/40">@I18n["Balanced"]</span>
                    <span class="text-xs text-text/40">@I18n["Maximum"]</span>
                </div>
            </div>
                </div>

                @* Advanced Settings collapsible *@
                <div class="rounded-xl border border-text/15 bg-background overflow-hidden">
            <button type="button" id="step4AdvancedToggle"
                    class="w-full flex items-center justify-between px-4 py-3 text-sm font-semibold text-text hover:bg-text/5 transition-colors">
                <span>@I18n["Advanced Settings"]</span>
                <svg id="step4AdvancedChevron"
                     class="w-4 h-4 text-text/50 transition-transform duration-300"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <div id="step4AdvancedPanel"
                 class="overflow-hidden transition-[max-height] duration-500 ease-in-out"
                 style="max-height: 0;">
                <div class="px-4 pb-4 pt-2 space-y-3">
                    <p class="text-xs text-text/55">@I18n["Customize AI prompt templates for this project. Leave a prompt unchanged to use the global default."]</p>
                    @if (Model.Step4Prompts.Any())
                    {
                        <div class="space-y-3" id="step4PromptList">
                            @foreach (var prompt in Model.Step4Prompts)
                            {
                                @await Html.PartialAsync("_PromptCard", (
                                    Prompt: prompt,
                                    EditUrl: (string)null,
                                    HasOverride: false
                                ))
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-xs text-text/40">@I18n["No configurable prompts available."]</p>
                    }
                </div>
            </div>
                </div>

            </div>
        </div>
    </section>
</form>

@* Prompt edit modal *@
<div id="step4PromptModal"
     class="hidden fixed inset-0 z-50 bg-black/40 flex items-center justify-center p-4">
    <div class="w-full max-w-2xl bg-background rounded-2xl shadow-xl flex flex-col max-h-[90vh]">
        <div class="flex items-center justify-between px-6 py-4 border-b border-secondary/10 flex-shrink-0">
            <div>
                <h2 id="step4ModalTitle" class="text-base font-bold text-text"></h2>
                <p id="step4ModalDescription" class="text-xs text-text/50 mt-0.5"></p>
            </div>
            <button type="button" id="step4ModalClose" class="text-text/40 hover:text-text transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div class="overflow-y-auto flex-1 px-6 py-4">
            <p class="text-xs text-text/55 mb-3">@I18n["Edit the user prompt template for this project. Use {{variables}} for dynamic values. Leave empty to use the global default."]</p>
            <textarea id="step4ModalTextarea"
                      rows="12"
                      class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 font-mono text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary resize-y"></textarea>
        </div>
        <div class="flex items-center justify-between px-6 py-4 border-t border-secondary/10 flex-shrink-0 gap-3">
            <button type="button" id="step4ModalReset"
                    class="text-xs text-text/50 hover:text-text transition-colors underline underline-offset-2">
                @I18n["Reset to global default"]
            </button>
            <div class="flex gap-2">
                <button type="button" id="step4ModalCancel"
                        class="px-5 py-2 border border-text/20 rounded-lg text-sm hover:bg-text/5 transition-colors">
                    @I18n["Cancel"]
                </button>
                <button type="button" id="step4ModalApply"
                        class="px-5 py-2 bg-primary text-white rounded-lg text-sm hover:bg-primary/90 transition-colors font-medium">
                    @I18n["Apply"]
                </button>
            </div>
        </div>
    </div>
</div>
