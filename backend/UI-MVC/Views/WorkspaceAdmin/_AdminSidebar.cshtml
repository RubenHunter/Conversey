@using Conversey.BL.Administration
@using Conversey.UI_MVC.Models
@using Conversey.UI_MVC.Resources
@inject AdminContext AdminContext
@inject WorkspaceContext WorkspaceContext
@inject IAdminI18nService I18n
@inject IProjectManager ProjectManager

@{
    var wsSlug = WorkspaceContext.CurrentWorkspace?.Id.Text ?? "";
    var projects = WorkspaceContext.CurrentWorkspace?.Id is { } wsId
        ? ProjectManager.GetAllProjectsFromWorkspaceId(wsId)
        : Enumerable.Empty<Conversey.BL.Domain.Administration.Project>();
}

<aside class="hidden lg:flex fixed inset-y-0 left-0 w-[17rem] flex-col border-r border-secondary/10 bg-white/95 backdrop-blur z-40">
    <div class="pointer-events-none absolute inset-x-0 border-t border-secondary/10" style="top: var(--admin-header-height, 4rem);"></div>
    <div class="px-4 py-3">
        <a asp-controller="AdminProfile" asp-action="Index" class="group flex items-center gap-3 px-2 py-0 text-text hover:text-primary transition-colors">
            <span class="w-8 h-8 rounded-full border border-secondary/30 flex items-center justify-center text-primary group-hover:border-primary/40 transition-colors shrink-0">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                </svg>
            </span>
            <div class="min-w-0">
                <div class="text-xs font-bold truncate">@AdminContext.CurrentAdmin.Email</div>
                <div class="text-[10px] text-secondary">@I18n["Workspace Admin"]</div>
            </div>
        </a>
    </div>

    <nav class="flex-1 overflow-y-auto px-4 py-5 space-y-2" data-sidebar-nav>
        @* ── Dashboard ── *@
        <a href="/admin" class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-semibold text-text/70 hover:text-primary hover:bg-primary/5 transition-all shrink-0" data-sidebar-page="/admin">
            <span class="w-8 h-8 rounded-lg bg-background border border-secondary/10 flex items-center justify-center text-primary shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7m-9 2v8m4-8v8m5-13l2 2"></path></svg>
            </span>
            Dashboard
        </a>

        @* ── Projects (expandable) ── *@
        <div class="sidebar-section" data-sidebar-section>
            <button type="button" class="sidebar-section-toggle flex items-center gap-3 w-full px-3 py-2 rounded-lg text-sm font-semibold text-text/70 hover:text-primary hover:bg-primary/5 transition-all" data-sidebar-toggle="projects" aria-expanded="false">
                <span class="w-8 h-8 rounded-lg bg-background border border-secondary/10 flex items-center justify-center text-primary shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h10"></path></svg>
                </span>
                <span class="flex-1 text-left">Projects</span>
                <svg class="sidebar-chevron w-3.5 h-3.5 text-secondary shrink-0 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="sidebar-section-content grid transition-[grid-template-rows] duration-300 ease-in-out grid-rows-[0fr] ml-5 mt-1" data-sidebar-content="projects">
                <div class="overflow-hidden">
                    <div class="space-y-0.5 pt-1">
                <a href="/admin/projects" class="sidebar-link sidebar-sublink flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium text-text/50 hover:text-primary hover:bg-primary/5 transition-all" data-sidebar-page="/admin/projects">
                    <span class="w-3 h-3 shrink-0 flex items-center justify-center">+</span>
                    View all
                </a>
                @foreach (var project in projects)
                {
                    <a href="/admin/projects/@project.Id" class="sidebar-link sidebar-sublink flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium text-text/50 hover:text-primary hover:bg-primary/5 transition-all truncate" data-sidebar-page="/admin/projects/@project.Id" title="@project.Name">
                        <svg class="w-3 h-3 shrink-0 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        @project.Name
                    </a>
                }
                    </div>
                </div>
            </div>
        </div>

        @* ── AI Dashboard ── *@
        <a href="/admin/@wsSlug/ai" class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-semibold text-text/70 hover:text-primary hover:bg-primary/5 transition-all shrink-0" data-sidebar-page="/admin/@wsSlug/ai">
            <span class="w-8 h-8 rounded-lg bg-background border border-secondary/10 flex items-center justify-center text-primary shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </span>
            AI Dashboard
        </a>

        @* ── Costs ── *@
        <a href="/admin/@wsSlug/ai/costs" class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-semibold text-text/70 hover:text-primary hover:bg-primary/5 transition-all shrink-0" data-sidebar-page="/admin/@wsSlug/ai/costs">
            <span class="w-8 h-8 rounded-lg bg-background border border-secondary/10 flex items-center justify-center text-primary shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5h6m2 0h2v14H3V5h2m4 0v14"></path></svg>
            </span>
            Costs
        </a>

        @* ── Moderation ── *@
        <a href="/admin/workspace/moderation" class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-semibold text-text/70 hover:text-primary hover:bg-primary/5 transition-all shrink-0" data-sidebar-page="/admin/workspace/moderation">
            <span class="w-8 h-8 rounded-lg bg-background border border-secondary/10 flex items-center justify-center text-primary shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </span>
            Moderation
        </a>

        @* ── Analytics (expandable) ── *@
        <div class="sidebar-section" data-sidebar-section>
            <button type="button" class="sidebar-section-toggle flex items-center gap-3 w-full px-3 py-2 rounded-lg text-sm font-semibold text-text/70 hover:text-primary hover:bg-primary/5 transition-all" data-sidebar-toggle="analytics" aria-expanded="false">
                <span class="w-8 h-8 rounded-lg bg-background border border-secondary/10 flex items-center justify-center text-primary shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                </span>
                <span class="flex-1 text-left">Analytics</span>
                <svg class="sidebar-chevron w-3.5 h-3.5 text-secondary shrink-0 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="sidebar-section-content grid transition-[grid-template-rows] duration-300 ease-in-out grid-rows-[0fr] ml-5 mt-1" data-sidebar-content="analytics">
                <div class="overflow-hidden">
                    <div class="space-y-0.5 pt-1">
                <a href="/admin/workspace/analytics" class="sidebar-link sidebar-sublink flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium text-text/50 hover:text-primary hover:bg-primary/5 transition-all" data-sidebar-page="/admin/workspace/analytics">
                    <svg class="w-3 h-3 shrink-0 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    Overview
                </a>
                <a href="/admin/workspace/analytics/ideas" class="sidebar-link sidebar-sublink flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium text-text/50 hover:text-primary hover:bg-primary/5 transition-all" data-sidebar-page="/admin/workspace/analytics/ideas">
                    <svg class="w-3 h-3 shrink-0 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    Ideas
                </a>
                <a href="/admin/workspace/analytics/answers" class="sidebar-link sidebar-sublink flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium text-text/50 hover:text-primary hover:bg-primary/5 transition-all" data-sidebar-page="/admin/workspace/analytics/answers">
                    <svg class="w-3 h-3 shrink-0 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    Answers
                </a>
                    </div>
                </div>
            </div>
        </div>

        @* ── Admins ── *@
        <a href="/admin/workspace/admins" class="sidebar-link flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-semibold text-text/70 hover:text-primary hover:bg-primary/5 transition-all shrink-0" data-sidebar-page="/admin/workspace/admins">
            <span class="w-8 h-8 rounded-lg bg-background border border-secondary/10 flex items-center justify-center text-primary shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            </span>
            Admins
        </a>
    </nav>

    <div class="mt-auto px-4 py-5">
        <form class="w-full" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Account/Login", new { area = "Identity" })" method="post">
            <button type="submit" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border border-accent/30 text-accent font-bold text-sm hover:bg-accent/5 transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2h4a2 2 0 012 2v1"></path></svg>
                Log out
            </button>
        </form>
    </div>
</aside>
