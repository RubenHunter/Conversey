@using Conversey.UI_MVC.Models
@using Conversey.BL.Domain.Administration
@model Conversey.UI_MVC.Models.WorkspaceAi.WorkspaceAiPromptEditViewModel
@inject AdminContext AdminContext
@{
    ViewData["Title"] = $"Edit Prompt: {Model.Prompt.Name}";
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        ("Dashboard", $"/admin/{Model.WorkspaceId}", false),
        ("AI Settings", $"/admin/{Model.WorkspaceId}/ai", false),
        ("Prompts", $"/admin/{Model.WorkspaceId}/ai/prompts", false),
        (Model.Prompt.Name, null, true)
    };
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-text tracking-tight"><span data-i18n="Edit">Edit</span>: @Model.Prompt.Name</h1>
                <p class="mt-1 text-sm text-text/60">@(string.IsNullOrWhiteSpace(Model.Prompt.Description) ? "Modify the prompt template." : Model.Prompt.Description)</p>
            </div>
            <a href="@Url.Action("Prompts", new { workspaceSlug = Model.WorkspaceId, projectId = Model.ProjectId })" class="text-sm text-primary hover:text-primary/80 transition-colors flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                <span data-i18n="Back to Prompts">Back to Prompts</span>
            </a>
        </div>

        @if (Model.HasDefault)
        {
            <div class="mb-6 rounded-xl border border-primary/20 bg-primary/5 p-4 flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <div>
                    <p class="text-sm font-medium text-primary" data-i18n="Reset to default available">Reset to default available</p>
                    <p class="text-xs text-text/60 mt-1" data-i18n="If you break this prompt, you can restore the original default values.">If you break this prompt, you can restore the original default values.</p>
                    <form asp-action="ResetPrompt" asp-route-workspaceSlug="@Model.WorkspaceId" asp-route-id="@Model.Prompt.Id" method="post" class="mt-2 inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="projectId" value="@Model.ProjectId" />
                        <button type="submit" class="px-3 py-1.5 bg-primary/10 text-primary rounded-lg hover:bg-primary/20 transition-colors text-xs font-medium" onclick="return confirm('Reset this prompt to its default values? This will overwrite your changes.')">
                            <span data-i18n="Reset to Default">Reset to Default</span>
                        </button>
                    </form>
                </div>
            </div>
        }

        <form asp-action="SavePrompt" asp-route-workspaceSlug="@Model.WorkspaceId" asp-route-id="@Model.Prompt.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="projectId" value="@Model.ProjectId" />
            <input type="hidden" asp-for="Prompt.Id" />
            <input type="hidden" asp-for="Prompt.Name" />

            @await Html.PartialAsync("_PromptEditCard", (
                Prompt: Model.Prompt,
                TextareaName: "Prompt.UserPromptTemplate",
                TextareaId: "promptUserTemplate",
                ReadOnly: false
            ))

            <div class="bg-white rounded-xl border border-secondary/10 shadow-sm mb-6">
                <div class="px-6 py-4 border-b border-secondary/10">
                    <h2 class="text-sm font-semibold text-text" data-i18n="Description">Description</h2>
                    <p class="text-xs text-text/50 mt-0.5" data-i18n="Administrative note - what this prompt is used for.">Administrative note - what this prompt is used for.</p>
                </div>
                <div class="px-6 py-4">
                    <input asp-for="Prompt.Description" type="text" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" />
                </div>
            </div>

            <div class="flex items-center justify-end gap-3">
                <a href="@Url.Action("Prompts", new { workspaceSlug = Model.WorkspaceId, projectId = Model.ProjectId })" class="px-6 py-2 border border-secondary/20 rounded-lg hover:bg-background transition-colors text-sm font-medium text-text/70" data-i18n="Cancel">Cancel</a>
                <button type="submit" class="px-6 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors text-sm font-medium" data-i18n="Save Changes">Save Changes</button>
            </div>
        </form>
    </main>
</div>

<script type="module" vite-src="~/components/shared/infoToggle.ts"></script>
