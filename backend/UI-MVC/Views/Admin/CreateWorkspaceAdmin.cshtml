@model Conversey.UI_MVC.Models.Admin.AdminFormViewModel<Conversey.BL.Domain.Administration.WorkspaceAdmin>
@using Conversey.UI_MVC.Models
@using Conversey.UI_MVC.Resources
@inject AdminContext AdminContext
@inject IAdminI18nService AdminI18n
@{
    ViewData["Title"] = "Create Workspace Admin";
    ViewData["WorkspaceName"] = "Conversey Platform";
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        ("Dashboard", AdminContext.GetDashboardUrl(), false),
        ("Workspaces", "/admin/workspaces", false),
        ("Create Workspace Admin", null, true)
    };
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")
    
    <main class="p-8 w-full max-w-4xl mx-auto">
        @await Html.PartialAsync("_WorkspaceAdminForm", Model)
    </main>
</div>
