@{
    ViewData["Title"] = "Create Project";
}

<div class="min-h-screen bg-gray-50 px-4 py-10">
    <div class="mx-auto max-w-3xl rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between gap-4">
            <h1 class="text-2xl font-bold text-gray-900">Create Project</h1>
            <a
                href="@Url.Action("Projects", "Admin")"
                class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-700">
                Back to projects
            </a>
        </div>

        <p class="mt-4 text-gray-700">
            Project creation form placeholder.
        </p>
    </div>
</div>
