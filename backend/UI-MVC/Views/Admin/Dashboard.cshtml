@model Conversey.UI_MVC.Models.Admin.DashboardViewModel
@using Conversey.UI_MVC.Models
@inject AdminContext AdminContext
@inject WorkspaceContext WorkspaceContext

@{
    ViewData["Title"] = Model.PageTitle;
    var forcePasswordChange = TempData["ForcePasswordChange"] as bool? == true;
}

<div class="min-h-screen bg-background font-sans text-text admin-dashboard" data-force-password-change="@forcePasswordChange.ToString().ToLowerInvariant()">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-7xl mx-auto">

        <!-- Page Title -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-text tracking-tight" data-i18n="dashboard.title">@Model.PageTitle</h1>
            <p class="mt-2 text-sm text-text/60" data-i18n="dashboard.description">@Model.PageDescription</p>
        </div>

        <!-- Row 0: Stat Cards -->
        @if (Model.StatWidgets.Any())
        {
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6 animate-enter" style="animation-delay:0ms">
                @foreach (var stat in Model.StatWidgets)
                {
                    <div class="bg-white rounded-xl border border-secondary/10 p-5 shadow-sm">
                        <p class="text-xs font-semibold text-secondary uppercase tracking-wider" data-i18n="@stat.Label">@stat.Label</p>
                        <p class="text-3xl font-bold text-primary mt-1">@stat.Value</p>
                        @if (!string.IsNullOrEmpty(stat.SubLabel))
                        {
                            <p class="text-xs text-text/50 mt-1" data-i18n="@stat.SubLabel">@stat.SubLabel</p>
                        }
                    </div>
                }
            </div>
        }

        <!-- Row 1: Navigation Cards -->
        @if (Model.NavCards.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6 animate-enter" style="animation-delay:0ms">
                @foreach (var navCard in Model.NavCards)
                {
                    @await Html.PartialAsync("~/Views/Shared/Admin/_NavCard.cshtml", navCard)
                }
            </div>
        }

         <!-- Row 3: Widget Row — Comparison (2 cols) | QuickLinks (1 col) | Engagement (1 col) -->
        @{
            bool hasComparison = Model.ComparisonWidget != null;
            bool hasQuickLinks = Model.QuickLinksWidget != null && Model.QuickLinksWidget.Items.Any();
            bool hasEngagement = Model.EngagementWidget != null;
            int widgetCols = (hasComparison ? 2 : 0) + (hasQuickLinks ? 1 : 0) + (hasEngagement ? 1 : 0);
            bool isComparisonFullWidth = hasComparison && Model.ComparisonWidget!.Items.Count > 10;
        }
        @if (widgetCols > 0)
        {
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 mb-6 items-stretch animate-enter" style="animation-delay:80ms">
                @if (hasComparison)
                {
                    <div class="@(isComparisonFullWidth ? "lg:col-span-4" : "lg:col-span-2")">
                        @await Html.PartialAsync("~/Views/Shared/Admin/Dashboard/_ComparisonWidget.cshtml", Model.ComparisonWidget)
                    </div>
                }
                @if (hasQuickLinks)
                {
                    <div class="lg:col-span-1">
                        @await Html.PartialAsync("~/Views/Shared/Admin/Dashboard/_QuickLinksWidget.cshtml", Model.QuickLinksWidget)
                    </div>
                }
                @if (hasEngagement)
                {
                    <div class="lg:col-span-1">
                        @await Html.PartialAsync("~/Views/Shared/Admin/Dashboard/_EngagementWidget.cshtml", Model.EngagementWidget)
                    </div>
                }
            </div>
        }

        <!-- Row 4: Usage Trend Chart -->
        @if (Model.UsageTrendChart != null)
        {
            <div class="bg-white rounded-xl border border-secondary/10 shadow-sm p-6 mb-6 animate-enter" style="animation-delay:160ms">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-bold" data-i18n="Usage Trend">Usage Trend</h2>
                    <div class="flex items-center gap-1 bg-secondary/5 rounded-lg p-1" id="dashboard-trend-periods">
                        <button type="button" data-days="7" class="px-3 py-1 text-xs font-medium rounded-md transition-colors text-text/50 hover:text-text" data-i18n="7d">7d</button>
                        <button type="button" data-days="30" class="px-3 py-1 text-xs font-medium rounded-md transition-colors bg-white text-text shadow-sm" data-i18n="1m">1m</button>
                        <button type="button" data-days="365" class="px-3 py-1 text-xs font-medium rounded-md transition-colors text-text/50 hover:text-text">1y</button>
                        <button type="button" data-days="0" class="px-3 py-1 text-xs font-medium rounded-md transition-colors text-text/50 hover:text-text" data-i18n="All">All</button>
                    </div>
                </div>
                <div style="position:relative; height:280px"><canvas id="dashboard-usage-trend"></canvas></div>
            </div>
            <script type="application/json" id="dashboard-usage-trend-data">@Html.Raw(Model.UsageTrendJson)</script>
        }

    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

<div id="forceChangePasswordModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-text/45 p-4">
    <div class="w-full max-w-md rounded-2xl border border-secondary/10 bg-white p-6 shadow-xl">
        <div class="mb-4">
            <h3 class="text-xl font-bold text-text">Change password</h3>
            <p class="mt-1 text-sm text-text/60">You must change your password before continuing.</p>
        </div>
        <form id="forceChangePasswordForm" asp-controller="AdminProfile" asp-action="ChangePassword" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div>
                <label for="forceNewPassword" class="mb-1 block text-sm font-semibold text-text/80">New password</label>
                <div class="relative">
                    <input id="forceNewPassword" name="NewPassword" type="password" required class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 pr-10 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25" />
                    <button type="button" class="absolute inset-y-0 right-0 flex items-center px-3 text-text/50 transition hover:text-text" data-password-toggle="forceNewPassword" aria-label="Show password">
                        <svg data-password-icon="show" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z" /><circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg data-password-icon="hide" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 1l22 22" /><path d="M10.6 10.6a3 3 0 0 0 4.24 4.24" /><path d="M9.88 9.88 7.1 7.1C4.5 8.6 2.8 12 2.8 12s3.5 6 10.2 6c2 0 3.7-.4 5.1-1.1l-2.28-2.28" /><path d="M14.12 14.12 9.88 9.88" /><path d="M17 7c-1.5-1-3.3-1.6-5-1.6-1.2 0-2.4.2-3.4.6" />
                        </svg>
                    </button>
                </div>
            </div>
            <div>
                <label for="forceConfirmPassword" class="mb-1 block text-sm font-semibold text-text/80">Confirm new password</label>
                <div class="relative">
                    <input id="forceConfirmPassword" name="ConfirmPassword" type="password" required class="w-full rounded-xl border border-secondary/20 bg-background/40 px-4 py-2.5 pr-10 text-sm text-text focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/25" />
                    <button type="button" class="absolute inset-y-0 right-0 flex items-center px-3 text-text/50 transition hover:text-text" data-password-toggle="forceConfirmPassword" aria-label="Show password">
                        <svg data-password-icon="show" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z" /><circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg data-password-icon="hide" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 1l22 22" /><path d="M10.6 10.6a3 3 0 0 0 4.24 4.24" /><path d="M9.88 9.88 7.1 7.1C4.5 8.6 2.8 12 2.8 12s3.5 6 10.2 6c2 0 3.7-.4 5.1-1.1l-2.28-2.28" /><path d="M14.12 14.12 9.88 9.88" /><path d="M17 7c-1.5-1-3.3-1.6-5-1.6-1.2 0-2.4.2-3.4.6" />
                        </svg>
                    </button>
                </div>
            </div>
            <ul id="forcePasswordChecklist" class="mt-1 space-y-1 text-xs text-accent">
                <li data-requirement="length" class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-accent"></span><span>At least 6 characters</span></li>
                <li data-requirement="lowercase" class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-accent"></span><span>Lowercase letter</span></li>
                <li data-requirement="uppercase" class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-accent"></span><span>Uppercase letter</span></li>
                <li data-requirement="digit" class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-accent"></span><span>Number</span></li>
                <li data-requirement="symbol" class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-accent"></span><span>Symbol</span></li>
            </ul>
            <p id="forcePasswordError" class="hidden text-sm font-medium text-accent"></p>
            <div class="mt-6 flex justify-end">
                <button type="submit" class="rounded-xl bg-primary px-4 py-2 text-sm font-semibold text-white transition hover:bg-primary/90">Update password</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script type="module" vite-src="~/components/shared/passwordVisibilityToggle.ts"></script>
    <script type="module" vite-src="~/components/shared/forcePasswordChangeModal.ts"></script>
}

<script>
(function() {
    var toggle = document.getElementById('dashboard-circles-toggle');
    if (!toggle) return;
    toggle.querySelectorAll('button').forEach(function(btn) {
        btn.addEventListener('click', function() {
            toggle.querySelectorAll('button').forEach(function(b) { b.classList.remove('bg-white', 'text-text', 'shadow-sm'); b.classList.add('text-text/50'); });
            btn.classList.add('bg-white', 'text-text', 'shadow-sm');
            btn.classList.remove('text-text/50');
            var filter = btn.getAttribute('data-filter');
            var showClass = filter === 'all' ? 'circle-all' : 'circle-active';
            var hideClass = filter === 'all' ? 'circle-active' : 'circle-all';
            document.querySelectorAll('.' + hideClass).forEach(function(el) { el.classList.add('hidden'); });
            document.querySelectorAll('.' + showClass).forEach(function(el) { el.classList.remove('hidden'); });
            var showLegend = filter === 'all' ? 'legend-all' : 'legend-active';
            var hideLegend = filter === 'all' ? 'legend-active' : 'legend-all';
            document.querySelectorAll('.' + hideLegend).forEach(function(el) { el.classList.add('hidden'); });
            document.querySelectorAll('.' + showLegend).forEach(function(el) { el.classList.remove('hidden'); });
        });
    });
})();
</script>

