@model Conversey.UI_MVC.Models.Admin.DashboardViewModel
@using Conversey.UI_MVC.Models
@inject AdminContext AdminContext
@inject WorkspaceContext WorkspaceContext

@{
    ViewData["Title"] = Model.PageTitle;
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-7xl mx-auto">
        <!-- Page Title -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-text tracking-tight">@Model.PageTitle</h1>
            <p class="mt-2 text-sm text-text/60">@Model.PageDescription</p>
        </div>

        <!-- Single 4-column grid for all widgets -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <!-- Stat Widgets: Small = 1 column each -->
            @if (Model.StatWidgets != null && Model.StatWidgets.Any())
            {
                @foreach (var statWidget in Model.StatWidgets)
                {
                    <div class="col-span-1">
                        @await Html.PartialAsync("~/Views/Shared/Admin/Dashboard/_StatWidget.cshtml", statWidget)
                    </div>
                }
            }

            <!-- Navigation Cards: Large = 2 columns each -->
            @if (Model.NavCards != null && Model.NavCards.Any())
            {
                @foreach (var navCard in Model.NavCards)
                {
                    <div class="md:col-span-2">
                        @await Html.PartialAsync("~/Views/Shared/Admin/_NavCard.cshtml", navCard)
                    </div>
                }
            }

            <!-- Comparison: Large = 2 columns -->
            @if (Model.ComparisonWidget != null)
            {
                <div class="md:col-span-2 h-full">
                    @await Html.PartialAsync("~/Views/Shared/Admin/Dashboard/_ComparisonWidget.cshtml", Model.ComparisonWidget)
                </div>
            }

            <!-- QuickLinks: 3 individual stacked in one column with gaps filling space -->
            @if (Model.QuickLinksWidget != null && Model.QuickLinksWidget.Items.Any())
            {
                <div class="col-span-1 h-full flex flex-col">
                    @foreach (var quickLink in Model.QuickLinksWidget.Items.Select((item, index) => (item, index)))
                    {
                        var (item, idx) = quickLink;
                        @await Html.PartialAsync("~/Views/Shared/Admin/Dashboard/_QuickLinkCard.cshtml", item)
                        @if (idx < Model.QuickLinksWidget.Items.Count - 1)
                        {
                            <div class="flex-grow min-h-0"></div>
                        }
                    }
                </div>
            }

            <!-- Engagement: Medium = 1 column -->
            @if (Model.EngagementWidget != null)
            {
                <div class="col-span-1 h-full">
                    @await Html.PartialAsync("~/Views/Shared/Admin/Dashboard/_EngagementWidget.cshtml", Model.EngagementWidget)
                </div>
            }

            <!-- Chart: ExtraLarge = 4 columns -->
            @if (Model.UsageTrendChart != null)
            {
                <div class="md:col-span-4">
                    @await Html.PartialAsync("~/Views/Shared/Admin/Dashboard/_ChartWidget.cshtml", Model.UsageTrendChart)
                </div>
            }
        </div>
    </main>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
}
