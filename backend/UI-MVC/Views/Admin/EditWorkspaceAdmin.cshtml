@using Conversey.UI_MVC.Resources
@model Conversey.UI_MVC.Models.Admin.AdminFormViewModel<Conversey.BL.Domain.Administration.WorkspaceAdmin>
@inject IAdminI18nService I18n
@{
    ViewData["Title"] = "Edit Workspace Admin";
    ViewData["WorkspaceName"] = "Conversey";
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        ("Workspaces", Url.Action("Workspaces", "ConverseyAdmin"), false),
        ("Edit workspace admin", null, true)
    };
    var formViewData = new ViewDataDictionary(ViewData)
    {
        ["ModalTitle"] = "Edit workspace admin",
        ["WorkspaceAdminEmailInputId"] = "workspaceAdminStandaloneEditEmailInput",
        ["WorkspaceAdminUsernameInputId"] = "workspaceAdminStandaloneEditUsernameInput",
        ["WorkspaceAdminPhoneInputId"] = "workspaceAdminStandaloneEditPhoneInput",
        ["SubmitLabel"] = "Save changes"
    };
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")
    <main class="mx-auto w-full max-w-2xl p-8">
        @await Html.PartialAsync("_WorkspaceAdminForm", Model, formViewData)
    </main>
</div>
