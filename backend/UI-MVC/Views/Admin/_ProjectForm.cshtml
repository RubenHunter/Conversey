@using Conversey.BL.Domain.Administration
@using Conversey.UI_MVC.Models
@model Conversey.UI_MVC.Models.Admin.ProjectFormViewModel
@inject WorkspaceContext WorkspaceContext

<form method="post" asp-action="@Model.FormAction" class="mt-6 space-y-6">
    
    @if (ViewData["IsEdit"] as bool? == true)
    {
        <input type="hidden" asp-for="Project.Id" />
    }

    <div>
        <label asp-for="Project.Name" class="block text-sm font-medium text-gray-700">Project Name</label>
        <input asp-for="Project.Name" class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" />
        <span asp-validation-for="Project.Name" class="text-sm text-red-600"></span>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700">Workspace</label>
        <input type="text" value="@WorkspaceContext.CurrentWorkspace.Name" disabled
               class="mt-1 block w-full rounded-md border border-gray-300 bg-gray-50 px-3 py-2 text-gray-500 sm:text-sm" />
    </div>

    <div>
        <label asp-for="Project.Description" class="block text-sm font-medium text-gray-700">Description</label>
        <textarea asp-for="Project.Description" rows="4"
                  class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2"></textarea>
        <span asp-validation-for="Project.Description" class="text-sm text-red-600"></span>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
            <label asp-for="Project.Status" class="block text-sm font-medium text-gray-700">Status</label>
            <select asp-for="Project.Status" asp-items="Html.GetEnumSelectList<Status>()"
                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2">
            </select>
        </div>

        <div>
            <label asp-for="Project.InteractionForm" class="block text-sm font-medium text-gray-700">Interaction Form</label>
            <select asp-for="Project.InteractionForm" asp-items="Html.GetEnumSelectList<InteractionType>()"
                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2">
            </select>
        </div>
    </div>

    <div>
        <label asp-for="Project.NudgingStrength" class="block text-sm font-medium text-gray-700">AI Nudging Strength</label>
        <select asp-for="Project.NudgingStrength"
                class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2">
            <option value="1">1 - Minimal (max 1 round)</option>
            <option value="2">2 - Light (max 1 round)</option>
            <option value="3">3 - Medium (default, max 2 rounds)</option>
            <option value="4">4 - Strong (max 3 rounds)</option>
            <option value="5">5 - Deep (max 4 rounds)</option>
        </select>
        <p class="mt-1 text-xs text-gray-500">Controls how hard the AI pushes for deeper idea quality before publish.</p>
        <span asp-validation-for="Project.NudgingStrength" class="text-sm text-red-600"></span>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
            <label asp-for="Project.StartDate" class="block text-sm font-medium text-gray-700">Start Date</label>
            <input asp-for="Project.StartDate" type="date"
                   class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" />
        </div>

        <div>
            <label asp-for="Project.EndDate" class="block text-sm font-medium text-gray-700">End Date</label>
            <input asp-for="Project.EndDate" type="date"
                   class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2" />
        </div>
    </div>

    <div class="flex justify-end pt-4">
        <button type="submit"
                class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">
            @Model.SubmitLabel
        </button>
    </div>
</form>
