@model IReadOnlyList<Conversey.BL.Domain.Ai.RateLimitConfig>
@{
    ViewData["Title"] = "Rate Limits";
}

<div class="min-h-screen bg-gray-50 px-4 py-10">
    <div class="mx-auto max-w-5xl">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Rate Limits</h1>
                <p class="mt-1 text-sm text-gray-500">Configure request rate limits for AI-powered API endpoints. Changes take effect immediately.</p>
            </div>
            <a href="@Url.Action("Index")" class="text-sm text-indigo-600 hover:text-indigo-700">&larr; Back to AI Management</a>
        </div>

        @if (Model.Count == 0)
        {
            <div class="mt-6 rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center">
                <p class="text-sm text-gray-500">No rate limit configurations found. Run the application with <code class="rounded bg-gray-100 px-1">Database:ResetOnStart</code> set to <code class="rounded bg-gray-100 px-1">true</code> to seed defaults.</p>
            </div>
        }
        else
        {
            <div class="mt-6 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-semibold uppercase text-gray-500">Policy</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-semibold uppercase text-gray-500">Permit Limit</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-semibold uppercase text-gray-500">Window (s)</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-semibold uppercase text-gray-500">Queue Limit</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-semibold uppercase text-gray-500">Last Updated</th>
                            <th scope="col" class="px-6 py-3"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 bg-white">
                        @foreach (var config in Model)
                        {
                            <tr>
                                <td class="whitespace-nowrap px-6 py-4">
                                    <span class="rounded bg-indigo-50 px-2 py-0.5 font-mono text-xs font-medium text-indigo-700">@config.PolicyName</span>
                                    <p class="mt-0.5 text-xs text-gray-400">
                                        @(config.PolicyName == "AiFixedPolicy" ? "User-facing AI endpoints (ideas, nudging, discovery)" : "Admin AI endpoints (health, costs, model listing)")
                                    </p>
                                </td>
                                <td class="whitespace-nowrap px-6 py-4 text-right font-mono text-sm text-gray-900">@config.PermitLimit req/min</td>
                                <td class="whitespace-nowrap px-6 py-4 text-right font-mono text-sm text-gray-900">@config.WindowSeconds s</td>
                                <td class="whitespace-nowrap px-6 py-4 text-right font-mono text-sm text-gray-900">@config.QueueLimit</td>
                                <td class="whitespace-nowrap px-6 py-4 text-right text-xs text-gray-400">@config.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="whitespace-nowrap px-6 py-4 text-right">
                                    <a href="@Url.Action("EditRateLimit", new { id = config.Id })" class="text-sm font-medium text-indigo-600 hover:text-indigo-700">Edit</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <p class="mt-4 text-xs text-gray-400">
                The <strong>permit limit</strong> is the number of requests allowed within the <strong>window</strong> (in seconds).
                Setting <strong>queue limit</strong> above 0 allows requests to be queued instead of immediately rejected when the limit is hit.
            </p>
        }
    </div>
</div>
