@model IReadOnlyList<Conversey.BL.Domain.Ai.AiProviderConfig>
@{
    ViewData["Title"] = "AI Providers";
}

<div class="min-h-screen bg-gray-50 px-4 py-10">
    <div class="mx-auto max-w-5xl">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">AI Providers</h1>
                <p class="mt-1 text-sm text-gray-500">Configure AI service providers, models, and API keys. Only one provider can be enabled at a time.</p>
            </div>
            <div class="flex items-center gap-3">
                <a href="@Url.Action("Index")" class="text-sm text-indigo-600 hover:text-indigo-700">&larr; Back</a>
                <a href="/api/ai/health" target="_blank" class="rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                    Test Connection (API)
                </a>
                <a href="@Url.Action("CreateProvider")" class="rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-medium text-white shadow-sm hover:bg-indigo-700">
                    Add Provider
                </a>
            </div>
        </div>

        <div class="mt-6 space-y-4">
            @if (!Model.Any())
            {
                <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
                    <p class="text-sm text-gray-500">No providers configured. The system falls back to <code class="rounded bg-gray-100 px-1">appsettings.json</code> for Mistral API credentials.</p>
                </div>
            }
            @foreach (var config in Model)
            {
                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    <div class="flex items-start justify-between border-b border-gray-200 px-6 py-4">
                        <div class="flex items-center gap-3">
                            <h2 class="text-sm font-semibold text-gray-900">@config.ProviderName</h2>
                            <span class="rounded-full px-2 py-0.5 text-xs font-medium @(config.IsEnabled ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-600")">
                                @(config.IsEnabled ? "Active" : "Disabled")
                            </span>
                        </div>
                        <div class="flex items-center gap-2">
                            <a href="@Url.Action("ConfigureModels", new { id = config.Id })" class="rounded-md border border-indigo-200 bg-white px-3 py-1.5 text-xs font-medium text-indigo-700 shadow-sm hover:bg-indigo-50">
                                Models
                            </a>
                            <a href="@Url.Action("EditProvider", new { id = config.Id })" class="rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-medium text-white shadow-sm hover:bg-indigo-700">
                                Edit
                            </a>
                            <form asp-action="DeleteProvider" asp-route-id="@config.Id" method="post" class="inline" onsubmit="return confirm('Delete provider @config.ProviderName?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="rounded-md border border-red-200 px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                    <div class="px-6 py-4">
                        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                            <div>
                                <h3 class="text-xs font-semibold uppercase text-gray-500">Base URL</h3>
                                <p class="mt-1 text-sm font-mono text-gray-700">@(string.IsNullOrWhiteSpace(config.BaseUrl) ? "—" : config.BaseUrl)</p>
                            </div>
                            <div>
                                <h3 class="text-xs font-semibold uppercase text-gray-500">API Key</h3>
                                <p class="mt-1 text-sm font-mono text-gray-700">@(string.IsNullOrWhiteSpace(config.ApiKey) ? "—" : new string('*', Math.Min(config.ApiKey.Length, 20)))</p>
                            </div>
                            <div>
                                <h3 class="text-xs font-semibold uppercase text-gray-500">Completions Model</h3>
                                <p class="mt-1 text-sm font-mono text-gray-700">@(string.IsNullOrWhiteSpace(config.CompletionsModel) ? "—" : config.CompletionsModel)</p>
                            </div>
                            <div>
                                <h3 class="text-xs font-semibold uppercase text-gray-500">Moderation Model</h3>
                                <p class="mt-1 text-sm font-mono text-gray-700">@(string.IsNullOrWhiteSpace(config.ModerationModel) ? "—" : config.ModerationModel)</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
