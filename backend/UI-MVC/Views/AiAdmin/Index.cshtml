@{
    ViewData["Title"] = "AI Management";
}

<div class="min-h-screen bg-gray-50 px-4 py-10">
    <div class="mx-auto max-w-5xl space-y-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">AI Management</h1>
            <p class="mt-1 text-sm text-gray-500">Configure AI prompts, monitor costs, and manage provider settings.</p>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <a href="@Url.Action("Prompts")" class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md">
                <h2 class="text-lg font-semibold text-gray-900">Prompts</h2>
                <p class="mt-2 text-sm text-gray-500">View and edit system and user prompt templates used for moderation, nudging, ranking, and categorization.</p>
            </a>

            <a href="@Url.Action("Providers")" class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md">
                <h2 class="text-lg font-semibold text-gray-900">Providers &amp; Models</h2>
                <p class="mt-2 text-sm text-gray-500">Switch AI providers (Mistral, Azure, Ollama, Google), configure API keys, base URLs, and select models per operation type.</p>
            </a>

            <a href="@Url.Action("Costs")" class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md">
                <h2 class="text-lg font-semibold text-gray-900">Costs &amp; Audit</h2>
                <p class="mt-2 text-sm text-gray-500">Monitor AI API usage, token consumption, and costs per model and operation type.</p>
            </a>

            <a href="@Url.Action("RateLimits")" class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md">
                <h2 class="text-lg font-semibold text-gray-900">Rate Limits</h2>
                <p class="mt-2 text-sm text-gray-500">Configure request rate limits for AI-powered endpoints. Changes apply immediately without restart.</p>
            </a>

            <a href="@Url.Action("Keywords")" class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm transition hover:border-indigo-300 hover:shadow-md">
                <h2 class="text-lg font-semibold text-gray-900">Moderation Keywords</h2>
                <p class="mt-2 text-sm text-gray-500">Manage words blocked before any API call. Saves costs by filtering unsafe content locally.</p>
            </a>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <h2 class="text-sm font-semibold text-gray-900">Connection Test</h2>
                    <p class="mt-1 text-xs text-gray-500">Probes the active AI provider (moderation + completions) and returns detailed error info.</p>
                </div>
                <a href="/api/ai/health" target="_blank" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700">
                    Run Health Check
                </a>
            </div>
        </div>
    </div>
</div>
