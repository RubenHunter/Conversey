@using Conversey.UI_MVC.Models
@using Conversey.BL.Domain.Administration
@model Conversey.UI_MVC.Models.AiAdmin.AiDashboardViewModel
@inject AdminContext AdminContext
@{
    ViewData["Title"] = "AI Settings";
    ViewData["WorkspaceName"] = "Conversey Platform";
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        ("Dashboard", "/admin/conversey", false),
        ("AI Settings", null, true)
    };
    var nlBe = System.Globalization.CultureInfo.GetCultureInfo("nl-BE");
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto">
        <div class="mb-10">
            <h1 class="text-3xl font-bold text-text tracking-tight" data-i18n="AI Settings">AI Settings</h1>
            <p class="mt-2 text-sm text-text/60" data-i18n="Configure AI providers, monitor costs, and manage prompts.">Configure AI providers, monitor costs, and manage prompts.</p>
        </div>

        <div id="health-banner" class="mb-6 hidden"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
            <div class="bg-white p-5 rounded-xl border border-secondary/10 shadow-sm">
                <span class="text-[10px] text-secondary uppercase font-bold tracking-wider block" data-i18n="Total Cost (this month)">Total Cost (this month)</span>
                <div class="text-2xl font-bold text-text mt-1">@Model.CostsSummary.TotalCost.ToString("C", nlBe)</div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-secondary/10 shadow-sm">
                <span class="text-[10px] text-secondary uppercase font-bold tracking-wider block" data-i18n="API Calls">API Calls</span>
                <div class="text-2xl font-bold text-text mt-1">@Model.CostsSummary.Models.Sum(m => m.CallCount)</div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-secondary/10 shadow-sm">
                <span class="text-[10px] text-secondary uppercase font-bold tracking-wider block" data-i18n="Providers">Providers</span>
                <div class="text-2xl font-bold text-text mt-1">@Model.TotalProviders</div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-secondary/10 shadow-sm">
                <span class="text-[10px] text-secondary uppercase font-bold tracking-wider block" data-i18n="Prompts">Prompts</span>
                <div class="text-2xl font-bold text-text mt-1">@Model.TotalPrompts</div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
            <a href="@Url.Action("Providers", new { setup = true })" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary/20 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="Setup Provider & Model">Setup Provider & Model</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="Configure AI provider, API key, and select models">Configure AI provider, API key, and select models</p>
                    </div>
                </div>
            </a>

            <a href="@Url.Action("Costs", "AiAdmin")" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary group-hover:bg-secondary/20 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="Costs & Audit">Costs & Audit</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="View AI usage, costs, and audit logs with filters">View AI usage, costs, and audit logs with filters</p>
                    </div>
                </div>
            </a>

            <a href="@Url.Action("Providers", "AiAdmin")" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary/20 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="Providers & Models">Providers & Models</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="Manage AI providers and model configurations">Manage AI providers and model configurations</p>
                    </div>
                </div>
            </a>

            <a href="@Url.Action("Prompts", "AiAdmin")" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center text-accent group-hover:bg-accent/20 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="Prompts">Prompts</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="Edit AI prompt templates with reset to default">Edit AI prompt templates with reset to default</p>
                    </div>
                </div>
            </a>

            <a href="@Url.Action("Keywords", "AiAdmin")" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600 group-hover:bg-amber-100 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="Moderation Keywords">Moderation Keywords</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="Manage flagged words for content filtering">Manage flagged words for content filtering</p>
                    </div>
                </div>
            </a>

            <a href="@Url.Action("Pricing", "AiAdmin")" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600 group-hover:bg-emerald-100 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="Model Pricing">Model Pricing</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="View today's per-model API prices per million tokens">View today's per-model API prices per million tokens</p>
                    </div>
                </div>
            </a>

            <a href="@Url.Action("RateLimits", "AiAdmin")" class="group bg-white rounded-xl border border-secondary/10 shadow-sm p-6 hover:shadow-lg hover:border-primary/30 transition-all">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-rose-50 flex items-center justify-center text-rose-600 group-hover:bg-rose-100 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-text" data-i18n="Rate Limits">Rate Limits</h3>
                        <p class="text-xs text-text/50 mt-1" data-i18n="Configure per-user or global request rate limiting for AI endpoints">Configure per-user or global request rate limiting for AI endpoints</p>
                    </div>
                </div>
            </a>
        </div>

        @if (Model.CostsSummary.Models.Any())
        {
            <div class="bg-white rounded-xl border border-secondary/10 shadow-sm">
                <div class="px-6 py-4 border-b border-secondary/10">
                    <h2 class="text-sm font-semibold text-text" data-i18n="Cost Breakdown by Model">Cost Breakdown by Model</h2>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-secondary/10 text-sm">
                        <thead class="bg-background/50">
                            <tr>
                                <th class="px-6 py-3 text-left text-[10px] font-bold uppercase text-secondary tracking-wider" data-i18n="Model">Model</th>
                                <th class="px-6 py-3 text-right text-[10px] font-bold uppercase text-secondary tracking-wider" data-i18n="Calls">Calls</th>
                                <th class="px-6 py-3 text-right text-[10px] font-bold uppercase text-secondary tracking-wider" data-i18n="Input Tokens">Input Tokens</th>
                                <th class="px-6 py-3 text-right text-[10px] font-bold uppercase text-secondary tracking-wider" data-i18n="Output Tokens">Output Tokens</th>
                                <th class="px-6 py-3 text-right text-[10px] font-bold uppercase text-secondary tracking-wider" data-i18n="Total Cost">Total Cost</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-secondary/10">
                            @foreach (var m in Model.CostsSummary.Models)
                            {
                                <tr class="hover:bg-background/30">
                                    <td class="px-6 py-3 font-mono text-xs text-text">@m.ModelName</td>
                                    <td class="px-6 py-3 text-right text-xs text-text/70">@m.CallCount</td>
                                    <td class="px-6 py-3 text-right text-xs text-text/70">@m.TotalInputTokens.ToString("N0")</td>
                                    <td class="px-6 py-3 text-right text-xs text-text/70">@m.TotalOutputTokens.ToString("N0")</td>
                                    <td class="px-6 py-3 text-right text-xs font-semibold text-text">@m.TotalCost.ToString("C", nlBe)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </main>
</div>

<script type="module" vite-src="~/components/aiAdmin/indexPage.ts"></script>
