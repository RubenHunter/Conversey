<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl border border-secondary/10 shadow-sm p-6">
        <h2 class="text-lg font-semibold text-text mb-2">Select models</h2>
        <div id="modelsStatus" class="text-xs text-text/50 mb-4">Loading models from provider...</div>

        <div class="space-y-5">
            <div>
                <div class="flex items-center gap-1.5 mb-1">
                    <label for="setupCompletionsModel" class="block text-[10px] font-bold uppercase text-secondary tracking-wider">Completions Model</label>
                    <span class="info-trigger cursor-pointer" data-info-title="Completions Model" data-info-content="The model used for text generation tasks. This powers: idea nudging (quality checks), idea ranking, idea categorization, and generating constructive alternatives for flagged content. Prefer a fast, cost-effective model like <code class=&quot;bg-background px-1 rounded text-[11px]&quot;>mistral-small-latest</code>.">
                        <svg class="w-3.5 h-3.5 text-text/30 hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></span>
                </div>
                <select id="setupCompletionsModel" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm font-mono text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                    <option value="">Loading models...</option>
                </select>
            </div>

            <div>
                <div class="flex items-center gap-1.5 mb-1">
                    <label for="setupModerationModel" class="block text-[10px] font-bold uppercase text-secondary tracking-wider">Moderation Model</label>
                    <span class="info-trigger cursor-pointer" data-info-title="Moderation Model" data-info-content="The model used for content moderation. This checks submitted ideas for harmful content before they are published. Mistral, Azure, and OpenAI provide dedicated moderation endpoints (e.g. <code class=&quot;bg-background px-1 rounded text-[11px]&quot;>mistral-moderation-latest</code>).<br><br>If you leave this empty, the completions model will be used for moderation via a prompt-based fallback — less reliable but works with any provider.">
                        <svg class="w-3.5 h-3.5 text-text/30 hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></span>
                </div>
                <select id="setupModerationModel" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm font-mono text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                    <option value="">Loading models...</option>
                </select>
            </div>

            <div>
                <div class="flex items-center gap-1.5 mb-1">
                    <label for="setupTemperature" class="block text-[10px] font-bold uppercase text-secondary tracking-wider">Temperature</label>
                    <span class="info-trigger cursor-pointer" data-info-title="Temperature" data-info-content="<strong>0</strong> = deterministic (same input → same output, best for moderation/categorization).<br><strong>1</strong> = balanced (some creativity, good for nudging questions).<br><strong>2</strong> = maximum creativity (may produce unexpected results).<br><br>Recommended: 0.1–0.2 for structured tasks like moderation and categorization.">
                        <svg class="w-3.5 h-3.5 text-text/30 hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></span>
                </div>
                <input id="setupTemperature" type="number" min="0" max="2" step="0.1" value="0.2" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50" />
            </div>
        </div>
    </div>

    <div id="infoTipPanel" class="info-tip hidden fixed right-0 top-0 bottom-0 w-80 bg-white shadow-2xl z-50 border-l border-secondary/10 overflow-y-auto" onclick="event.stopPropagation()">
        <div class="p-5">
            <div class="flex items-start justify-between mb-3">
                <h3 id="infoTipTitle" class="font-semibold text-sm"></h3>
                <button type="button" id="infoTipClose" class="text-text/40 hover:text-text"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
            </div>
            <div id="infoTipContent" class="text-xs text-text/60 leading-relaxed"></div>
        </div>
    </div>
</div>

<script>
(function() {
    var statusEl = document.getElementById('modelsStatus');
    var compSelect = document.getElementById('setupCompletionsModel');
    var modSelect = document.getElementById('setupModerationModel');

    function showError(html) {
        statusEl.innerHTML = html;
        statusEl.className = 'text-xs mb-4';
    }

    function loadModels() {
        var provider = document.getElementById('setupProvider')?.value || '';
        var baseUrl = document.getElementById('setupBaseUrl')?.value || '';
        var apiKey = document.getElementById('setupApiKey')?.value || '';

        if (!baseUrl) {
            showError('<span class="text-amber-600">Enter provider details in step 1 first.</span>');
            compSelect.innerHTML = '<option value="">No base URL</option>';
            modSelect.innerHTML = '<option value="">No base URL</option>';
            return;
        }

        statusEl.textContent = 'Testing connection to ' + provider + '...';
        statusEl.className = 'text-xs text-text/50 mb-4';

        fetch('/admin/ai/providers/test-models', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ providerName: provider, baseUrl: baseUrl, apiKey: apiKey })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) {
                var isAuth = data.error.toLowerCase().indexOf('unauthorized') !== -1
                    || data.error.toLowerCase().indexOf('401') !== -1
                    || data.error.toLowerCase().indexOf('api key') !== -1
                    || data.error.toLowerCase().indexOf('key') !== -1;
                var extra = isAuth
                    ? ' <button type="button" onclick="document.getElementById(\'prevBtn\').click()" class="underline text-primary hover:text-primary/80 font-medium text-[11px]">Go back to step 1 to fix your credentials.</button>'
                    : ' <button type="button" onclick="document.getElementById(\'prevBtn\').click()" class="underline text-text/40 hover:text-text/60 font-medium text-[11px]">Go back to step 1.</button>';
                showError('<span class="text-red-600">Connection failed: ' + data.error + '.</span><br><span class="text-text/50">Select a model from the dropdown or type one manually below.</span>' + extra);
                compSelect.innerHTML = '<option value="">Could not load from API — select below</option>';
                modSelect.innerHTML = '<option value="">None (skip moderation)</option>';
                return;
            }
            var models = data.models || [];
            statusEl.textContent = 'Found ' + models.length + ' model(s). Select from the dropdowns below.';
            statusEl.className = 'text-xs text-green-600 mb-4';

            var prevComp = compSelect.value;
            var prevMod = modSelect.value;

            compSelect.innerHTML = '<option value="">Select a model...</option>';
            modSelect.innerHTML = '<option value="">None (completions model will be used for moderation)</option>';
            models.forEach(function(m) {
                var opt1 = document.createElement('option');
                opt1.value = m;
                opt1.textContent = m;
                if (m === prevComp) opt1.selected = true;
                compSelect.appendChild(opt1);
                var opt2 = document.createElement('option');
                opt2.value = m;
                opt2.textContent = m;
                if (m === prevMod) opt2.selected = true;
                modSelect.appendChild(opt2);
            });
        })
        .catch(function(e) {
            showError('<span class="text-red-600">Connection failed: ' + e.message + '.</span><br><span class="text-text/50">Select a model from the dropdown or type one manually below.</span> <button type="button" onclick="document.getElementById(\'prevBtn\').click()" class="underline text-primary hover:text-primary/80 font-medium text-[11px]">Go back to step 1 to fix your credentials.</button>');
            compSelect.innerHTML = '<option value="">Failed — select below</option>';
            modSelect.innerHTML = '<option value="">None (skip moderation)</option>';
        });
    }

    var infoPanel = document.getElementById('infoTipPanel');
    var infoTitle = document.getElementById('infoTipTitle');
    var infoContent = document.getElementById('infoTipContent');
    var infoClose = document.getElementById('infoTipClose');
    var activeTrigger = null;

    document.querySelectorAll('.info-trigger').forEach(function(el) {
        el.addEventListener('click', function(e) {
            e.stopPropagation();
            if (activeTrigger === el) {
                infoPanel.classList.add('hidden');
                activeTrigger = null;
                return;
            }
            infoTitle.textContent = el.getAttribute('data-info-title');
            infoContent.innerHTML = el.getAttribute('data-info-content');
            infoPanel.classList.remove('hidden');
            activeTrigger = el;
        });
    });

    infoClose.addEventListener('click', function() {
        infoPanel.classList.add('hidden');
        activeTrigger = null;
    });

    document.addEventListener('stepper:step-enter', function(e) {
        if (e.detail && e.detail.step === 2) {
            loadModels();
        }
    });
})();
</script>
