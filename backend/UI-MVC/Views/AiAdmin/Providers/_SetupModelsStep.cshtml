@using Conversey.UI_MVC.Resources
@inject IAdminI18nService I18n

<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl border border-secondary/10 shadow-sm p-6">
        <h2 class="text-lg font-semibold text-text mb-2">@I18n["Select models"]</h2>
        <div id="modelsStatus" class="text-xs text-text/50 mb-4">@I18n["Loading models from provider..."]</div>

        <div class="space-y-5">
            <div>
                <div class="flex items-center gap-1.5 mb-1">
                    <label for="setupCompletionsModel" class="block text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Completions Model"]</label>
                    <span class="info-trigger cursor-pointer" data-info-title="@I18n["Completions Model"]" data-info-content="@I18n["The model used for text generation tasks."]">
                        <svg class="w-3.5 h-3.5 text-text/30 hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></span>
                </div>
                <select id="setupCompletionsModel" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm font-mono text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                    <option value="">@I18n["Loading models..."]</option>
                </select>
            </div>

            <div>
                <div class="flex items-center gap-1.5 mb-1">
                    <label for="setupModerationModel" class="block text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Moderation Model"]</label>
                    <span class="info-trigger cursor-pointer" data-info-title="@I18n["Moderation Model"]" data-info-content="@I18n["The model used for content moderation."]">
                        <svg class="w-3.5 h-3.5 text-text/30 hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></span>
                </div>
                <select id="setupModerationModel" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm font-mono text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                    <option value="">@I18n["Loading models..."]</option>
                </select>
            </div>

            <div>
                <div class="flex items-center gap-1.5 mb-1">
                    <label for="setupTemperature" class="block text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Temperature"]</label>
                    <span class="info-trigger cursor-pointer" data-info-title="@I18n["Temperature"]" data-info-content="@I18n["Controls randomness: 0 = deterministic, 2 = creative."]">
                        <svg class="w-3.5 h-3.5 text-text/30 hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></span>
                </div>
                <input id="setupTemperature" type="number" min="0" max="2" step="0.1" value="0.2" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50" />
            </div>
        </div>
    </div>

    <div id="infoTipPanel" class="info-tip hidden fixed right-0 top-0 bottom-0 w-80 bg-white shadow-2xl z-50 border-l border-secondary/10 overflow-y-auto" onclick="event.stopPropagation()">
        <div class="p-5">
            <div class="flex items-start justify-between mb-3">
                <h3 id="infoTipTitle" class="font-semibold text-sm"></h3>
                <button type="button" id="infoTipClose" class="text-text/40 hover:text-text"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
            </div>
            <div id="infoTipContent" class="text-xs text-text/60 leading-relaxed"></div>
        </div>
    </div>
</div>

<script>
var i18nEnterProviderDetailsFirst = '@I18n["Enter provider details in step 1 first."]';
var i18nNoBaseURL = '@I18n["No base URL"]';
var i18nTestingConnectionTo = '@I18n["Testing connection to"]';
var i18nConnectionFailed2 = '@I18n["Connection failed:"]';
var i18nGoBackToStep1ToFixCredentials = '@I18n["Go back to step 1 to fix your credentials."]';
var i18nGoBackToStep1 = '@I18n["Go back to step 1."]';
var i18nCouldNotLoadFromAPI = '@I18n["Could not load from API"]';
var i18nNoneSkipModeration = '@I18n["None (skip moderation)"]';
var i18nSelectAModel = '@I18n["Select a model..."]';
var i18nModelsFoundSuffix = '@I18n["model(s). Select from the dropdowns below."]';
var i18nFound = '@I18n["Found"]';

(function() {
    var statusEl = document.getElementById('modelsStatus');
    var compSelect = document.getElementById('setupCompletionsModel');
    var modSelect = document.getElementById('setupModerationModel');

    function showError(html) {
        statusEl.innerHTML = html;
        statusEl.className = 'text-xs mb-4';
    }

    function loadModels() {
        var provider = document.getElementById('setupProvider')?.value || '';
        var baseUrl = document.getElementById('setupBaseUrl')?.value || '';
        var apiKey = document.getElementById('setupApiKey')?.value || '';

        if (!baseUrl) {
            showError('<span class="text-amber-600">' + i18nEnterProviderDetailsFirst + '</span>');
            compSelect.innerHTML = '<option value="">' + i18nNoBaseURL + '</option>';
            modSelect.innerHTML = '<option value="">' + i18nNoBaseURL + '</option>';
            return;
        }

        statusEl.textContent = i18nTestingConnectionTo + ' ' + provider + '...';
        statusEl.className = 'text-xs text-text/50 mb-4';

        fetch('/admin/ai/providers/test-models', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ providerName: provider, baseUrl: baseUrl, apiKey: apiKey })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) {
                var isAuth = data.error.toLowerCase().indexOf('unauthorized') !== -1
                    || data.error.toLowerCase().indexOf('401') !== -1
                    || data.error.toLowerCase().indexOf('api key') !== -1
                    || data.error.toLowerCase().indexOf('key') !== -1;
                var extra = isAuth
                    ? ' <button type="button" onclick="document.getElementById(\'prevBtn\').click()" class="underline text-primary hover:text-primary/80 font-medium text-[11px]">' + i18nGoBackToStep1ToFixCredentials + '</button>'
                    : ' <button type="button" onclick="document.getElementById(\'prevBtn\').click()" class="underline text-text/40 hover:text-text/60 font-medium text-[11px]">' + i18nGoBackToStep1 + '</button>';
                showError('<span class="text-red-600">' + i18nConnectionFailed2 + ' ' + data.error + '.</span><br><span class="text-text/50">' + i18nSelectAModel + '</span>' + extra);
                compSelect.innerHTML = '<option value="">' + i18nCouldNotLoadFromAPI + '</option>';
                modSelect.innerHTML = '<option value="">' + i18nNoneSkipModeration + '</option>';
                return;
            }
            var models = data.models || [];
            statusEl.textContent = i18nFound + ' ' + models.length + ' ' + i18nModelsFoundSuffix;
            statusEl.className = 'text-xs text-green-600 mb-4';

            var prevComp = compSelect.value;
            var prevMod = modSelect.value;

            compSelect.innerHTML = '<option value="">' + i18nSelectAModel + '</option>';
            modSelect.innerHTML = '<option value="">' + i18nNoneSkipModeration + '</option>';
            models.forEach(function(m) {
                var opt1 = document.createElement('option');
                opt1.value = m;
                opt1.textContent = m;
                if (m === prevComp) opt1.selected = true;
                compSelect.appendChild(opt1);
                var opt2 = document.createElement('option');
                opt2.value = m;
                opt2.textContent = m;
                if (m === prevMod) opt2.selected = true;
                modSelect.appendChild(opt2);
            });
        })
        .catch(function(e) {
            showError('<span class="text-red-600">' + i18nConnectionFailed2 + ' ' + e.message + '.</span><br><span class="text-text/50">' + i18nSelectAModel + '</span> <button type="button" onclick="document.getElementById(\'prevBtn\').click()" class="underline text-primary hover:text-primary/80 font-medium text-[11px]">' + i18nGoBackToStep1ToFixCredentials + '</button>');
            compSelect.innerHTML = '<option value="">' + i18nCouldNotLoadFromAPI + '</option>';
            modSelect.innerHTML = '<option value="">' + i18nNoneSkipModeration + '</option>';
        });
    }

    var infoPanel = document.getElementById('infoTipPanel');
    var infoTitle = document.getElementById('infoTipTitle');
    var infoContent = document.getElementById('infoTipContent');
    var infoClose = document.getElementById('infoTipClose');
    var activeTrigger = null;

    document.querySelectorAll('.info-trigger').forEach(function(el) {
        el.addEventListener('click', function(e) {
            e.stopPropagation();
            if (activeTrigger === el) {
                infoPanel.classList.add('hidden');
                activeTrigger = null;
                return;
            }
            infoTitle.textContent = el.getAttribute('data-info-title');
            infoContent.innerHTML = el.getAttribute('data-info-content');
            infoPanel.classList.remove('hidden');
            activeTrigger = el;
        });
    });

    infoClose.addEventListener('click', function() {
        infoPanel.classList.add('hidden');
        activeTrigger = null;
    });

    document.addEventListener('stepper:step-enter', function(e) {
        if (e.detail && e.detail.step === 2) {
            loadModels();
        }
    });
})();
</script>
