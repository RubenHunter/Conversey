@using Conversey.UI_MVC.Models
@using Conversey.UI_MVC.Models.Admin
@using Conversey.UI_MVC.Models.AiAdmin
@using Conversey.BL.Domain.Administration
@inject AdminContext AdminContext
@{
    ViewData["Title"] = "Setup New Provider";
    ViewData["WorkspaceName"] = "Conversey Platform";
    ViewData["Breadcrumbs"] = new (string Label, string Url, bool IsCurrent)[]
    {
        ("Dashboard", "/admin", false),
        ("AI Settings", "/admin/ai", false),
        ("Providers", "/admin/ai/providers", false),
        ("Setup New Provider", null, true)
    };

    var steps = new List<StepItem>
    {
        new() { Label = "Provider", PartialViewName = "Providers/_SetupProviderStep" },
        new() { Label = "Models", PartialViewName = "Providers/_SetupModelsStep" },
        new() { Label = "Verify", PartialViewName = "Providers/_SetupVerifyStep" }
    };
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")
    @Html.AntiForgeryToken()

    <div id="dynamic-stepper" class="w-full max-w-5xl mx-auto p-6 text-text" data-total-steps="@steps.Count" data-entity="Provider">
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-12 gap-4">
            <h1 class="text-4xl font-bold tracking-tight" data-i18n="Setup New Provider">Setup New Provider</h1>
            <div class="flex gap-2">
                <button id="prevBtn" type="button" class="hidden px-8 py-2 border border-text rounded-lg hover:bg-text/5 transition-all">
                    <span style="display:none" data-i18n="Previous">Previous</span><span data-i18n="< Back">< Back</span>
                </button>
                <button id="nextBtn" type="button" class="px-8 py-2 bg-text text-background rounded-lg hover:opacity-90 transition-all">
                    <span data-i18n="Continue">Continue</span> <span style="display:none" data-i18n="Finish Setup">Finish Setup</span>
                </button>
            </div>
        </div>

        <div class="relative flex justify-between items-start mb-16 px-8">
            <div class="absolute top-3.5 h-0.5 z-0">
                <div class="absolute inset-0 border-t-2 border-dotted border-text/20"></div>
                <div id="progress-line" class="absolute inset-y-0 left-0 bg-primary transition-all duration-500 ease-in-out" style="width: 0%; height: 2px;"></div>
            </div>
            @for (int i = 0; i < steps.Count; i++)
            {
                var stepNum = i + 1;
                <div class="step-indicator flex flex-col items-center flex-1" data-step="@stepNum">
                    <div class="step-circle z-10 w-7 h-7 rounded-full border-2 border-text bg-background flex items-center justify-center transition-all duration-300">
                        <div class="step-dot w-2 h-2 rounded-full bg-text scale-0 transition-transform duration-300"></div>
                    </div>
                    <span class="mt-4 text-xs uppercase text-text/50 font-medium"><span data-i18n="step">step</span> @stepNum</span>
                    <span class="text-sm font-bold text-center">@steps[i].Label</span>
                </div>
            }
        </div>

        <div class="step-content-container relative overflow-visible min-h-75">
            @for (int i = 0; i < steps.Count; i++)
            {
                <div id="step-content-@(i+1)" class="step-pane hidden animate-in fade-in slide-in-from-right-4 duration-500">
                    @await Html.PartialAsync(steps[i].PartialViewName)
                </div>
            }
        </div>
    </div>
</div>

<script>
(function() {
    var STORAGE_KEY = 'conversey-ai-provider-setup-state-v1';
    var STORAGE_VERSION = 1;
    var fieldDefaults = {
        setupProvider: '',
        setupBaseUrl: '',
        setupApiKey: '',
        setupKeyExpiry: '',
        setupCompletionsModel: '',
        setupModerationModel: '',
        setupTemperature: '0.2'
    };
    var fieldIds = Object.keys(fieldDefaults);

    function readState() {
        try {
            var raw = localStorage.getItem(STORAGE_KEY);
            if (!raw) return null;
            var parsed = JSON.parse(raw);
            if (!parsed || parsed.version !== STORAGE_VERSION || typeof parsed !== 'object') return null;
            return parsed;
        } catch {
            return null;
        }
    }

    function writeState(nextState) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(nextState));
    }

    function getCurrentFieldValues() {
        var values = {};
        fieldIds.forEach(function(id) {
            var el = document.getElementById(id);
            values[id] = el ? (el.value || '') : fieldDefaults[id];
        });
        return values;
    }

    function saveFields() {
        var state = readState() || { version: STORAGE_VERSION, currentStep: 1, fields: {} };
        state.version = STORAGE_VERSION;
        state.fields = getCurrentFieldValues();
        writeState(state);
    }

    function restoreFields() {
        var state = readState();
        var fields = state && state.fields && typeof state.fields === 'object' ? state.fields : null;

        fieldIds.forEach(function(id) {
            var el = document.getElementById(id);
            if (!el) return;
            var desired = fields && Object.prototype.hasOwnProperty.call(fields, id)
                ? (fields[id] || '')
                : fieldDefaults[id];
            // If this is a select (models), and the desired value is not present in options,
            // create a temporary option so the select reports the restored value (used by step 3 health check).
            if (el.tagName === 'SELECT') {
                var sel = el;
                // Try to set value first
                sel.value = desired;
                if (desired && sel.value !== desired) {
                    // No matching option exists — add a temporary one and select it
                    try {
                        var opt = document.createElement('option');
                        opt.value = desired;
                        opt.textContent = desired + ' (restored)';
                        opt.setAttribute('data-restored', '1');
                        sel.appendChild(opt);
                        sel.value = desired;
                    } catch (e) {
                        // ignore DOM errors
                    }
                }
            } else {
                el.value = desired;
            }
        });
    }

    function getCurrentStep() {
        var state = readState();
        return state && typeof state.currentStep === 'number' ? state.currentStep : 1;
    }

    function setCurrentStep(step) {
        var state = readState() || { version: STORAGE_VERSION, currentStep: 1, fields: getCurrentFieldValues() };
        state.version = STORAGE_VERSION;
        state.currentStep = step;
        if (!state.fields) {
            state.fields = getCurrentFieldValues();
        }
        writeState(state);
    }

    function clearState() {
        localStorage.removeItem(STORAGE_KEY);
    }

    window.__ProviderSetupState = {
        saveFields: saveFields,
        restoreFields: restoreFields,
        getCurrentStep: getCurrentStep,
        setCurrentStep: setCurrentStep,
        clear: clearState,
        storageKey: STORAGE_KEY
    };

    document.addEventListener('DOMContentLoaded', function() {
        restoreFields();

        fieldIds.forEach(function(id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.addEventListener('input', saveFields);
            el.addEventListener('change', saveFields);
        });

        window.addEventListener('pageshow', function(event) {
            restoreFields();

            if (event && event.persisted && !readState()) {
                document.dispatchEvent(new CustomEvent('provider-setup:reset'));
            }
        });
    });
})();
</script>

<script type="module" vite-src="~/components/shared/universalStepper.ts"></script>
