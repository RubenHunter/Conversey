@using Conversey.UI_MVC.Models
@using Conversey.UI_MVC.Resources
@using Conversey.BL.Domain.Administration
@using System.Text.Json
@model Conversey.UI_MVC.Models.AiAdmin.AiCostsViewModel
@inject AdminContext AdminContext
@inject IAdminI18nService I18n
@{
    ViewData["Title"] = I18n["AI Costs & Audit"];
    ViewData["WorkspaceName"] = "Conversey Platform";
    ViewData["Breadcrumbs"] = new (string Label, string? Url, bool IsCurrent)[]
    {
        (I18n["Dashboard"], "/admin", false),
        (I18n["AI Settings"], "/admin/ai", false),
        (I18n["Costs & Audit"], null, true)
    };
    var nlBe = System.Globalization.CultureInfo.GetCultureInfo("nl-BE");
    var timelineData = Model.Timeline.DailyCosts.Select(d => new { date = d.Date.ToString("yyyy-MM-dd"), cost = Math.Round((double)d.Cost, 4), calls = d.CallCount }).ToList();
    var auditData = Model.AuditLogs.Select(l => new { date = l.StartTime.ToLocalTime().ToString("yyyy-MM-dd"), model = l.ModelName ?? "", cost = Math.Round((double)l.Cost, 6) }).ToList();
}

<div class="min-h-screen bg-background font-sans text-text">
    @await Html.PartialAsync("_AdminHeader")

    <main class="p-8 w-full max-w-400 mx-auto">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-text tracking-tight">@I18n["Costs & Audit"]</h1>
                <p class="mt-1 text-sm text-text/60">@I18n["AI API usage, token consumption, and costs."]</p>
            </div>
            <a href="@Url.Action("Index")" class="text-sm text-primary hover:text-primary/80 transition-colors flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                @I18n["Back to Dashboard"]
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-white p-5 rounded-xl border border-secondary/10 shadow-sm">
                <span class="text-[10px] text-secondary uppercase font-bold tracking-wider block">@I18n["Total Cost"]</span>
                <div class="text-2xl font-bold text-text mt-1">@Model.Summary.TotalCost.ToString("C", nlBe)</div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-secondary/10 shadow-sm">
                <span class="text-[10px] text-secondary uppercase font-bold tracking-wider block">@I18n["Total Calls"]</span>
                <div class="text-2xl font-bold text-text mt-1">@Model.Timeline.TotalCalls</div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-secondary/10 shadow-sm">
                <span class="text-[10px] text-secondary uppercase font-bold tracking-wider block">@I18n["Input Tokens"]</span>
                <div class="text-2xl font-bold text-text mt-1">@Model.Timeline.DailyCosts.Sum(d => d.InputTokens).ToString("N0")</div>
            </div>
            <div class="bg-white p-5 rounded-xl border border-secondary/10 shadow-sm">
                <span class="text-[10px] text-secondary uppercase font-bold tracking-wider block">@I18n["Output Tokens"]</span>
                <div class="text-2xl font-bold text-text mt-1">@Model.Timeline.DailyCosts.Sum(d => d.OutputTokens).ToString("N0")</div>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-secondary/10 shadow-sm mb-8 p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-sm font-semibold text-text">@I18n["Cost Overview"]</h2>
                <div class="flex bg-secondary/5 rounded-lg p-1 gap-0.5">
                    <button class="chart-toggle px-3 py-1 text-xs font-medium rounded-md transition-colors bg-white text-text shadow-sm" data-type="line">@I18n["Line"]</button>
                    <button class="chart-toggle px-3 py-1 text-xs font-medium rounded-md transition-colors text-text/50 hover:text-text" data-type="bar">@I18n["Bar"]</button>
                    <button class="chart-toggle px-3 py-1 text-xs font-medium rounded-md transition-colors text-text/50 hover:text-text" data-type="pie">@I18n["Pie"]</button>
                </div>
            </div>
            <div class="w-full h-72"><canvas id="cost-timeline-chart"></canvas></div>
        </div>

        <div class="bg-white rounded-xl border border-secondary/10 shadow-sm mb-8">
            <div class="px-6 py-4 border-b border-secondary/10">
                <h2 class="text-sm font-semibold text-text">@I18n["Filters"]</h2>
            </div>
            <form method="get" asp-action="Costs" class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-secondary tracking-wider mb-1">@I18n["Workspace"]</label>
                        <select name="Filter.WorkspaceId" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <option value="">@I18n["All workspaces"]</option>
                            @foreach (var ws in Model.Workspaces)
                            {
                                <option value="@ws" selected="@(Model.Filter.WorkspaceId == ws)">@ws</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-secondary tracking-wider mb-1">@I18n["Model"]</label>
                        <select name="Filter.ModelName" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <option value="">@I18n["All models"]</option>
                            @foreach (var m in Model.Models)
                            {
                                <option value="@m" selected="@(Model.Filter.ModelName == m)">@m</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-secondary tracking-wider mb-1">@I18n["Type"]</label>
                        <select name="Filter.ModelType" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <option value="">@I18n["All types"]</option>
                            @foreach (var t in Model.ModelTypes)
                            {
                                <option value="@t" selected="@(Model.Filter.ModelType == t)">@t</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-secondary tracking-wider mb-1">@I18n["Provider"]</label>
                        <select name="Filter.ProviderName" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <option value="">@I18n["All providers"]</option>
                            @foreach (var p in Model.Providers)
                            {
                                <option value="@p" selected="@(Model.Filter.ProviderName == p)">@p</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-secondary tracking-wider mb-1">@I18n["Prompt"]</label>
                        <select name="Filter.PromptName" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                            <option value="">@I18n["All prompts"]</option>
                            @foreach (var p in Model.Prompts)
                            {
                                <option value="@p" selected="@(Model.Filter.PromptName == p)">@p</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-secondary tracking-wider mb-1">@I18n["Date From"]</label>
                        <input type="date" name="Filter.DateFrom" value="@(Model.Filter.DateFrom?.ToString("yyyy-MM-dd"))" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-secondary tracking-wider mb-1">@I18n["Date To"]</label>
                        <input type="date" name="Filter.DateTo" value="@(Model.Filter.DateTo?.ToString("yyyy-MM-dd"))" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50" />
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase text-secondary tracking-wider mb-1">@I18n["Timeline Days"]</label>
                        <select name="Filter.TimelineDays" class="w-full rounded-lg border border-secondary/20 bg-white px-3 py-2 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary/50">
                            @foreach (var days in new[] { 7, 14, 30, 60, 90 })
                            {
                                <option value="@days" selected="@(Model.Filter.TimelineDays == days)">@days @I18n["days"]</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="mt-4 flex gap-3">
                    <button type="submit" class="px-6 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors text-sm font-medium">@I18n["Apply Filters"]</button>
                    <a href="@Url.Action("Costs")" class="px-6 py-2 border border-secondary/20 rounded-lg hover:bg-background transition-colors text-sm font-medium text-text/70">@I18n["Clear"]</a>
                </div>
            </form>
        </div>

        <div class="bg-white rounded-xl border border-secondary/10 shadow-sm">
            <div class="px-6 py-4 border-b border-secondary/10 flex items-center justify-between">
                <h2 class="text-sm font-semibold text-text">@I18n["Audit Log"] (@Model.AuditLogs.Count @I18n["entries"])</h2>
            </div>
            <div class="costs-audit-table max-[1500px]:overflow-x-auto">
                <table class="w-full table-fixed divide-y divide-secondary/10 text-xs min-w-[1000px]">
                    <colgroup>
                        <col style="width:8%"><col style="width:12%"><col style="width:14%">
                        <col style="width:14%"><col style="width:8%"><col style="width:16%">
                        <col style="width:6%"><col style="width:6%"><col style="width:8%"><col style="width:8%">
                    </colgroup>
                    <thead class="bg-background/50">
                        <tr>
                            <th class="px-2 py-2 text-left text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Time"]</th>
                            <th class="px-2 py-2 text-left text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Workspace"]</th>
                            <th class="px-2 py-2 text-left text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Project"]</th>
                            <th class="px-2 py-2 text-left text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Model"]</th>
                            <th class="px-2 py-2 text-left text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Type"]</th>
                            <th class="px-2 py-2 text-left text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Prompt"]</th>
                            <th class="px-2 py-2 text-right text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["In"]</th>
                            <th class="px-2 py-2 text-right text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Out"]</th>
                            <th class="px-2 py-2 text-right text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Cost"]</th>
                            <th class="px-2 py-2 text-right text-[10px] font-bold uppercase text-secondary tracking-wider">@I18n["Dur."]</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-secondary/10">
                        @if (!Model.AuditLogs.Any())
                        {
                            <tr><td colspan="10" class="px-6 py-8 text-center text-sm text-text/50">@I18n["No AI calls recorded."]</td></tr>
                        }
                        else
                        {
                            @foreach (var log in Model.AuditLogs)
                            {
                                <tr class="hover:bg-background/30">
                                    <td class="px-2 py-2 text-xs text-text/70">@log.StartTime.ToLocalTime().ToString("MM-dd HH:mm")</td>
                                    <td class="px-2 py-2 text-xs text-text/70"><span class="block truncate" title="@log.WorkspaceId">@log.WorkspaceId</span></td>
                                    <td class="px-2 py-2 text-xs text-text/70"><span class="block truncate" title="@log.ProjectId">@log.ProjectId</span></td>
                                    <td class="px-2 py-2 font-mono text-xs text-text"><span class="block truncate" title="@log.ModelName">@log.ModelName</span></td>
                                    <td class="px-2 py-2 text-xs text-text/60">@log.ModelType</td>
                                    <td class="px-2 py-2 text-xs text-text/60"><span class="block truncate" title="@log.PromptName">@log.PromptName</span></td>
                                    <td class="px-2 py-2 text-right text-xs text-text/60">@log.InputTokens.ToString("N0")</td>
                                    <td class="px-2 py-2 text-right text-xs text-text/60">@log.OutputTokens.ToString("N0")</td>
                                    <td class="px-2 py-2 text-right text-xs font-semibold text-text">@log.Cost.ToString("C", nlBe)</td>
                                    <td class="px-2 py-2 text-right text-xs text-text/60">@(log.Duration.TotalSeconds < 1 ? I18n["< 1s"] : $"{log.Duration.TotalSeconds:F1}s")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script type="application/json" id="cost-chart-data">@Html.Raw(JsonSerializer.Serialize(new { timeline = timelineData, audit = auditData, timelineDays = Model.Filter.TimelineDays }))</script>
<script type="module" vite-src="~/components/shared/costCharts.ts"></script>
