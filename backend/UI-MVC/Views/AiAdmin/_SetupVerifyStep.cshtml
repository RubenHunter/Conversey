<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl border border-secondary/10 shadow-sm p-6">
        <h2 class="text-lg font-semibold text-text mb-4">Verify &amp; Save</h2>

        <div id="healthCheckBar" class="rounded-lg p-3 mb-4 text-xs hidden">
        </div>

        <div id="setupSummary" class="space-y-3 mb-6 text-sm">
            <p class="text-text/60">Fill in the previous steps to see a summary here.</p>
        </div>

        <div class="flex gap-3">
            <button id="saveProviderBtn" type="button" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors text-sm font-medium flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Save Provider
            </button>
        </div>
    </div>
</div>

<script>
(function() {
    function getVal(id) { var el = document.getElementById(id); return el ? el.value || '' : ''; }

    function updateSummary() {
        var provider = getVal('setupProvider');
        var baseUrl = getVal('setupBaseUrl');
        var apiKey = getVal('setupApiKey');
        var compModel = getVal('setupCompletionsModel');
        var modModel = getVal('setupModerationModel');
        var temp = getVal('setupTemperature');

        var badge = function(text, color) {
            return '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium ' + color + '">' + text + '</span>';
        };

        var html = '';
        if (provider) html += '<div class="flex justify-between items-center py-2 border-b border-secondary/5"><span class="text-text/50 text-xs">Provider name</span><span class="font-medium text-text">' + provider + '</span></div>';
        if (baseUrl) html += '<div class="flex justify-between items-center py-2 border-b border-secondary/5"><span class="text-text/50 text-xs">Base URL</span><span class="font-mono text-[11px] text-text break-all max-w-[60%] text-right">' + baseUrl + '</span></div>';
        html += '<div class="flex justify-between items-center py-2 border-b border-secondary/5"><span class="text-text/50 text-xs">API Key</span><span class="font-mono text-[11px] text-text">' + (apiKey ? apiKey.substring(0, 8) + '...' : '<span class="text-amber-600">Not set</span>') + '</span></div>';
        html += '<div class="flex justify-between items-center py-2 border-b border-secondary/5"><span class="text-text/50 text-xs">Completions model</span><span class="font-mono text-[11px] text-text">' + (compModel || '<span class="text-red-500">Not selected</span>') + '</span></div>';
        if (modModel) {
            html += '<div class="flex justify-between items-center py-2 border-b border-secondary/5"><span class="text-text/50 text-xs">Moderation model</span><span class="font-mono text-[11px] text-text">' + modModel + '</span></div>';
        } else {
            html += '<div class="flex justify-between items-center py-2 border-b border-secondary/5"><span class="text-text/50 text-xs">Moderation model</span><span class="text-[11px] text-text/40">' + badge('prompt fallback', 'bg-amber-50 text-amber-700') + ' <span class="text-text/40">Completions model will be used for moderation via prompt.</span></span></div>';
        }
        html += '<div class="flex justify-between items-center py-2"><span class="text-text/50 text-xs">Temperature</span><span class="text-text">' + (temp || '0.2') + '</span></div>';

        document.getElementById('setupSummary').innerHTML = html || '<p class="text-text/60">Fill in the previous steps to see a summary here.</p>';
    }

    function runHealthCheck() {
        var bar = document.getElementById('healthCheckBar');
        var provider = getVal('setupProvider');
        var baseUrl = getVal('setupBaseUrl');
        var apiKey = getVal('setupApiKey');

        if (!baseUrl) {
            bar.className = 'rounded-lg p-3 mb-4 text-xs bg-amber-50 text-amber-700 border border-amber-200 hidden';
            return;
        }

        bar.className = 'rounded-lg p-3 mb-4 text-xs bg-secondary/5 text-text/50 border border-secondary/10';
        bar.innerHTML = '<span class="flex items-center gap-2"><svg class="w-3.5 h-3.5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Checking provider connection...</span>';

        fetch('/admin/ai/providers/test-models', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ providerName: provider, baseUrl: baseUrl, apiKey: apiKey })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) {
                bar.className = 'rounded-lg p-3 mb-4 text-xs bg-red-50 text-red-700 border border-red-200';
                bar.innerHTML = '<span class="flex items-center gap-2"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Connection failed:</strong> ' + data.error + ' <button type="button" onclick="document.getElementById(\'prevBtn\').click()" class="underline ml-1 font-medium">Go back to step 1</button></span>';
            } else {
                var models = data.models || [];
                bar.className = 'rounded-lg p-3 mb-4 text-xs bg-green-50 text-green-700 border border-green-200';
                bar.innerHTML = '<span class="flex items-center gap-2"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Connection OK.</strong> Provider is reachable, ' + models.length + ' model(s) available.</span>';
            }
        })
        .catch(function(e) {
            bar.className = 'rounded-lg p-3 mb-4 text-xs bg-red-50 text-red-700 border border-red-200';
            bar.innerHTML = '<span class="flex items-center gap-2"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Connection failed:</strong> ' + e.message + ' <button type="button" onclick="document.getElementById(\'prevBtn\').click()" class="underline ml-1 font-medium">Go back to step 1</button></span>';
        });
    }

    document.querySelectorAll('#setupProvider, #setupBaseUrl, #setupApiKey, #setupCompletionsModel, #setupModerationModel, #setupTemperature').forEach(function(el) {
        el.addEventListener('input', updateSummary);
        el.addEventListener('change', updateSummary);
    });
    updateSummary();

    document.addEventListener('stepper:step-enter', function(e) {
        if (e.detail && e.detail.step === 3) {
            runHealthCheck();
        }
    });

    document.getElementById('saveProviderBtn').addEventListener('click', function() {
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/ai/providers';

        var compModel = getVal('setupCompletionsModel');
        var modModel = getVal('setupModerationModel');

        var fields = {
            ProviderName: getVal('setupProvider'),
            BaseUrl: getVal('setupBaseUrl'),
            ApiKey: getVal('setupApiKey'),
            CompletionsModel: compModel,
            ModerationModel: modModel,
            Temperature: getVal('setupTemperature') || '0.2',
            IsEnabled: 'true'
        };

        var expiry = getVal('setupKeyExpiry');
        if (expiry) fields.ApiKeyExpiresAt = expiry;

        for (var key in fields) {
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = key;
            input.value = fields[key];
            form.appendChild(input);
        }

        var token = document.querySelector('input[name="__RequestVerificationToken"]');
        if (token) {
            var tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = token.value;
            form.appendChild(tokenInput);
        }

        document.body.appendChild(form);
        form.submit();
    });
})();
</script>
