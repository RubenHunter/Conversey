@model IReadOnlyList<Conversey.BL.Domain.Ai.ModerationKeyword>
@{
    ViewData["Title"] = "Moderation Keywords";
}

<div class="min-h-screen bg-gray-50 px-4 py-10">
    <div class="mx-auto max-w-5xl">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Moderation Keywords</h1>
                <p class="mt-1 text-sm text-gray-500">
                    Words filtered before any AI API call — saves costs by blocking known unsafe terms locally.
                </p>
            </div>
            <a href="@Url.Action("Index")" class="text-sm text-indigo-600 hover:text-indigo-700">&larr; Back to AI Management</a>
        </div>

        <div class="mt-6 rounded-lg border border-green-200 bg-green-50 p-4">
            <div class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                <div>
                    <h3 class="text-sm font-semibold text-green-800">Cost savings</h3>
                    <p class="mt-1 text-sm text-green-700">
                        Each keyword match avoids a moderation API call, saving ~&euro;0.0001 per request.
                        Keywords are checked case-insensitively against the full content text (substring match).
                        Changes take effect immediately — no restart required.
                    </p>
                </div>
            </div>
        </div>

        <div class="mt-6 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
            <h2 class="text-sm font-semibold text-gray-900">Add keyword</h2>
            <form asp-action="CreateKeyword" method="post" class="mt-3 flex items-end gap-3">
                @Html.AntiForgeryToken()
                <div class="flex-1">
                    <label for="keywordInput" class="block text-xs font-medium text-gray-600">Keyword (lowercase, single word or phrase)</label>
                    <input id="keywordInput" name="Keyword" type="text" maxlength="200" required
                           class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
                           placeholder="e.g. offensive term" />
                </div>
                <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700">
                    Add
                </button>
            </form>
        </div>

        <div class="mt-6">
            @if (Model.Count == 0)
            {
                <p class="text-sm text-gray-500">No keywords configured. Add one to enable client-side filtering.</p>
            }
            else
            {
                <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Keyword</th>
                                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500">Added</th>
                                <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var keyword in Model)
                            {
                                <tr>
                                    <td class="whitespace-nowrap px-6 py-3 text-sm font-medium text-gray-900">@keyword.Keyword</td>
                                    <td class="whitespace-nowrap px-6 py-3 text-sm text-gray-500">@keyword.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td class="whitespace-nowrap px-6 py-3 text-right">
                                        <form asp-action="DeleteKeyword" asp-route-id="@keyword.Id" method="post" class="inline" onsubmit="return confirm('Delete keyword \'@keyword.Keyword\'?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-xs text-red-600 hover:text-red-800">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
