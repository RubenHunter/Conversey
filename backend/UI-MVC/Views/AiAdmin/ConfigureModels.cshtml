@model Conversey.BL.Domain.Ai.AiProviderConfig
@{
    ViewData["Title"] = $"Configure Models: {Model.ProviderName}";
    var availableModels = ViewBag.AvailableModels as IReadOnlyList<string> ?? Array.Empty<string>();
    var fetchError = ViewBag.FetchError as string;
    var hasModels = availableModels.Count > 0;
}

<div class="min-h-screen bg-gray-50 px-4 py-10">
    <div class="mx-auto max-w-5xl">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Configure Models: @Model.ProviderName</h1>
                <p class="mt-1 text-sm text-gray-500">Select which models to use for AI operations. Models are fetched from the provider's API.</p>
            </div>
            <a href="@Url.Action("Providers")" class="text-sm text-indigo-600 hover:text-indigo-700">&larr; Back to Providers</a>
        </div>

        <div class="mt-6 space-y-6">
            <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                <div class="border-b border-gray-200 px-6 py-4">
                    <h2 class="text-sm font-semibold text-gray-900">Provider Connection</h2>
                </div>
                <div class="px-6 py-4">
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                        <div>
                            <h3 class="text-xs font-semibold uppercase text-gray-500">Base URL</h3>
                            <p class="mt-1 text-sm font-mono text-gray-700">@(string.IsNullOrWhiteSpace(Model.BaseUrl) ? "—" : Model.BaseUrl)</p>
                        </div>
                        <div>
                            <h3 class="text-xs font-semibold uppercase text-gray-500">API Key</h3>
                            <p class="mt-1 text-sm font-mono text-gray-700">@(string.IsNullOrWhiteSpace(Model.ApiKey) ? "—" : new string('*', Math.Min(Model.ApiKey.Length, 20)))</p>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a href="@Url.Action("EditProvider", new { id = Model.Id })" class="text-sm text-indigo-600 hover:text-indigo-700">Edit connection settings</a>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(fetchError))
            {
                <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 shadow-sm">
                    <p class="text-sm font-medium text-amber-800">Could not fetch models from provider API.</p>
                    <p class="mt-1 text-xs text-amber-600">@fetchError</p>
                    <p class="mt-1 text-xs text-amber-600">You can still enter model names manually below.</p>
                </div>
            }

            @if (hasModels)
            {
                <div class="rounded-lg border border-green-200 bg-green-50 p-4 shadow-sm">
                    <p class="text-sm font-medium text-green-800">@availableModels.Count model(s) found.</p>
                    <p class="mt-1 text-xs text-green-600">Select from the dropdowns below, or type a model name manually.</p>
                </div>
            }

            <form asp-action="ConfigureModels" asp-route-id="@Model.Id" method="post" class="space-y-6">
                @Html.AntiForgeryToken()

                <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
                    <div class="border-b border-gray-200 px-6 py-4">
                        <h2 class="text-sm font-semibold text-gray-900">Model Selection</h2>
                    </div>
                    <div class="px-6 py-4 space-y-4">
                        <div>
                            <label asp-for="CompletionsModel" class="block text-xs font-semibold uppercase text-gray-500">Completions Model</label>
                            <div class="mt-1 flex gap-2">
                                @if (hasModels)
                                {
                                    <select asp-for="CompletionsModel" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                                        <option value="">— select or type manually —</option>
                                        @foreach (var m in availableModels)
                                        {
                                            var selected = string.Equals(m, Model.CompletionsModel, StringComparison.OrdinalIgnoreCase);
                                            <option value="@m" selected="@selected">@m</option>
                                        }
                                    </select>
                                }
                                <input asp-for="CompletionsModel" type="text" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 @(hasModels ? "hidden" : "")" placeholder="mistral-small-latest" list="completions-datalist" />
                                @if (hasModels)
                                {
                                    <datalist id="completions-datalist">
                                        @foreach (var m in availableModels)
                                        {
                                            <option value="@m" />
                                        }
                                    </datalist>
                                }
                            </div>
                            <p class="mt-1 text-xs text-gray-400">Used for: idea nudging, ranking, categorization, alternative generation.</p>
                        </div>

                        <div>
                            <label asp-for="ModerationModel" class="block text-xs font-semibold uppercase text-gray-500">Moderation Model</label>
                            <div class="mt-1 flex gap-2">
                                @if (hasModels)
                                {
                                    <select asp-for="ModerationModel" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                                        <option value="">— none (skip moderation) —</option>
                                        @foreach (var m in availableModels)
                                        {
                                            var selected = string.Equals(m, Model.ModerationModel, StringComparison.OrdinalIgnoreCase);
                                            <option value="@m" selected="@selected">@m</option>
                                        }
                                    </select>
                                }
                                <input asp-for="ModerationModel" type="text" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 @(hasModels ? "hidden" : "")" placeholder="mistral-moderation-latest" list="moderation-datalist" />
                                @if (hasModels)
                                {
                                    <datalist id="moderation-datalist">
                                        @foreach (var m in availableModels)
                                        {
                                            <option value="@m" />
                                        }
                                    </datalist>
                                }
                            </div>
                            <p class="mt-1 text-xs text-gray-400">Used for: content moderation. Leave empty if provider has no dedicated moderation endpoint.</p>
                        </div>

                        <div>
                            <label asp-for="Temperature" class="block text-xs font-semibold uppercase text-gray-500">Temperature</label>
                            <input asp-for="Temperature" type="number" min="0" max="2" step="0.1" class="mt-1 w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" placeholder="1.0" />
                            <p class="mt-1 text-xs text-gray-400">0 = deterministic, 1 = balanced, 2 = creative. Mistral models work well at 0.1-0.2 for structured tasks.</p>
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end gap-3">
                    <a href="@Url.Action("Providers")" class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                        Skip (save later)
                    </a>
                    <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700">
                        Save Models
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
