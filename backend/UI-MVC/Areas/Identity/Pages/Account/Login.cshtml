@page
@using Conversey.UI_MVC.Models
@model LoginModel
@inject WorkspaceContext WorkspaceContext

@{
    ViewData["Title"] = "Log in";
    var workspaceName = WorkspaceContext.CurrentWorkspace?.Name ?? "Conversey Portal";
}

<div class="min-h-screen flex items-center justify-center px-4 py-12 bg-cover bg-center bg-no-repeat relative overflow-hidden" 
     style="background-image: url('/Assets/login_bg.png');">
    
    <!-- Subtle Overlay for contrast -->
    <div class="absolute inset-0 bg-black/10 backdrop-blur-[2px]"></div>

    <div class="w-full max-w-md relative z-10">
        <!-- Logo / Brand Header -->
        <div class="text-center mb-10 animate-fade-in">
            <div class="inline-flex items-center justify-center p-3 mb-4 bg-white/20 backdrop-blur-md rounded-2xl shadow-xl border border-white/30">
                <span class="text-2xl font-black text-white tracking-tighter">CONVERSEY</span>
            </div>
            <h1 class="text-4xl font-extrabold text-white tracking-tight drop-shadow-lg">
                @ViewData["Title"]
            </h1>
            <p class="text-white/80 mt-2 font-medium">@workspaceName</p>
        </div>

        <!-- Login Card with Glassmorphism -->
        <section class="bg-white/70 backdrop-blur-xl rounded-3xl shadow-2xl p-8 border border-white/40 transform transition-all hover:scale-[1.01]">
            <form id="account" method="post" class="space-y-6">
                <div class="text-center mb-6">
                    <h2 class="text-xl font-bold text-gray-800">Welkom terug</h2>
                    <p class="text-sm text-gray-500">Voer je gegevens in om toegang te krijgen</p>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-red-600 bg-red-100/80 p-4 rounded-xl text-sm border border-red-200" role="alert"></div>

                <div>
                    <label asp-for="Input.Email" class="block text-xs font-bold text-gray-600 uppercase tracking-wider mb-2 ml-1">E-mailadres</label>
                    <div class="relative group">
                        <input asp-for="Input.Email" 
                               class="block w-full px-4 py-3 bg-white/50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white outline-none transition-all duration-200" 
                               autocomplete="username" aria-required="true" placeholder="naam@voorbeeld.be" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-2 ml-1 block"></span>
                </div>

                <div>
                    <label asp-for="Input.Password" class="block text-xs font-bold text-gray-600 uppercase tracking-wider mb-2 ml-1">Wachtwoord</label>
                    <div class="relative">
                        <input asp-for="Input.Password" 
                               class="block w-full px-4 py-3 bg-white/50 border border-gray-200 rounded-xl focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white outline-none transition-all duration-200" 
                               autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-2 ml-1 block"></span>
                </div>

                <div class="flex items-center justify-between px-1">
                    <div class="flex items-center">
                        <input class="w-4 h-4 text-blue-600 rounded-lg border-gray-300 focus:ring-blue-500 cursor-pointer" type="checkbox" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="ml-2 text-sm text-gray-600 cursor-pointer select-none">
                            Onthoud mij
                        </label>
                    </div>
                    <a href="#" class="text-sm font-semibold text-blue-600 hover:text-blue-700 transition-colors">Wachtwoord vergeten?</a>
                </div>

                <div class="pt-2">
                    <button id="login-submit" type="submit" 
                            class="w-full px-6 py-3.5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-blue-500/30 hover:shadow-blue-500/50 hover:from-blue-700 hover:to-indigo-700 active:scale-[0.98] transition-all duration-200">
                        Inloggen
                    </button>
                </div>
            </form>
        </section>

        <!-- Footer -->
        <div class="text-center mt-8">
            <p class="text-white/60 text-sm">
                &copy; @DateTime.Now.Year Conversey. Alle rechten voorbehouden.
            </p>
        </div>
    </div>
</div>

<style>
    @@keyframes fade-in {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
        animation: fade-in 0.8s ease-out forwards;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
