@page
@using Conversey.UI_MVC.Models
@model LoginModel
@inject WorkspaceContext WorkspaceContext

@{
    ViewData["Title"] = "Log in";
}

<div class="min-h-screen flex items-center justify-center px-4 py-8 bg-background">
    <div class="w-full max-w-md">
        <!-- Using text-text for the main heading -->
        <h1 class="text-3xl font-bold mb-8 text-center text-text">@ViewData["Title"]</h1>
        
        @if (WorkspaceContext.CurrentWorkspace != null)
        {
            <h2 class="text-l font-semibold mb-4 text-center text-text/80">@WorkspaceContext.CurrentWorkspace.Name</h2>
        }
        else
        {
            <h2 class="text-l font-semibold mb-4 text-center text-text/80">Conversey Admin Portal</h2>
        } 

        <!-- Kept bg-white for the card to pop against the bg-background -->
        <section class="bg-white rounded-lg shadow-md p-10 m-5 border border-secondary/20">
            <form id="account" method="post">
                <h2 class="text-xl font-semibold mb-4 text-text">Use a local account to log in.</h2>
                <hr class="mb-4 border-background" />
                
                <div asp-validation-summary="ModelOnly" class="text-accent bg-accent/10 p-3 rounded-md mb-4" role="alert"></div>
                
                <div class="mb-4">
                    <label asp-for="Input.Email" class="block text-sm font-medium text-text mb-1">Email</label>
                    <!-- Focus ring changed to primary -->
                    <input asp-for="Input.Email" class="block w-full px-3 py-2 border border-secondary/30 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-accent text-sm mt-1 block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Password" class="block text-sm font-medium text-text mb-1">Password</label>
                    <input asp-for="Input.Password" class="block w-full px-3 py-2 border border-secondary/30 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <span asp-validation-for="Input.Password" class="text-accent text-sm mt-1 block"></span>
                </div>

                <div class="flex items-center mb-4">
                    <!-- Checkbox uses primary -->
                    <input class="w-4 h-4 text-primary rounded focus:ring-2 focus:ring-primary" type="checkbox" asp-for="Input.RememberMe" />
                    <label asp-for="Input.RememberMe" class="ml-2 text-sm font-medium text-text">
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>

                <div class="mb-6">
                    <!-- Primary button with hover state -->
                    <button id="login-submit" type="submit" class="w-full px-4 py-2 bg-primary text-white font-medium rounded-md hover:opacity-90 transition-opacity">Log in</button>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
