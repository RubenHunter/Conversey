@page
@using Conversey.UI_MVC.Models
@model LoginModel
@inject WorkspaceContext WorkspaceContext

@{
    ViewData["Title"] = "Log in";
}

<div class="min-h-screen flex items-center justify-center px-4 py-8 bg-gray-50">
    <div class="w-full max-w-md">
        <h1 class="text-3xl font-bold mb-8 text-center">@ViewData["Title"]</h1>
        @if (WorkspaceContext.CurrentWorkspace != null)
{
    <h2 class="text-l font-semibold mb-4 text-center">@WorkspaceContext.CurrentWorkspace.Name</h2>
}
else
{
    <h2 class="text-l font-semibold mb-4 text-center">Conversey Admin Portal</h2>
} 
        <section class="bg-white rounded-lg shadow-md p-10 m-5">
            <form id="account" method="post">
                <h2 class="text-xl font-semibold mb-4">Use a local account to log in.</h2>
                <hr class="mb-4" />
                <div asp-validation-summary="ModelOnly" class="text-red-600 bg-red-50 p-3 rounded-md mb-4" role="alert"></div>
                <div class="mb-4">
                    <label asp-for="Input.Email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input asp-for="Input.Email" class="block w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-red-600 text-sm mt-1 block"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Input.Password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <input asp-for="Input.Password" class="block w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <span asp-validation-for="Input.Password" class="text-red-600 text-sm mt-1 block"></span>
                </div>
                <div class="flex items-center mb-4">
                    <input class="w-4 h-4 text-blue-600 rounded focus:ring-2 focus:ring-blue-500" type="checkbox" asp-for="Input.RememberMe" />
                    <label asp-for="Input.RememberMe" class="ml-2 text-sm font-medium text-gray-700">
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div class="mb-6">
                    <button id="login-submit" type="submit" class="w-full px-4 py-2 bg-blue-600 text-white font-medium rounded-md hover:bg-blue-700 transition-colors">Log in</button>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
